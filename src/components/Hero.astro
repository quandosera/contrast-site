---
// src/components/Hero.astro
interface Props {
  title: string;
  accent: string;
  subtextText?: string;
  subtextHighlight?: string;
  bgImage?: string;
}

const { 
  title, 
  accent, 
  subtextText,
  subtextHighlight,
  bgImage = "https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop" 
} = Astro.props;
---

<section class="relative overflow-hidden min-h-[380px] md:min-h-[480px] flex items-center justify-center bg-brand-dark group">
    
    <div class="absolute inset-0 z-0">
        <img 
            src={bgImage} 
            alt="" 
            class="w-full h-full object-cover opacity-30 select-none pointer-events-none" 
        />
        
        <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/90 via-transparent to-brand-dark"></div>
        
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(10,10,10,0.4)_100%)]"></div>
        
        <div class="absolute inset-0 opacity-[0.03] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 relative z-10 flex flex-col items-center text-center pt-28 pb-12 md:pt-36 md:pb-16">
        
        <h1 class="flex flex-wrap justify-center items-center gap-x-3 md:gap-x-5 gap-y-1 text-5xl sm:text-6xl lg:text-7xl font-black tracking-tighter uppercase italic select-none mb-6">
            <span class="text-white drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] whitespace-nowrap">
                {title}
            </span> 
            <span class="text-transparent bg-clip-text bg-gradient-to-br from-white via-white to-brand-accent drop-shadow-[0_0_30px_rgba(255,59,59,0.3)] pr-4 py-1 whitespace-nowrap">
                {accent}
            </span>
        </h1>
        
        {subtextText && (
            <div class="inline-flex items-center gap-3 bg-white/[0.02] border border-white/10 backdrop-blur-3xl px-5 py-2.5 rounded-xl md:rounded-2xl shadow-xl group/sub transition-all hover:bg-white/[0.05] hover:border-brand-accent/40">
                <div class="flex gap-1.5">
                    <div class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-pulse shadow-[0_0_8px_rgba(255,59,59,0.5)]"></div>
                </div>

                <p class="text-gray-400 font-black tracking-[0.3em] md:tracking-[0.4em] uppercase text-[9px] md:text-[11px] italic whitespace-nowrap">
                    {subtextText} 
                    {subtextHighlight && (
                        <>
                            <span class="mx-2 text-white/10">|</span> 
                            <span class="text-white group-hover/sub:text-brand-accent transition-colors">{subtextHighlight}</span>
                        </>
                    )}
                </p>

                <div class="flex gap-1.5">
                    <div class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-pulse shadow-[0_0_8px_rgba(255,59,59,0.5)]"></div>
                </div>
            </div>
        )}
        
        <div class="mt-8">
            <slot />
        </div>
        
    </div>
</section>

<style>
    /* Keeps images smooth during any subtle shifts */
    img {
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
    }
</style>
