---
// src/components/Hero.astro
interface Props {
  title: string;
  accent: string;
  subtextText?: string;
  subtextHighlight?: string;
  bgImage?: string;
}

const { 
  title, 
  accent, 
  subtextText,
  subtextHighlight,
  bgImage = "https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop" 
} = Astro.props;
---

<section class="relative pt-28 pb-16 md:pt-44 md:pb-28 overflow-hidden border-b border-white/5">
    <div class="absolute inset-0 z-0">
        <img src={bgImage} alt="Background" class="w-full h-full object-cover opacity-10 scale-105 select-none pointer-events-none" />
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,59,59,0.15)_0%,transparent_70%)]"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/40 via-brand-dark/90 to-brand-dark"></div>
        <div class="absolute inset-0 opacity-[0.04] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none"></div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 relative z-10 flex flex-col items-center text-center">
        
        <h1 class="flex flex-wrap justify-center items-center gap-x-3 md:gap-x-5 gap-y-1 md:gap-y-2 text-5xl sm:text-6xl lg:text-7xl font-black tracking-tight uppercase italic select-none mb-8">
            
            <span class="text-white drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] whitespace-nowrap">
                {title}
            </span> 
            
            <span class="text-transparent bg-clip-text bg-gradient-to-br from-white via-white to-brand-accent/80 drop-shadow-[0_0_40px_rgba(255,59,59,0.3)] pr-6 py-2 whitespace-nowrap">
                {accent}
            </span>
            
        </h1>
        
        {subtextText && (
            <div class="inline-flex items-center gap-3 md:gap-4 bg-white/[0.03] border border-white/10 backdrop-blur-2xl px-5 py-2.5 md:px-8 md:py-3.5 rounded-xl md:rounded-2xl shadow-2xl group transition-all hover:bg-white/[0.05] hover:border-brand-accent/30">
                
                <div class="flex gap-1">
                    <div class="w-1 h-1 rounded-full bg-brand-accent animate-pulse"></div>
                    <div class="w-1 h-1 rounded-full bg-brand-accent/40 hidden sm:block"></div>
                </div>

                <p class="text-gray-400 font-black tracking-[0.2em] md:tracking-[0.4em] uppercase text-[9px] md:text-[11px] italic whitespace-nowrap">
                    {subtextText} 
                    {subtextHighlight && (
                        <Fragment>
                            <span class="mx-1 md:mx-2 text-white/20">//</span> 
                            <span class="text-white group-hover:text-brand-accent transition-colors">{subtextHighlight}</span>
                        </Fragment>
                    )}
                </p>

                <div class="flex gap-1">
                    <div class="w-1 h-1 rounded-full bg-brand-accent/40 hidden sm:block"></div>
                    <div class="w-1 h-1 rounded-full bg-brand-accent animate-pulse"></div>
                </div>
                
            </div>
        )}
        
        <slot />
        
    </div>
</section>
