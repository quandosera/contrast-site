---
// src/components/Player.astro
interface Props {
    currentShow: string;
    djName?: string;
}

const { 
    currentShow = "Contrast Selection", 
    djName = "Contrast DJ" 
} = Astro.props;

// Combining them for the scrolling marquee
const displayInfo = `${djName} - ${currentShow}`.toUpperCase();
---

<div class="fixed bottom-0 left-0 w-full bg-brand-dark z-50 px-5 py-4 md:py-5 border-t border-white/10 shadow-[0_-20px_50px_rgba(0,0,0,0.9)]" transition:persist>
    
    <div class="container mx-auto flex items-center justify-between md:grid md:grid-cols-3 max-w-7xl">
        
        <div class="flex items-center gap-4 min-w-0 pr-4">
            <div class="relative w-14 h-14 md:w-16 md:h-16 flex-shrink-0 bg-brand-dark rounded-xl overflow-hidden flex items-center justify-center border border-white/10 shadow-2xl">
                <i id="player-vinyl" class="fa-solid fa-compact-disc text-3xl md:text-5xl text-zinc-800 animate-spin-slow pause-spin"></i>
                <div id="player-status-icon" class="absolute inset-0 bg-black/40 hidden items-center justify-center">
                    <i class="fa-solid fa-chart-simple text-brand-accent text-xl animate-pulse"></i>
                </div>
            </div>
            
            <div class="flex flex-col min-w-0 overflow-hidden">
                <span class="text-[10px] md:text-xs font-black text-brand-accent tracking-[0.3em] uppercase flex items-center gap-1.5 mb-1">
                    <span class="w-2 h-2 rounded-full bg-brand-accent animate-ping"></span> NOW PLAYING
                </span>
                
                <div class="player-marquee-container relative w-full overflow-hidden h-5 md:h-7">
                    <div class="player-marquee-inner flex whitespace-nowrap italic font-black text-white text-xs md:text-lg uppercase">
                        <span class="pr-10 marquee-text-source">{displayInfo}</span>
                        <span class="pr-10">{displayInfo}</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex md:justify-center flex-shrink-0">
            <button id="master-play-btn" class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-brand-accent text-white flex items-center justify-center hover:scale-110 active:scale-90 transition-all border-2 border-brand-accent/50 shadow-[0_0_30px_rgba(255,59,59,0.3)]">
                <i class="fa-solid fa-play ml-1 text-xl md:text-2xl"></i>
            </button>
        </div>

        <div class="hidden md:flex justify-end items-center gap-4">
            <button id="mute-btn" class="text-gray-400 hover:text-white transition-colors">
                <i id="volume-icon" class="fa-solid fa-volume-high text-lg"></i>
            </button>
            <div class="w-24 lg:w-32 flex items-center">
                <input id="volume-slider" class="premium-slider" type="range" min="0" max="1" step="0.01" value="0.8">
            </div>
        </div>

    </div>
    <div class="h-[env(safe-area-inset-bottom)] w-full"></div>
    
    <audio id="stream-audio" crossorigin="anonymous" transition:persist></audio>
</div>

<script>
    const STREAM_URL = 'https://s10.myradiostream.com:35080/listen.mp3';
    // IMPORTANT: Ensure your image is moved to public/images/contrast.png
    const STATION_LOGO_PATH = '/images/contrast.png';
    let previousVolume = 0.8;

    // --- NEW FUNCTION: MEDIA SESSION API ---
    function updateMediaSession() {
        if ('mediaSession' in navigator) {
            // Grabs whatever is currently showing in the marquee
            const marqueeText = document.querySelector('.marquee-text-source')?.textContent || "CONTRAST RADIO";
            
            // Default fallback values
            let artistStr = "Contrast Radio";
            let titleStr = "Live Broadcast";

            // Tries to split "DJ NAME - SHOW NAME"
            if (marqueeText.includes(' - ')) {
                const parts = marqueeText.split(' - ');
                artistStr = parts[0] || "Contrast DJ";
                titleStr = parts[1] || "Contrast Selection";
            } else {
                 // If format is different, just show the whole text as title
                titleStr = marqueeText;
            }

            // Update the phone's Now Playing info
            navigator.mediaSession.metadata = new MediaMetadata({
                title: titleStr,
                artist: artistStr,
                album: "Contrast Radio - The Next Movement",
                artwork: [
                    // We use the same high-res image for all sizes; modern OSs handle scaling.
                    { src: STATION_LOGO_PATH, sizes: '96x96',   type: 'image/png' },
                    { src: STATION_LOGO_PATH, sizes: '128x128', type: 'image/png' },
                    { src: STATION_LOGO_PATH, sizes: '192x192', type: 'image/png' },
                    { src: STATION_LOGO_PATH, sizes: '256x256', type: 'image/png' },
                    { src: STATION_LOGO_PATH, sizes: '512x512', type: 'image/png' },
                ]
            });

            // Ensure lock screen buttons work
            const audio = document.getElementById('stream-audio') as HTMLAudioElement;
            if (audio) {
                    navigator.mediaSession.setActionHandler('play', () => {
                    if (!audio.src.includes('listen.mp3')) audio.src = STREAM_URL;
                    audio.play().catch(e => console.error("Lock screen play error", e));
                });
                navigator.mediaSession.setActionHandler('pause', () => audio.pause());
                navigator.mediaSession.setActionHandler('stop', () => {
                    audio.pause();
                    audio.src = ""; // Clear buffer on stop
                });
                    // Disable seek buttons for live radio
                navigator.mediaSession.setActionHandler('seekbackward', null);
                navigator.mediaSession.setActionHandler('seekforward', null);
            }
        }
    }
    // ---------------------------------------


    function syncAllButtons() {
        const audio = document.getElementById('stream-audio') as HTMLAudioElement;
        if (!audio) return;

        const isPlaying = !audio.paused && audio.src.includes('listen.mp3');
        const vinyl = document.getElementById('player-vinyl');
        const statusIcon = document.getElementById('player-status-icon');
        const masterBtn = document.getElementById('master-play-btn');

        if (isPlaying) {
            vinyl?.classList.remove('pause-spin');
            statusIcon?.classList.replace('hidden', 'flex');
            if (masterBtn?.querySelector('i')) masterBtn.querySelector('i')!.className = 'fa-solid fa-stop text-xl md:text-2xl';
            
            // FIRE THE UPDATE WHEN PLAYING STARTS
            updateMediaSession();

        } else {
            vinyl?.classList.add('pause-spin');
            statusIcon?.classList.replace('flex', 'hidden');
            if (masterBtn?.querySelector('i')) masterBtn.querySelector('i')!.className = 'fa-solid fa-play ml-1 text-xl md:text-2xl';
        }

        document.querySelectorAll('.player-trigger, .nav-player-trigger').forEach((btn: any) => {
            const icon = btn.querySelector('i');
            const textSpan = btn.querySelector('.btn-text');
            if (isPlaying) {
                if (icon) icon.className = btn.classList.contains('nav-player-trigger') ? 'fa-solid fa-pause btn-icon' : 'fa-solid fa-stop mr-2';
                if (textSpan) textSpan.textContent = btn.classList.contains('nav-player-trigger') ? 'PAUSE' : 'STOP';
            } else {
                if (icon) icon.className = btn.classList.contains('nav-player-trigger') ? 'fa-solid fa-play btn-icon' : 'fa-solid fa-play mr-2';
                if (textSpan) textSpan.textContent = btn.classList.contains('nav-player-trigger') ? 'LISTEN' : 'TUNE IN NOW';
            }
        });
    }

    function initPlayer() {
        const audio = document.getElementById('stream-audio') as HTMLAudioElement;
        if (!audio) return;

        if (!window.__eventListenersBound) {
            document.addEventListener('click', async (e) => {
                const target = (e.target as HTMLElement).closest('#master-play-btn, .player-trigger, .nav-player-trigger');
                if (!target) return;

                // Check if we need to start or stop
                if (audio.paused || !audio.src.includes('listen.mp3')) {
                    // STARTING
                    audio.src = STREAM_URL;
                    try { await audio.play(); } catch (err) { console.error("Stream error:", err); }
                } else {
                    // STOPPING
                    audio.pause();
                    // Important for live radio: clear source to stop buffering
                    audio.src = ""; 
                }
                syncAllButtons();
            });

            // Keep UI synced if audio stops for other reasons (buffering, external pause)
            audio.addEventListener('play', syncAllButtons);
            audio.addEventListener('pause', syncAllButtons);
            window.__eventListenersBound = true;
        }

        // --- Volume Slider Logic (Unchanged) ---
        const slider = document.getElementById('volume-slider') as HTMLInputElement;
        const volIcon = document.getElementById('volume-icon');
        const muteBtn = document.getElementById('mute-btn');

        if (slider) {
            // FIX: Using hardcoded hex to ensure gradient reliability
            const ACCENT_COLOR = '#ff3b3b'; 

            const updateVisuals = (v: number) => {
                const p = v * 100;
                // Applies the red accent fill to the left of the thumb
                slider.style.background = `linear-gradient(to right, ${ACCENT_COLOR} 0%, ${ACCENT_COLOR} ${p}%, rgba(255,255,255,0.1) ${p}%, rgba(255,255,255,0.1) 100%)`;
                
                if (volIcon) {
                    volIcon.className = v === 0 ? 'fa-solid fa-volume-xmark text-brand-accent' : v < 0.5 ? 'fa-solid fa-volume-low text-gray-300' : 'fa-solid fa-volume-high text-white';
                }
            };

            // Initialize slider position based on current audio volume
            slider.value = audio.volume.toString();
            updateVisuals(audio.volume);

            slider.oninput = (e) => {
                const v = parseFloat((e.target as HTMLInputElement).value);
                audio.volume = v;
                updateVisuals(v);
                if (v > 0) previousVolume = v;
            };

            if (muteBtn) {
                muteBtn.onclick = () => {
                    // Toggle between 0 and the last known volume
                    audio.volume = audio.volume > 0 ? 0 : previousVolume;
                    slider.value = audio.volume.toString();
                    updateVisuals(audio.volume);
                };
            }
        }
        // ------------------------------------

        // Final sync on load to ensure correct state
        syncAllButtons();
    }

    // Using astro:page-load ensures this runs on initial load AND subsequent navigations
    document.addEventListener('astro:page-load', initPlayer);
</script>

<style is:global>
    .animate-spin-slow { animation: spin 5s linear infinite; }
    .pause-spin { animation-play-state: paused !important; }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* ACCENTED SLIDER BASE STYLES */
    .premium-slider {
        -webkit-appearance: none; appearance: none;
        width: 100%; height: 4px; border-radius: 999px;
        background: rgba(255,255,255,0.1); outline: none;
        cursor: pointer;
    }
    
    /* CHROME/SAFARI THUMB */
    .premium-slider::-webkit-slider-thumb {
        -webkit-appearance: none; height: 16px; width: 16px;
        border-radius: 50%; background: #ffffff; cursor: pointer;
        box-shadow: 0 0 10px rgba(255, 59, 59, 0.5); /* Red glow */
        border: none;
        margin-top: -6px; /* Centers thumb on the track */
    }

    /* FIREFOX THUMB */
    .premium-slider::-moz-range-thumb {
        height: 16px; width: 16px; border-radius: 50%;
        background: #ffffff; cursor: pointer; border: none;
        box-shadow: 0 0 10px rgba(255, 59, 59, 0.5); /* Red glow */
    }
</style>
