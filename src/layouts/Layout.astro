---
import { ClientRouter } from 'astro:transitions';
import Player from '../components/Player.astro';

interface Props {
    title?: string;
    currentShow?: string;
}

const { 
    title = "Contrast Radio | Up and Coming",
    currentShow = "Contrast Selection" 
} = Astro.props;

const pageTitle = currentShow !== "Contrast Selection" && currentShow !== "Auto DJ Mix" 
    ? `${currentShow} | Contrast Radio` 
    : title;
---
<!doctype html>
<html lang="en-GB" class="scroll-smooth bg-brand-dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>

        <ClientRouter />

        <meta name="description" content="Contrast Radio — Up & Coming. Independent community radio." />
        <link rel="icon" href="/favicon.ico" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    </head>
    <body class="antialiased text-white selection:bg-brand-accent/30 pb-28 bg-brand-dark font-['Inter',sans-serif]">

        <a class="skip-link" href="#main-content">Skip to content</a>

        <header id="main-header" class="fixed w-full top-0 z-50 h-24 transition-all duration-500 ease-in-out">
            <div class="container mx-auto px-6 sm:px-8 lg:px-12 flex items-center justify-between h-full max-w-screen-2xl relative z-10">
                
                <a href="/" class="flex items-center gap-5 group">
                    <div class="w-12 h-12 rounded-full bg-brand-accent flex items-center justify-center text-white group-hover:scale-110 transition-transform shadow-[0_0_30px_theme('colors.brand.accent/40')]">
                        <i class="fa-solid fa-podcast text-xl"></i>
                    </div>
                    <div class="flex flex-col justify-center">
                        <h1 class="text-2xl md:text-3xl font-black tracking-tighter leading-none uppercase italic">
                            CONTRAST<span class="text-brand-accent">RADIO</span>
                        </h1>
                        <span class="text-[0.7rem] text-gray-400 font-bold tracking-[0.4em] uppercase mt-1.5 opacity-80">Up & Coming</span>
                    </div>
                </a>

                <nav class="hidden lg:flex items-center space-x-10">
                    <a href="/" class="text-[0.75rem] font-black tracking-widest hover:text-brand-accent transition-colors uppercase">HOME</a>
                    <a href="/about" class="text-[0.75rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">ABOUT</a>
                    <a href="/djs" class="text-[0.75rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">DJ'S</a>
                    <a href="/schedule" class="text-[0.75rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">SCHEDULE</a>
                    <a href="/gallery" class="text-[0.75rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">GALLERY</a>
                    <a href="/contact" class="text-[0.75rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">CONTACT</a>
                    
                    <button id="nav-listen-btn" class="nav-player-trigger flex items-center justify-center gap-3 bg-brand-accent hover:bg-[#e02d2d] text-white text-[11px] font-black tracking-[0.2em] w-36 py-3 rounded-full transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-xl shadow-brand-accent/20 uppercase italic">
                        <i class="fa-solid fa-play text-[10px] btn-icon"></i>
                        <span class="btn-text">LISTEN</span>
                    </button>
                </nav>

                <div class="lg:hidden flex items-center gap-4">
                    <button id="mobile-menu-btn" class="text-gray-300 hover:text-white p-3" aria-label="Toggle menu">
                        <i class="fa-solid fa-bars text-3xl"></i>
                    </button>
                </div>
            </div>
            
            <div id="header-bg" class="absolute inset-0 bg-brand-dark/0 backdrop-blur-0 transition-all duration-500 pointer-events-none border-b border-white/0"></div>
        </header>

        <div id="mobile-menu" class="fixed inset-0 bg-brand-dark/98 backdrop-blur-3xl z-40 hidden flex-col justify-center items-center space-y-8 pt-10">
            <nav class="flex flex-col items-center space-y-6">
                <a href="/" class="text-4xl font-black text-white italic uppercase">HOME</a>
                <a href="/about" class="text-4xl font-black text-gray-400 italic uppercase">ABOUT</a>
                <a href="/djs" class="text-4xl font-black text-gray-400 italic uppercase">DJ'S</a>
                <a href="/schedule" class="text-4xl font-black text-gray-400 italic uppercase">SCHEDULE</a>
                
                <button class="nav-player-trigger mt-6 flex items-center justify-center gap-4 bg-brand-accent text-white text-xl font-black tracking-widest w-64 py-5 rounded-full shadow-2xl uppercase italic">
                    <i class="fa-solid fa-play btn-icon"></i>
                    <span class="btn-text">LISTEN</span>
                </button>
            </nav>
        </div>

        <main id="main-content" class="min-h-screen pt-0">
            <slot />
        </main>

        <footer class="bg-brand-surface py-24 border-t border-white/5 relative z-10">
            <div class="container mx-auto px-4 text-center">
                <p class="text-gray-600 text-[10px] uppercase tracking-[0.3em] font-black">
                    &copy; {new Date().getFullYear()} Contrast Radio.
                </p>
            </div>
        </footer>

        <Player currentShow={currentShow} />

        <script>
            function initHeader() {
                const header = document.getElementById('main-header');
                const headerBg = document.getElementById('header-bg');
                const menuBtn = document.getElementById('mobile-menu-btn');
                const mobileMenu = document.getElementById('mobile-menu');

                // Scroll Logic for Smooth UI Transition
                const handleScroll = () => {
                    if (window.scrollY > 40) {
                        headerBg?.classList.replace('bg-brand-dark/0', 'bg-brand-dark/80');
                        headerBg?.classList.replace('backdrop-blur-0', 'backdrop-blur-2xl');
                        headerBg?.classList.replace('border-white/0', 'border-white/10');
                    } else {
                        headerBg?.classList.replace('bg-brand-dark/80', 'bg-brand-dark/0');
                        headerBg?.classList.replace('backdrop-blur-2xl', 'backdrop-blur-0');
                        headerBg?.classList.replace('border-white/10', 'border-white/0');
                    }
                };

                window.addEventListener('scroll', handleScroll);
                handleScroll(); // Initial check

                // Mobile Menu Logic
                menuBtn?.addEventListener('click', () => {
                    const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
                    menuBtn.setAttribute('aria-expanded', String(!expanded));
                    mobileMenu?.classList.toggle('hidden');
                    mobileMenu?.classList.toggle('flex');
                    const icon = menuBtn.querySelector('i');
                    if (icon) icon.className = !expanded ? 'fa-solid fa-xmark text-3xl' : 'fa-solid fa-bars text-2xl';
                });
            }

            // Run on initial load and after Astro transitions
            document.addEventListener('astro:page-load', initHeader);
        </script>
    </body>
</html>

<style is:global>
    .skip-link { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0; }
    .skip-link:focus { position: fixed; top: 1rem; left: 1rem; z-index: 9999; padding: 0.75rem 1.5rem; background: theme('colors.brand.dark'); color: white; border-radius: 0.5rem; border: 1px solid theme('colors.brand.accent'); }

    /* Fix for smooth image rendering during scale transitions */
    img { backface-visibility: hidden; transform-style: preserve-3d; }
</style>
