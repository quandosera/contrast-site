---
import { ClientRouter } from 'astro:transitions';

interface Props {
    title?: string;
    currentShow?: string;
}

const { 
    title = "Contrast Radio | Up and Coming",
    currentShow = "Contrast Selection" 
} = Astro.props;

const pageTitle = currentShow !== "Contrast Selection" && currentShow !== "Auto DJ Mix" 
    ? `${currentShow} | Contrast Radio` 
    : title;
---
<!doctype html>
<html lang="en-GB" class="scroll-smooth bg-[#13111C]">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>

        <ClientRouter />

        <meta name="description" content="Contrast Radio — Up & Coming. Independent community radio with rotating shows and live streams." />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content="Contrast Radio — live shows, mixes and community programming." />
        <meta property="og:type" content="website" />
        <link rel="icon" href="/favicon.ico" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet">
        
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    </head>
    <body class="antialiased text-white selection:bg-purple-500/30 pb-20 bg-[#13111C]">

        <a class="skip-link" href="#main-content">Skip to content</a>

        <!-- Premium Fixed Header -->
        <header class="fixed w-full top-0 z-50 glass h-16 transition-all duration-300">
            <div class="container mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-full">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-3 group">
                    <div class="w-8 h-8 rounded-full bg-[#9b51e0] flex items-center justify-center text-white group-hover:scale-105 transition-transform shadow-lg shadow-purple-500/20">
                        <i class="fa-solid fa-podcast text-base"></i>
                    </div>
                    <div class="flex flex-col">
                        <h1 class="text-lg font-black tracking-tight leading-none uppercase italic">CONTRAST<span class="text-[#9b51e0]">RADIO</span></h1>
                        <span class="text-[0.6rem] text-gray-400 font-semibold tracking-[0.2em] uppercase mt-0.5">Up & Coming</span>
                    </div>
                </a>

                <!-- Desktop Nav -->
                <nav class="hidden md:flex items-center space-x-8">
                    <a href="/" class="text-[0.7rem] font-black tracking-widest hover:text-[#b77bed] transition-colors uppercase">HOME</a>
                    <a href="/about" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">ABOUT</a>
                    <a href="/djs" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">DJ'S</a>
                    <a href="/schedule" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">SCHEDULE</a>
                    <a href="/gallery" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">GALLERY</a>
                    <a href="/contact" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">CONTACT</a>
                </nav>

                <!-- Header Actions -->
                <div class="flex items-center gap-4">
                    <button class="hidden md:flex player-trigger bg-white text-[#13111C] w-36 justify-center py-2 rounded-full font-black text-[0.65rem] tracking-widest hover:bg-gray-200 transition-all items-center gap-2 shadow-xl active:scale-95 uppercase">
                        <i class="fa-solid fa-play text-[10px]"></i> Listen Live
                    </button>
                    <button id="mobile-menu-btn" class="md:hidden text-gray-300 hover:text-white p-2" aria-label="Toggle menu" aria-expanded="false">
                        <i class="fa-solid fa-bars text-xl"></i>
                    </button>
                </div>
            </div>
        </header>

        <!-- Mobile Menu Overlay -->
        <div id="mobile-menu" class="fixed inset-0 bg-[#13111C]/98 backdrop-blur-2xl z-40 hidden flex-col justify-center items-center space-y-8 pt-10">
            <nav class="flex flex-col items-center space-y-8">
                <a href="/" class="text-3xl font-black text-white hover:text-[#9b51e0]">HOME</a>
                <a href="/about" class="text-3xl font-black text-gray-400 hover:text-white">ABOUT</a>
                <a href="/djs" class="text-3xl font-black text-gray-400 hover:text-white">DJ'S</a>
                <a href="/schedule" class="text-3xl font-black text-gray-400 hover:text-white">SCHEDULE</a>
                <a href="/gallery" class="text-3xl font-black text-gray-400 hover:text-white">GALLERY</a>
                <a href="/contact" class="text-3xl font-black text-gray-400 hover:text-white">CONTACT</a>
                <button class="player-trigger bg-[#9b51e0] text-white w-64 py-4 flex justify-center items-center gap-3 rounded-full font-black text-lg mt-4 shadow-lg shadow-purple-500/30 uppercase tracking-widest"><i class="fa-solid fa-play text-[14px]"></i> Listen Live</button>
            </nav>
        </div>

        <!-- Content Slot -->
        <main id="main-content" class="min-h-screen">
            <slot />
        </main>

        <!-- Compact Footer -->
        <footer class="bg-[#0a090f] py-12 border-t border-gray-800/40">
            <div class="container mx-auto px-4 text-center">
                <div class="flex items-center justify-center gap-2 text-xl font-black mb-6 italic">
                    <i class="fa-solid fa-podcast text-[#9b51e0] text-lg"></i> CONTRAST RADIO
                </div>
                <div class="flex justify-center gap-6 mb-8">
                    <a href="#" class="w-9 h-9 rounded-full bg-gray-900 border border-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#9b51e0] hover:text-white hover:border-[#9b51e0] transition-all duration-300"><i class="fa-brands fa-facebook-f text-sm"></i></a>
                    <a href="#" class="w-9 h-9 rounded-full bg-gray-900 border border-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#9b51e0] hover:text-white hover:border-[#9b51e0] transition-all duration-300"><i class="fa-brands fa-twitter text-sm"></i></a>
                    <a href="#" class="w-9 h-9 rounded-full bg-gray-900 border border-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#9b51e0] hover:text-white hover:border-[#9b51e0] transition-all duration-300"><i class="fa-brands fa-instagram text-sm"></i></a>
                </div>
                <p class="text-gray-600 text-[9px] leading-relaxed uppercase tracking-[0.3em] font-black">
                    &copy; {new Date().getFullYear()} Contrast Radio. All rights reserved.<br>
                    Independent community radio.
                </p>
            </div>
        </footer>

        <!-- Balanced Persistent Bottom Player -->
        <div class="fixed bottom-0 left-0 w-full glass-player z-50 px-4 py-2.5 shadow-[0_-5px_25px_rgba(0,0,0,0.7)]" transition:persist>
            <div class="container mx-auto flex items-center justify-between gap-4">
                <!-- Info Section -->
                <div class="flex items-center gap-3 min-w-0 flex-1 md:flex-none md:w-1/3">
                    <div class="relative w-11 h-11 flex-shrink-0 bg-[#1E1B29] rounded-lg overflow-hidden flex items-center justify-center border border-gray-700/60 shadow-inner group">
                        <img src="https://images.unsplash.com/photo-1614613535308-eb5fbd3d2c17?q=80&w=100&auto=format&fit=crop" alt="Album Art" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        <div id="player-status-icon" class="absolute inset-0 bg-black/60 hidden items-center justify-center">
                            <i class="fa-solid fa-chart-simple text-[#b77bed] text-xs animate-pulse"></i>
                        </div>
                    </div>
                    <div class="flex flex-col min-w-0">
                        <span class="text-[9px] font-black text-[#9b51e0] tracking-[0.2em] uppercase flex items-center gap-1.5 mb-0.5 whitespace-nowrap">
                            <span class="w-1.5 h-1.5 rounded-full bg-[#9b51e0] animate-pulse flex-shrink-0"></span> Now playing
                        </span>
                        <div id="now-playing" class="text-[12px] font-black text-white truncate tracking-wide uppercase">{currentShow}</div>
                    </div>
                </div>

                <!-- Control Section -->
                <div class="flex items-center justify-end md:justify-center flex-shrink-0 md:w-1/3">
                    <button id="master-play-btn" class="w-11 h-11 flex-shrink-0 rounded-full bg-white text-[#13111C] flex items-center justify-center hover:scale-110 active:scale-95 transition-all shadow-[0_0_20px_rgba(255,255,255,0.15)]" aria-label="Play Stream">
                        <i class="fa-solid fa-play ml-0.5 text-base"></i>
                    </button>
                </div>

                <!-- Volume Section (Desktop) -->
                <div class="hidden md:flex items-center justify-end gap-3 w-1/3">
                    <button id="mute-btn" class="text-gray-500 hover:text-white transition-colors w-5" aria-label="Mute">
                        <i class="fa-solid fa-volume-high text-sm"></i>
                    </button>
                    <div class="w-24 flex items-center">
                        <input id="volume-slider" type="range" min="0" max="1" step="0.01" value="0.7">
                    </div>
                </div>
            </div>
            <!-- Persistent Audio Element -->
            <audio id="stream-audio" crossorigin="anonymous" transition:persist></audio>
        </div>

        <!-- Hidden Metadata to bridge data between pages -->
        <div id="show-metadata" data-show={currentShow} hidden></div>

        <!-- COMPREHENSIVE SCRIPTS -->
        <script>
            document.addEventListener('astro:page-load', () => {
                const STREAM_URL = 'https://s10.myradiostream.com:35080/listen.mp3';
                const audio = document.getElementById('stream-audio') as HTMLAudioElement;
                const menuBtn = document.getElementById('mobile-menu-btn');
                const mobileMenu = document.getElementById('mobile-menu');
                const playBtns = document.querySelectorAll('#master-play-btn, .player-trigger');
                const volumeSlider = document.getElementById('volume-slider') as HTMLInputElement;
                const muteBtn = document.getElementById('mute-btn');
                const playerStatusIcon = document.getElementById('player-status-icon');
                const nowPlayingText = document.getElementById('now-playing');
                const metaShow = document.getElementById('show-metadata');

                // 1. Mobile Menu Toggling
                menuBtn?.addEventListener('click', () => {
                    const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
                    menuBtn.setAttribute('aria-expanded', String(!expanded));
                    mobileMenu?.classList.toggle('hidden');
                    mobileMenu?.classList.toggle('flex');
                    const icon = menuBtn.querySelector('i');
                    if (icon) icon.className = !expanded ? 'fa-solid fa-xmark' : 'fa-solid fa-bars';
                });

                // 2. State Sync: Update text when navigating pages
                if (nowPlayingText && metaShow) {
                    nowPlayingText.innerText = metaShow.getAttribute('data-show') || "Contrast Selection";
                }

                const updateSliderFill = (val: number) => {
                    if (volumeSlider) volumeSlider.style.backgroundSize = `${val * 100}% 100%`;
                };

                const updateUIState = (isPlaying: boolean) => {
                    // Update master button icons
                    document.querySelectorAll('#master-play-btn i').forEach((i: any) => {
                        i.className = isPlaying ? 'fa-solid fa-pause' : 'fa-solid fa-play ml-0.5';
                    });
                    
                    // Update status bar icon
                    if (isPlaying) {
                        playerStatusIcon?.classList.remove('hidden');
                        playerStatusIcon?.classList.add('flex');
                    } else {
                        playerStatusIcon?.classList.remove('flex');
                        playerStatusIcon?.classList.add('hidden');
                    }
                    
                    // Sync all triggers on the page (Live badges, hero buttons)
                    document.querySelectorAll('.player-trigger').forEach((btn: any) => {
                        btn.innerHTML = isPlaying ? '<i class="fa-solid fa-pause text-[10px]"></i> PAUSE' : '<i class="fa-solid fa-play text-[10px]"></i> LISTEN LIVE';
                    });
                };

                if (audio) {
                    // 3. Audio Continuity: Sync UI if music is already playing from previous page
                    if (!audio.paused && audio.src !== "") updateUIState(true);
                    
                    if (volumeSlider) {
                        volumeSlider.value = String(audio.volume);
                        updateSliderFill(audio.volume);
                    }

                    // 4. Global Flag Initialization
                    if (!window.__playerInitialized) {
                        window.__playerInitialized = true;
                        audio.volume = 0.7;
                        audio.addEventListener('play', () => updateUIState(true));
                        audio.addEventListener('pause', () => updateUIState(false));
                    }

                    // 5. Safe Event Re-binding (Prevents listener stacking)
                    playBtns.forEach(btn => {
                        const newBtn = btn.cloneNode(true);
                        btn.parentNode?.replaceChild(newBtn, btn);
                        newBtn.addEventListener('click', async () => {
                            if (audio.paused || audio.src === "") {
                                try {
                                    audio.src = STREAM_URL;
                                    await audio.play();
                                    // FORCE UI UPDATE ON PLAY
                                    updateUIState(true);
                                } catch (err) { 
                                    console.error('Playback failed', err);
                                    updateUIState(false);
                                }
                            } else {
                                audio.pause();
                                audio.src = "";
                                // FORCE UI UPDATE ON PAUSE
                                updateUIState(false);
                            }
                        });
                    });

                    // 6. Volume Control Re-binding
                    if (volumeSlider) {
                        const newSlider = volumeSlider.cloneNode(true) as HTMLInputElement;
                        volumeSlider.parentNode?.replaceChild(newSlider, volumeSlider);
                        newSlider.addEventListener('input', (e) => {
                            const v = parseFloat((e.target as HTMLInputElement).value);
                            audio.volume = v;
                            updateSliderFill(v);
                        });
                    }

                    // 7. Mute Logic
                    if (muteBtn) {
                        const newMuteBtn = muteBtn.cloneNode(true) as HTMLElement;
                        muteBtn.parentNode?.replaceChild(newMuteBtn, muteBtn);
                        let prevVol = audio.volume || 0.7;
                        newMuteBtn.addEventListener('click', () => {
                            if (audio.volume > 0) {
                                prevVol = audio.volume;
                                audio.volume = 0;
                                if(volumeSlider) volumeSlider.value = "0";
                                updateSliderFill(0);
                            } else {
                                audio.volume = prevVol;
                                if(volumeSlider) volumeSlider.value = String(prevVol);
                                updateSliderFill(prevVol);
                            }
                        });
                    }
                }
            });
        </script>
    </body>
</html>

<style is:global>
    /* CSS Variables for Dark Theme Consistency */
    :root {
        --brand-purple: #9b51e0;
        --brand-dark: #13111C;
        --brand-surface: #1E1B29;
    }

    /* Base Styling */
    html, body { 
        background-color: var(--brand-dark); 
        color: white;
    }

    /* Reset default link colors shown in screenshot */
    a {
        color: inherit;
        text-decoration: none;
    }
    
    /* Glassmorphism Components */
    .glass { 
        background: rgba(19, 17, 28, 0.75); 
        backdrop-filter: blur(12px); 
        -webkit-backdrop-filter: blur(12px); 
        border-bottom: 1px solid rgba(255, 255, 255, 0.08); 
    }
    
    .glass-player { 
        background: rgba(19, 17, 28, 0.92); 
        backdrop-filter: blur(20px); 
        -webkit-backdrop-filter: blur(20px); 
        border-top: 1px solid rgba(255, 255, 255, 0.1); 
    }

    /* Accessibility: Skip Link */
    .skip-link { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border-width: 0; }
    .skip-link:focus { position: fixed; top: 1rem; left: 1rem; z-index: 9999; padding: 0.75rem 1.5rem; background: var(--brand-dark); color: white; border-radius: 0.5rem; text-decoration: none; font-weight: 800; border: 1px solid var(--brand-purple); }

    /* Custom Range Slider */
    input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; }
    input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 12px; width: 12px; border-radius: 50%; background: #ffffff; cursor: pointer; margin-top: -4.5px; box-shadow: 0 0 10px rgba(155, 81, 224, 0.5); }
    input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 3px; cursor: pointer; background: rgba(255, 255, 255, 0.1); border-radius: 2px; background-image: linear-gradient(var(--brand-purple), var(--brand-purple)); background-repeat: no-repeat; }

    /* Scrollbar */
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: var(--brand-dark); }
    ::-webkit-scrollbar-thumb { background: #333; border-radius: 10px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--brand-purple); }
</style>
