---
// src/layouts/Layout.astro
import { ClientRouter } from 'astro:transitions';
import Player from '../components/Player.astro';

interface Props {
    title?: string;
    currentShow?: string;
}

const { 
    title = "Contrast Radio | The Next Movement",
    currentShow = "Contrast Selection" 
} = Astro.props;

const pageTitle = currentShow !== "Contrast Selection" && currentShow !== "Auto DJ Mix" 
    ? `${currentShow} | Contrast Radio` 
    : title;
---
<!doctype html>
<html lang="en-GB" class="scroll-smooth bg-brand-dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>

        <ClientRouter />

        <meta name="description" content="Contrast Radio — The Next Movement. Independent community radio." />

        <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="shortcut icon" href="/favicon.ico" />

        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="manifest" href="/site.webmanifest" />

        <meta name="theme-color" content="#0b0b0b">

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;800;900&display=swap" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    </head>
    <body class="antialiased text-white selection:bg-brand-accent/30 bg-brand-dark font-['Inter',sans-serif]">

        <a class="sr-only-focusable" href="#main-content">Skip to content</a>

        <header id="main-header" class="fixed w-full top-0 z-50 h-24 transition-all duration-500 ease-in-out">
            <div class="container mx-auto px-6 sm:px-8 lg:px-12 flex items-center justify-between h-full max-w-screen-2xl relative z-10">
                
                <a href="/" class="flex items-center gap-5 group">
                    <div class="w-10 h-10 md:w-12 md:h-12 rounded-full bg-brand-accent flex items-center justify-center text-white group-hover:scale-110 transition-transform shadow-[0_0_30px_theme('colors.brand.accent/40')]">
                        <i class="fa-solid fa-podcast text-lg md:text-xl"></i>
                    </div>
                    <div class="flex flex-col justify-center">
                        <h1 class="text-xl md:text-2xl font-black tracking-tighter leading-none uppercase italic">
                            CONTRAST<span class="text-brand-accent">RADIO</span>
                        </h1>
                        <span class="text-[0.6rem] md:text-[0.7rem] text-gray-400 font-bold tracking-[0.4em] uppercase mt-1.5 opacity-80">The Next Movement</span>
                    </div>
                </a>

                <nav class="hidden lg:flex items-center space-x-8 xl:space-x-10">
                    <a href="/" class="text-[0.7rem] font-black tracking-widest hover:text-brand-accent transition-colors uppercase">HOME</a>
                    <a href="/about" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">ABOUT</a>
                    <a href="/djs" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">DJ'S</a>
                    <a href="/schedule" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">SCHEDULE</a>
                    <a href="/gallery" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">GALLERY</a>
                    
                    <a href="/chat" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-all uppercase hover:drop-shadow-[0_0_8px_rgba(255,255,255,0.5)]">CHAT</a>
                    
                    <a href="/contact" class="text-[0.7rem] font-black tracking-widest text-gray-400 hover:text-white transition-colors uppercase">CONTACT</a>
                    
                    <button id="nav-listen-btn" class="nav-player-trigger flex items-center justify-center gap-3 bg-brand-accent hover:bg-[#e02d2d] text-white text-[11px] font-black tracking-[0.2em] w-36 py-3 rounded-full transition-all duration-300 transform hover:scale-105 active:scale-95 shadow-xl shadow-brand-accent/20 uppercase italic">
                        <i class="fa-solid fa-play text-[10px] btn-icon"></i>
                        <span class="btn-text">LISTEN</span>
                    </button>
                </nav>

                <div class="lg:hidden flex items-center gap-4">
                    <button id="mobile-menu-btn" class="text-gray-300 hover:text-white p-3" aria-label="Toggle menu" aria-expanded="false">
                        <i class="fa-solid fa-bars text-2xl"></i>
                    </button>
                </div>
            </div>
            
            <div id="header-bg" class="absolute inset-0 bg-brand-dark/0 backdrop-blur-0 transition-all duration-500 pointer-events-none border-b border-white/0"></div>
        </header>

        <div id="mobile-menu" class="fixed inset-0 bg-brand-dark/98 backdrop-blur-3xl z-40 hidden flex-col justify-center items-center pt-10">
            <nav class="flex flex-col items-center space-y-5">
                <a href="/" class="text-3xl font-black text-white italic uppercase tracking-tighter hover:text-brand-accent transition-colors">HOME</a>
                <a href="/about" class="text-3xl font-black text-gray-400 italic uppercase tracking-tighter hover:text-white transition-colors">ABOUT</a>
                <a href="/djs" class="text-3xl font-black text-gray-400 italic uppercase tracking-tighter hover:text-white transition-colors">DJ'S</a>
                <a href="/schedule" class="text-3xl font-black text-gray-400 italic uppercase tracking-tighter hover:text-white transition-colors">SCHEDULE</a>
                
                <a href="/chat" class="text-3xl font-black text-brand-accent italic uppercase tracking-tighter animate-pulse">LIVE CHAT</a>
                
                <a href="/gallery" class="text-3xl font-black text-gray-400 italic uppercase tracking-tighter hover:text-white transition-colors">GALLERY</a>
                <a href="/contact" class="text-3xl font-black text-gray-400 italic uppercase tracking-tighter hover:text-white transition-colors">CONTACT</a>
            </nav>
        </div>

        <main id="main-content" class="min-h-screen pt-0 pb-32">
            <slot />
        </main>

        <Player currentShow={currentShow} />

        <script>
            function initHeader() {
                const headerBg = document.getElementById('header-bg');
                const menuBtn = document.getElementById('mobile-menu-btn');
                const mobileMenu = document.getElementById('mobile-menu');

                const handleScroll = () => {
                    if (window.scrollY > 40) {
                        headerBg?.classList.replace('bg-brand-dark/0', 'bg-brand-dark/90');
                        headerBg?.classList.replace('backdrop-blur-0', 'backdrop-blur-2xl');
                        headerBg?.classList.replace('border-white/0', 'border-white/10');
                    } else {
                        headerBg?.classList.replace('bg-brand-dark/90', 'bg-brand-dark/0');
                        headerBg?.classList.replace('backdrop-blur-2xl', 'backdrop-blur-0');
                        headerBg?.classList.replace('border-white/10', 'border-white/0');
                    }
                };

                window.addEventListener('scroll', handleScroll);
                handleScroll();

                menuBtn?.addEventListener('click', () => {
                    const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
                    menuBtn.setAttribute('aria-expanded', String(!expanded));
                    mobileMenu?.classList.toggle('hidden');
                    mobileMenu?.classList.toggle('flex');
                    document.body.classList.toggle('overflow-hidden'); 
                    
                    const icon = menuBtn.querySelector('i');
                    if (icon) icon.className = !expanded ? 'fa-solid fa-xmark text-3xl' : 'fa-solid fa-bars text-2xl';
                });

                const mobileLinks = mobileMenu?.querySelectorAll('a');
                mobileLinks?.forEach(link => {
                    link.addEventListener('click', () => {
                        mobileMenu?.classList.add('hidden');
                        mobileMenu?.classList.remove('flex');
                        document.body.classList.remove('overflow-hidden');
                        menuBtn?.setAttribute('aria-expanded', 'false');
                        const icon = menuBtn?.querySelector('i');
                        if (icon) icon.className = 'fa-solid fa-bars text-2xl';
                    });
                });
            }

            document.addEventListener('astro:page-load', initHeader);
        </script>
    </body>
</html>

<style is:global>
    /* Accessibility: Visual Hide Utility */
    .sr-only-focusable {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }
    .sr-only-focusable:focus {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 9999;
        width: auto;
        height: auto;
        padding: 0.75rem 1.5rem;
        background: #ff3b3b;
        color: white;
        border-radius: 999px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 12px;
        clip: auto;
    }

    /* Player Marquee Masking */
    .player-marquee-container {
        mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
        -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    }
    .player-marquee-inner {
        display: flex;
        width: max-content;
        animation: marquee-infinite 15s linear infinite;
        will-change: transform;
    }
    @keyframes marquee-infinite {
        0% { transform: translateX(0); }
        100% { transform: translateX(-50%); }
    }

    img { backface-visibility: hidden; transform-style: preserve-3d; }
</style>
