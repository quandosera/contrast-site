---
import { ClientRouter } from 'astro:transitions';

interface Props {
    title?: string;
    currentShow?: string;
}

const { 
    title = "Contrast Radio | Up and Coming",
    currentShow = "Contrast Selection" 
} = Astro.props;

const pageTitle = currentShow !== "Contrast Selection" && currentShow !== "Auto DJ Mix" 
    ? `${currentShow} | Contrast Radio` 
    : title;
---
<!doctype html>
<html lang="en-GB">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{pageTitle}</title>

        <ClientRouter />

        <meta name="description" content="Contrast Radio — Up & Coming. Independent community radio with rotating shows and live streams." />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content="Contrast Radio — live shows, mixes and community programming." />
        <meta property="og:type" content="website" />
        <link rel="icon" href="/favicon.ico" />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
        
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    </head>
    <body>

        <a class="skip-link" href="#main-content">Skip to content</a>

        <header class="site-header">
            <div class="container header-inner">
                <div class="logo">
                    <a href="/">
                        <div class="logo-icon"><i class="fa-solid fa-podcast"></i></div>
                        <div class="logo-text">
                            <h1>CONTRAST<span>RADIO</span></h1>
                            <span class="tagline">UP & COMING</span>
                        </div>
                    </a>
                </div>

                <nav class="desktop-nav">
                    <a href="/">HOME</a>
                    <a href="/about">ABOUT</a>
                    <a href="/djs">DJ'S</a>
                    <a href="/schedule">SCHEDULE</a>
                    <a href="/gallery">GALLERY</a>
                    <a href="/contact">CONTACT</a>
                </nav>

                <div class="header-right">
                    <button class="btn-primary desktop-only player-trigger">LISTEN LIVE</button>
                    <button id="mobile-menu-btn" aria-label="Toggle menu" aria-controls="mobile-menu" aria-expanded="false">
                        <i class="fa-solid fa-bars"></i>
                    </button>
                </div>
            </div>
        </header>

        <div id="mobile-menu" class="mobile-menu hidden">
            <nav>
                <a href="/">HOME</a>
                <a href="/about">ABOUT</a>
                <a href="/djs">DJ'S</a>
                <a href="/schedule">SCHEDULE</a>
                <a href="/gallery">GALLERY</a>
                <a href="/contact">CONTACT</a>
                <button class="btn-primary w-full player-trigger">LISTEN LIVE</button>
            </nav>
        </div>

        <main id="main-content" class="main-content">
            <slot />
        </main>

        <footer class="site-footer">
            <div class="container footer-inner">
                <div class="footer-logo">
                    <i class="fa-solid fa-podcast"></i> CONTRAST RADIO
                </div>
                <div class="footer-copy">
                    &copy; {new Date().getFullYear()} Contrast Radio. All rights reserved.
                </div>
                <div class="footer-socials">
                    <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                </div>
            </div>
        </footer>

        <div class="bottom-player" transition:persist>
            <div class="container player-inner">
                <div class="player-info">
                    <div class="player-icon" id="player-status-icon"><i class="fa-solid fa-wifi"></i></div>
                    <div class="player-text">
                        <span class="now-playing-label">NOW PLAYING</span>
                        <div class="now-playing-title" id="now-playing">{currentShow}</div>
                    </div>
                </div>
                
                <div class="player-controls">
                    <button class="play-circle-btn" id="master-play-btn" aria-label="Play Stream" aria-pressed="false">
                        <i class="fa-solid fa-play" aria-hidden="true"></i>
                    </button>
                </div>

                <div class="player-volume desktop-only" aria-label="Volume control">
                    <button class="mute-btn" id="mute-btn" aria-label="Mute">
                        <i class="fa-solid fa-volume-high"></i>
                    </button>
                    <input id="volume-slider" type="range" min="0" max="1" step="0.01" value="0.7">
                </div>
            </div>

            <audio id="stream-audio" crossorigin="anonymous" transition:persist></audio>
        </div>

        <div id="show-metadata" data-show={currentShow} hidden></div>

        <script>
            document.addEventListener('astro:page-load', () => {
                const menuBtn = document.getElementById('mobile-menu-btn');
                const mobileMenu = document.getElementById('mobile-menu');
                
                menuBtn?.addEventListener('click', () => {
                    const expanded = menuBtn.getAttribute('aria-expanded') === 'true';
                    menuBtn.setAttribute('aria-expanded', String(!expanded));
                    mobileMenu?.classList.toggle('hidden');
                    const icon = menuBtn.querySelector('i');
                    if (icon) {
                        icon.className = !expanded ? 'fa-solid fa-xmark' : 'fa-solid fa-bars';
                    }
                });

                const STREAM_URL = 'https://s10.myradiostream.com:35080/listen.mp3';
                const audio = document.getElementById('stream-audio') as HTMLAudioElement;
                const playBtns = document.querySelectorAll('#master-play-btn, .player-trigger');
                const volumeSlider = document.getElementById('volume-slider') as HTMLInputElement;
                const muteBtn = document.getElementById('mute-btn');
                const playerStatusIcon = document.getElementById('player-status-icon');
                
                // Update the "Now Playing" text when navigating to a new page
                const nowPlayingText = document.getElementById('now-playing');
                const metaShow = document.getElementById('show-metadata');
                if (nowPlayingText && metaShow) {
                    nowPlayingText.innerText = metaShow.getAttribute('data-show') || "Contrast Selection";
                }

                let previousVolume = 0.7;

                const updateUIState = (isPlaying: boolean) => {
                    const iconClass = isPlaying ? 'fa-solid fa-pause' : 'fa-solid fa-play';
                    document.querySelectorAll('#master-play-btn i').forEach(i => {
                        i.className = iconClass;
                    });
                    
                    if (isPlaying) {
                        playerStatusIcon?.classList.add('is-playing');
                    } else {
                        playerStatusIcon?.classList.remove('is-playing');
                    }
                };

                const updateSliderFill = (val: number) => {
                    if (volumeSlider) {
                        volumeSlider.style.backgroundSize = `${val * 100}% 100%`;
                    }
                };

                if (audio) {
                    // Make sure UI matches actual audio state when navigating pages
                    if (!audio.paused && audio.src !== "") {
                        updateUIState(true);
                    }
                    if (volumeSlider) {
                        volumeSlider.value = String(audio.volume);
                        updateSliderFill(audio.volume);
                    }

                    // Avoid duplicate audio event listeners
                    if (!window.__playerInitialized) {
                        window.__playerInitialized = true;
                        audio.volume = 0.7;
                        updateSliderFill(0.7);

                        audio.addEventListener('play', () => updateUIState(true));
                        audio.addEventListener('pause', () => updateUIState(false));
                    }

                    // Attach click events safely for the new page DOM
                    playBtns.forEach(btn => {
                        // Remove old listeners to prevent double-firing
                        const newBtn = btn.cloneNode(true);
                        btn.parentNode?.replaceChild(newBtn, btn);

                        newBtn.addEventListener('click', async () => {
                            if (audio.paused || audio.src === "") {
                                try {
                                    audio.src = STREAM_URL;
                                    await audio.play();
                                    updateUIState(true);
                                } catch (err) {
                                    console.error('Playback failed', err);
                                }
                            } else {
                                audio.pause();
                                audio.src = "";
                                updateUIState(false);
                            }
                        });
                    });

                    if (volumeSlider) {
                        const newSlider = volumeSlider.cloneNode(true) as HTMLInputElement;
                        volumeSlider.parentNode?.replaceChild(newSlider, volumeSlider);
                        newSlider.addEventListener('input', (e) => {
                            const v = parseFloat((e.target as HTMLInputElement).value);
                            audio.volume = v;
                            updateSliderFill(v);
                        });
                    }

                    if (muteBtn) {
                        const newMuteBtn = muteBtn.cloneNode(true) as HTMLElement;
                        muteBtn.parentNode?.replaceChild(newMuteBtn, muteBtn);
                        newMuteBtn.addEventListener('click', () => {
                            if (audio.volume > 0) {
                                previousVolume = audio.volume;
                                audio.volume = 0;
                                const vs = document.getElementById('volume-slider') as HTMLInputElement;
                                if(vs) vs.value = "0";
                                updateSliderFill(0);
                            } else {
                                audio.volume = previousVolume;
                                const vs = document.getElementById('volume-slider') as HTMLInputElement;
                                if(vs) vs.value = String(previousVolume);
                                updateSliderFill(previousVolume);
                            }
                        });
                    }
                }
            });
        </script>
    </body>
</html>

<style is:global>
    :root {
        --purple: #a855f7; 
        --purple-dark: #9333ea;
        --purple-light: #fdf4ff;
        --dark-bg: #111827;
        --text-main: #1f2937;
        --text-muted: #6b7280;
        --bg-body: #f8fafc;
        --border-light: #e2e8f0;
        --header-h: 80px;
        --player-h: 90px;
    }

    * { box-sizing: border-box; }
    body { 
        margin: 0; 
        font-family: 'Inter', sans-serif; 
        background: var(--bg-body); 
        color: var(--text-main); 
        padding-bottom: var(--player-h);
    }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; width: 100%; }
    .desktop-only { display: flex; }

    /* SKIP LINK */
    .skip-link {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border-width: 0;
    }
    .skip-link:focus {
        position: fixed;
        top: 1rem;
        left: 1rem;
        z-index: 9999;
        width: auto;
        height: auto;
        padding: 0.75rem 1.5rem;
        background: var(--dark-bg);
        color: white;
        border-radius: 0.5rem;
        text-decoration: none;
        font-weight: 800;
    }

    /* HEADER */
    .site-header { background: #fff; position: sticky; top: 0; z-index: 1000; height: var(--header-h); display: flex; align-items: center; border-bottom: 1px solid var(--border-light); }
    .header-inner { display: flex; justify-content: space-between; align-items: center; width: 100%; }
    .logo a { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--text-main); }
    .logo-icon { background: var(--dark-bg); color: var(--purple); width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .logo-text h1 { margin: 0; font-size: 1.4rem; font-weight: 900; letter-spacing: -0.5px; line-height: 1; text-transform: uppercase;}
    .logo-text span { color: var(--purple); }
    .tagline { display: block; font-size: 0.65rem; color: var(--text-muted); font-weight: 800; letter-spacing: 1px; margin-top: 2px; }

    .desktop-nav { display: flex; gap: 30px; }
    .desktop-nav a { text-decoration: none; color: var(--text-main); font-weight: 800; font-size: 0.85rem; transition: color 0.2s; text-transform: uppercase;}
    .desktop-nav a:hover { color: var(--purple); }

    .btn-primary { background: var(--purple); color: #fff; border: none; padding: 10px 24px; border-radius: 50px; font-weight: 800; font-size: 0.85rem; cursor: pointer; transition: 0.2s; }
    .btn-primary:hover { background: var(--purple-dark); transform: scale(1.05); }

    #mobile-menu-btn { display: none; background: none; border: none; font-size: 1.5rem; color: var(--text-main); cursor: pointer; }

    /* MOBILE MENU */
    .mobile-menu { position: fixed; top: var(--header-h); left: 0; width: 100%; height: calc(100vh - var(--header-h)); background: #fff; padding: 40px 20px; z-index: 999; transition: transform 0.3s ease; }
    .mobile-menu.hidden { transform: translateX(100%); }
    .mobile-menu nav { display: flex; flex-direction: column; gap: 20px; align-items: center; }
    .mobile-menu a { text-decoration: none; color: var(--text-main); font-weight: 900; font-size: 1.5rem; text-transform: uppercase; }

    /* FOOTER (REVERTED TO YOUR ORIGINAL CODE) */
    .site-footer { background: var(--dark-bg); color: #fff; padding: 3.5rem 0; margin-top: 4rem; }
    .footer-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 20px; }
    .footer-logo { font-weight: 900; font-size: 1.2rem; display: flex; align-items: center; gap: 10px; color: var(--purple); }
    .footer-copy { color: #9ca3af; font-size: 0.85rem; }
    .footer-socials { display: flex; gap: 15px; }
    .footer-socials a { color: #fff; background: rgba(255,255,255,0.1); width: 35px; height: 35px; display: flex; align-items: center; justify-content: center; border-radius: 50%; text-decoration: none; transition: 0.2s; }
    .footer-socials a:hover { background: var(--purple); }

    /* BOTTOM PLAYER */
    .bottom-player { position: fixed; bottom: 0; left: 0; width: 100%; background: #fff; border-top: 1px solid var(--border-light); height: var(--player-h); z-index: 2000; display: flex; align-items: center; }
    .player-inner { display: flex; justify-content: space-between; align-items: center; width: 100%; }
    
    /* 1. Left aligned info */
    .player-info { display: flex; align-items: center; gap: 15px; flex: 1; }
    
    .player-icon { background: var(--bg-body); color: var(--text-muted); width: 45px; height: 45px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; }
    .player-icon.is-playing { color: var(--purple); background: var(--purple-light); }
    .player-icon.is-playing i { animation: wifi-pulse 1.5s infinite linear; }
    
    @keyframes wifi-pulse {
        0% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(1.1); }
        100% { opacity: 1; transform: scale(1); }
    }

    .now-playing-label { font-size: 0.65rem; font-weight: 900; color: var(--purple); letter-spacing: 1px; }
    .now-playing-title { font-weight: 800; font-size: 0.95rem; color: var(--text-main); }

    /* 2. Centered controls */
    .player-controls { flex: 1; display: flex; justify-content: center; align-items: center; }
    
    .play-circle-btn { display: flex; align-items: center; justify-content: center; background: var(--purple); color: #fff; border: none; width: 55px; height: 55px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; transition: 0.2s; box-shadow: 0 4px 10px rgba(168, 85, 247, 0.4); }
    .play-circle-btn:hover { transform: scale(1.1); }

    /* 3. Right aligned volume */
    .player-volume { flex: 1; display: flex; justify-content: flex-end; align-items: center; gap: 12px; }
    
    /* MUTE BUTTON RESET (Fixed the system background rendering issue) */
    .mute-btn { 
        appearance: none !important;
        -webkit-appearance: none !important;
        background-color: transparent !important; 
        background: transparent !important; 
        border: none !important; 
        box-shadow: none !important;
        outline: none !important;
        padding: 0;
        margin: 0;
        color: var(--text-muted); 
        font-size: 1.2rem; 
        cursor: pointer; 
        transition: color 0.2s; 
        width: 24px; 
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .mute-btn:hover { color: var(--purple); }

    #volume-slider { -webkit-appearance: none; width: 100px; height: 4px; background: #e5e7eb; border-radius: 5px; background-image: linear-gradient(var(--purple), var(--purple)); background-repeat: no-repeat; cursor: pointer; }
    #volume-slider::-webkit-slider-thumb { -webkit-appearance: none; height: 14px; width: 14px; border-radius: 50%; background: var(--purple); border: 2px solid #fff; }

    /* RESPONSIVE */
    @media (max-width: 1024px) {
        .desktop-nav, .desktop-only { display: none !important; }
        #mobile-menu-btn { display: block; }
        .player-info { flex: 1; }
        .player-controls { flex: 1; justify-content: flex-end; } /* Push play button to the right on mobile */
        .now-playing-title { font-size: 0.8rem; max-width: 140px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .footer-inner { justify-content: center; flex-direction: column; text-align: center; }
    }
</style>