---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const allDjs = await getCollection('djs');
const allShows = await getCollection('shows');

// Fetch current show data for the header status
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

// 2. TIME LOGIC (For Header Status Synchronization)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[dateInUK.getDay()];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    return h * 60 + m;
}

const currentSlot = rawSlots.find(slot => {
    if (slot.day !== currentDayStr) return false;
    const start = timeToMins(slot.startTime);
    let end = timeToMins(slot.endTime || "00:00");
    if (end <= start) end += 1440;
    return currentMins >= start && currentMins < end;
});

const currentShowName = currentSlot ? 
    (currentSlot.show === 'Auto DJ' ? "Contrast Selection" : (allShows.find(s => s.id === currentSlot.show)?.data.title || "Unknown")) 
    : "Auto DJ Mix";

// 3. FILTERING & SORTING LOGIC
const sortedDjs = allDjs
    // Only show DJs where 'active' is true (or not explicitly set to false)
    .filter(dj => dj.data.active !== false)
    // Sort primarily by 'rank' number, then alphabetically by name for ties
    .sort((a, b) => {
        const rankA = a.data.rank ?? 99; // Fallback to 99 if rank is missing
        const rankB = b.data.rank ?? 99;
        
        if (rankA !== rankB) return rankA - rankB;
        
        const nameA = a.data.name || a.id;
        const nameB = b.data.name || b.id;
        return nameA.localeCompare(nameB);
    });

// 4. PREPARE CONTENT
const processedDjs = await Promise.all(sortedDjs.map(async (dj) => {
    const { Content } = await dj.render();
    return { ...dj, Content };
}));
---

<Layout title="Our Residents | Contrast Radio" currentShow={currentShowName}>
    
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1571266028243-3716f02d2d2e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80" alt="DJ Decks" class="w-full h-full object-cover opacity-20" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#13111C]/80 to-[#13111C]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic mb-4">
                OUR <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">RESIDENTS</span>
            </h1>
            <p class="text-gray-400 font-bold tracking-widest uppercase text-sm">The talent behind the sound of Contrast Radio</p>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-24">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            {processedDjs.map(dj => (
                <div class="group relative flex flex-col bg-[#1E1B29]/40 border border-gray-800/60 rounded-[2rem] overflow-hidden transition-all duration-500 hover:border-[#9b51e0]/40 hover:shadow-2xl hover:shadow-purple-500/10 hover:-translate-y-2">
                    
                    <div class="relative aspect-square overflow-hidden bg-gray-900">
                        {dj.data.avatar ? (
                            <img src={dj.data.avatar} alt={dj.data.name || dj.id} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center text-gray-700">
                                <i class="fa-solid fa-user text-6xl opacity-20"></i>
                            </div>
                        )}
                        
                        <div class="absolute inset-0 bg-[#9b51e0]/20 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                            <div class="flex gap-6 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                {dj.data.socials?.instagram && (
                                    <a href={`https://instagram.com/${dj.data.socials.instagram}`} target="_blank" class="w-12 h-12 rounded-full bg-white text-[#13111C] flex items-center justify-center text-xl hover:scale-110 transition-transform shadow-lg" aria-label="Instagram">
                                        <i class="fa-brands fa-instagram"></i>
                                    </a>
                                )}
                                {dj.data.socials?.soundcloud && (
                                    <a href={`https://soundcloud.com/${dj.data.socials.soundcloud}`} target="_blank" class="w-12 h-12 rounded-full bg-white text-[#13111C] flex items-center justify-center text-xl hover:scale-110 transition-transform shadow-lg" aria-label="Soundcloud">
                                        <i class="fa-brands fa-soundcloud"></i>
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-8 flex-grow flex flex-col">
                        <div class="mb-4">
                            <h3 class="text-2xl font-black text-white uppercase italic leading-tight group-hover:text-[#b77bed] transition-colors">
                                {dj.data.name || dj.id.replace(/\.[^/.]+$/, "")}
                            </h3>
                            {dj.data.genre && (
                                <span class="text-[9px] font-black text-[#9b51e0] bg-[#9b51e0]/10 px-2.5 py-1 rounded-full border border-[#9b51e0]/20 inline-block uppercase tracking-[0.2em] mt-2">
                                    {dj.data.genre}
                                </span>
                            )}
                        </div>

                        <div class="text-sm text-gray-400 leading-relaxed line-clamp-2 mt-2 group-hover:text-gray-300 transition-colors">
                            <dj.Content />
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>
