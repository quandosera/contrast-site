---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro'; // Import your new component
import { getCollection, getEntry, render } from 'astro:content';

// 1. DATA FETCHING
const allDjs = await getCollection('djs');
const allShows = await getCollection('shows');

// Fetch current show data for the header status with fallback
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

// 2. TIME LOGIC (For Header Status Synchronization)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[dateInUK.getDay()];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    return h * 60 + m;
}

const currentSlot = rawSlots.find(slot => {
    if (slot.day !== currentDayStr) return false;
    const start = timeToMins(slot.startTime);
    let end = timeToMins(slot.endTime || "00:00");
    if (end <= start) end += 1440;
    return currentMins >= start && currentMins < end;
});

const currentShowName = currentSlot ? 
    (currentSlot.show === 'Auto DJ' ? "Contrast Selection" : (allShows.find(s => s.id === currentSlot.show)?.data.title || "Unknown")) 
    : "Auto DJ Mix";

// 3. FILTERING & SORTING LOGIC
const sortedDjs = allDjs
    .filter(dj => dj.data.active !== false)
    .sort((a, b) => {
        const rankA = a.data.rank ?? 99; 
        const rankB = b.data.rank ?? 99;
        if (rankA !== rankB) return rankA - rankB;
        const nameA = a.data.name || a.id;
        const nameB = b.data.name || b.id;
        return nameA.localeCompare(nameB);
    });

// 4. PREPARE CONTENT (Astro 5 Render)
const processedDjs = await Promise.all(sortedDjs.map(async (dj) => {
    const { Content } = await render(dj);
    return { ...dj, Content };
}));
---

<Layout title="Our Residents | Contrast Radio" currentShow={currentShowName}>
    
    <Hero 
        title="OUR" 
        accent="RESIDENTS" 
        subtextText="Curated Underground Selection" 
        subtextHighlight="Resident Talent"
        bgImage="https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop"
    />

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-32">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            {processedDjs.map(dj => (
                <div class="group relative flex flex-col bg-brand-surface/40 backdrop-blur-xl border border-white/5 rounded-[2.5rem] overflow-hidden transition-all duration-700 hover:border-brand-accent/30 hover:shadow-[0_30px_60px_rgba(0,0,0,0.5)] hover:-translate-y-2">
                    
                    <div class="relative aspect-square overflow-hidden bg-gray-900">
                        {dj.data.avatar ? (
                            <img src={dj.data.avatar} alt={dj.data.name || dj.id} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 group-hover:rotate-1" />
                        ) : (
                            <div class="w-full h-full flex items-center justify-center text-gray-800">
                                <i class="fa-solid fa-user text-6xl opacity-20"></i>
                            </div>
                        )}
                        
                        <div class="absolute inset-0 bg-brand-accent/20 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                            <div class="flex gap-6 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-700">
                                {dj.data.socials?.instagram && (
                                    <a href={`https://instagram.com/${dj.data.socials.instagram}`} target="_blank" class="w-12 h-12 rounded-full bg-white text-brand-dark flex items-center justify-center text-xl hover:scale-125 hover:bg-brand-accent hover:text-white transition-all shadow-2xl" aria-label="Instagram">
                                        <i class="fa-brands fa-instagram"></i>
                                    </a>
                                )}
                                {dj.data.socials?.soundcloud && (
                                    <a href={`https://soundcloud.com/${dj.data.socials.soundcloud}`} target="_blank" class="w-12 h-12 rounded-full bg-white text-brand-dark flex items-center justify-center text-xl hover:scale-125 hover:bg-brand-accent hover:text-white transition-all shadow-2xl" aria-label="Soundcloud">
                                        <i class="fa-brands fa-soundcloud"></i>
                                    </a>
                                )}
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-10 flex-grow flex flex-col relative">
                        <div class="mb-6">
                            <h3 class="text-3xl font-black text-white uppercase italic leading-none group-hover:text-brand-accent transition-colors">
                                {dj.data.name || dj.id.replace(/\.[^/.]+$/, "")}
                            </h3>
                            {dj.data.genre && (
                                <span class="text-[9px] font-black text-brand-accent bg-brand-accent/10 px-3 py-1.5 rounded-full border border-brand-accent/20 inline-block uppercase tracking-[0.2em] mt-4">
                                    {dj.data.genre}
                                </span>
                            )}
                        </div>

                        <div class="text-sm text-gray-400 leading-relaxed line-clamp-4 mt-2 group-hover:text-gray-300 transition-colors font-medium">
                            <dj.Content />
                        </div>

                        <div class="absolute bottom-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-accent/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>
