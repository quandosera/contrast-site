---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Us | Contrast Radio">
    
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop&ixlib=rb-4.1.0" alt="Radio Studio Mixing Desk" class="w-full h-full object-cover opacity-20" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#13111C]/80 to-[#13111C]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic mb-4">
                ABOUT <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">CONTRAST</span>
            </h1>
            <p class="text-gray-400 font-bold tracking-widest uppercase text-sm">Broadcasting the very best underground sounds, 24/7</p>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-24">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start max-w-6xl mx-auto mb-24">
            
            <!-- Story Column -->
            <div class="space-y-8">
                <div class="flex items-center gap-3">
                    <div class="text-[#9b51e0] text-2xl"><i class="fa-solid fa-broadcast-tower"></i></div>
                    <h2 class="text-3xl font-black uppercase italic tracking-tight text-white">Our Story</h2>
                </div>
                
                <p class="text-xl font-bold text-white leading-relaxed italic border-l-4 border-[#9b51e0] pl-6 py-2">
                    Contrast Radio is an independent, community-driven platform dedicated to delivering the finest authentic music to listeners across the globe.
                </p>
                
                <div class="space-y-6 text-gray-400 leading-relaxed">
                    <p>
                        Born out of a deep passion for underground and culture-defining sounds, we set out to create a space where music truly matters. We are not bound by commercial playlists or corporate algorithms; our selections are hand-picked by DJs who live and breathe the culture.
                    </p>

                    <p>
                        From the heavy basslines of classic Reggae and the smooth grooves of neo-Soul and R&B, to the late-night energy of underground House music, Contrast Radio spans the spectrum of rhythm and vibe. We champion the up-and-coming alongside the legendary, providing a crucial platform for DJs, producers, and artists to share their craft.
                    </p>
                </div>

                <!-- Mission Box (Glass Styled) -->
                <div class="bg-[#1E1B29]/60 backdrop-blur-md border border-gray-800/60 p-8 rounded-3xl shadow-xl">
                    <h3 class="text-white font-black text-xl mb-4 flex items-center gap-3 uppercase italic">
                        <i class="fa-solid fa-bullseye text-[#9b51e0]"></i> Our Mission
                    </h3>
                    <p class="text-gray-400 leading-relaxed italic">To connect diverse communities through a shared love of authentic music, preserving cultural sounds while pushing the boundaries of what radio can be.</p>
                </div>
            </div>

            <!-- Visual Column -->
            <div class="space-y-8">
                <div class="relative group">
                    <!-- Main Image Card -->
                    <div class="rounded-3xl overflow-hidden aspect-[4/3] border border-gray-800/60 shadow-2xl">
                        <img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=800&q=80" alt="Radio Studio Microphone" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                    </div>
                    <!-- Ambient Glow -->
                    <div class="absolute -inset-1 bg-gradient-to-r from-[#9b51e0] to-[#b77bed] rounded-3xl blur opacity-20 group-hover:opacity-30 transition duration-500"></div>
                </div>
                
                <!-- Stats Grid -->
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-[#1E1B29]/40 border border-gray-800/60 p-6 rounded-2xl text-center backdrop-blur-sm transition-all hover:border-[#9b51e0]/40">
                        <span class="block text-4xl font-black text-[#9b51e0] mb-1 italic tracking-tighter">24/7</span>
                        <span class="block text-[10px] font-black text-gray-500 uppercase tracking-[0.2em]">Broadcasting</span>
                    </div>
                    <div class="bg-[#1E1B29]/40 border border-gray-800/60 p-6 rounded-2xl text-center backdrop-blur-sm transition-all hover:border-[#9b51e0]/40">
                        <span class="block text-4xl font-black text-[#9b51e0] mb-1 italic tracking-tighter">100%</span>
                        <span class="block text-[10px] font-black text-gray-500 uppercase tracking-[0.2em]">Independent</span>
                    </div>
                </div>
            </div>

        </div>

        <!-- Genres Section -->
        <section class="max-w-6xl mx-auto pt-20 border-t border-gray-800/40">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-black uppercase italic tracking-tight text-white mb-2">The Sound of <span class="text-[#9b51e0]">Contrast</span></h2>
                <div class="w-20 h-1 bg-[#9b51e0] mx-auto rounded-full"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Reggae Card -->
                <div class="bg-[#1E1B29]/30 border border-gray-800/60 p-10 rounded-3xl text-center backdrop-blur-sm transition-all duration-500 hover:border-[#9b51e0]/50 hover:-translate-y-2 group">
                    <div class="text-4xl text-[#9b51e0] mb-6 group-hover:scale-110 transition-transform duration-500"><i class="fa-solid fa-compact-disc"></i></div>
                    <h3 class="text-white font-black text-lg mb-4 uppercase italic tracking-wider">Reggae & Dub</h3>
                    <p class="text-gray-500 text-sm leading-relaxed uppercase font-bold tracking-tighter">Rooted in culture, heavy on the bass. From foundation roots to modern dancehall.</p>
                </div>

                <!-- Soul Card -->
                <div class="bg-[#1E1B29]/30 border border-gray-800/60 p-10 rounded-3xl text-center backdrop-blur-sm transition-all duration-500 hover:border-[#9b51e0]/50 hover:-translate-y-2 group">
                    <div class="text-4xl text-[#9b51e0] mb-6 group-hover:scale-110 transition-transform duration-500"><i class="fa-solid fa-microphone-lines"></i></div>
                    <h3 class="text-white font-black text-lg mb-4 uppercase italic tracking-wider">Soul & R&B</h3>
                    <p class="text-gray-500 text-sm leading-relaxed uppercase font-bold tracking-tighter">Smooth, emotive, and timeless. The best of classic grooves and contemporary neo-soul.</p>
                </div>

                <!-- House Card -->
                <div class="bg-[#1E1B29]/30 border border-gray-800/60 p-10 rounded-3xl text-center backdrop-blur-sm transition-all duration-500 hover:border-[#9b51e0]/50 hover:-translate-y-2 group">
                    <div class="text-4xl text-[#9b51e0] mb-6 group-hover:scale-110 transition-transform duration-500"><i class="fa-solid fa-headphones-simple"></i></div>
                    <h3 class="text-white font-black text-lg mb-4 uppercase italic tracking-wider">House & Dance</h3>
                    <p class="text-gray-500 text-sm leading-relaxed uppercase font-bold tracking-tighter">Keeping the tempo up with deep, soulful, and underground electronic beats.</p>
                </div>
            </div>
        </section>

    </div>

</Layout>
