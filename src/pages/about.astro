---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING - For Header Status Synchronization
const allShows = await getCollection('shows');
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

// 2. TIME LOGIC (For Header Status synchronization)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[dateInUK.getDay()];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    if (h === 24) h = 0;
    return h * 60 + m;
}

const currentSlot = rawSlots.find(slot => {
    if (slot.day !== currentDayStr) return false;
    const start = timeToMins(slot.startTime);
    let end = timeToMins(slot.endTime || "00:00");
    if (end <= start && end !== 0) end += 1440;
    return currentMins >= start && currentMins < end;
});

const currentShowName = currentSlot ? 
    (currentSlot.show === 'Auto DJ' ? "Contrast Selection" : (allShows.find(s => s.id === currentSlot.show)?.data.title || "Unknown")) 
    : "Auto DJ Mix";
---

<Layout title="Our Story | Contrast Radio" currentShow={currentShowName}>
    
    <Hero 
        title="ABOUT" 
        accent="CONTRAST" 
        subtextText="Transmission of Culture" 
        subtextHighlight="Est. 2026"
        bgImage="https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop"
    />

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-32">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start max-w-6xl mx-auto mb-40">
            
            <div class="space-y-12">
                <div class="space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="relative flex items-center justify-center">
                            <span class="absolute w-3 h-3 bg-brand-accent rounded-full animate-ping opacity-40"></span>
                            <i class="fa-solid fa-satellite-dish text-brand-accent text-xl relative"></i>
                        </div>
                        <h2 class="text-3xl font-black uppercase italic tracking-tight text-white">Our Origins</h2>
                    </div>
                    
                    <p class="text-2xl font-black text-white leading-tight italic border-l-4 border-brand-accent pl-8 py-2 drop-shadow-lg">
                        Contrast Radio is an independent, community-driven platform dedicated to delivering the finest authentic music globally.
                    </p>
                </div>
                
                <div class="space-y-8 text-gray-400 leading-relaxed text-lg font-medium">
                    <p>
                        Born out of a deep passion for culture-defining sounds, we set out to create a space where music truly matters. We are not bound by commercial playlists or corporate algorithms; our selections are hand-picked by residents who live and breathe the culture.
                    </p>

                    <p>
                        From the heavy basslines of classic Reggae to the smooth grooves of neo-Soul and the late-night energy of underground House music, Contrast Radio spans the spectrum of rhythm and vibe.
                    </p>
                </div>

                <div class="relative group">
                    <div class="bg-brand-surface/40 backdrop-blur-2xl border border-white/10 p-12 rounded-[2.5rem] shadow-2xl relative z-10 overflow-hidden">
                        <h3 class="text-white font-black text-xl mb-5 flex items-center gap-3 uppercase italic">
                            <i class="fa-solid fa-bullseye text-brand-accent"></i> Our Mission
                        </h3>
                        <p class="text-gray-400 leading-relaxed italic text-lg">To connect diverse communities through a shared love of authentic music, preserving cultural sounds while pushing the boundaries of what radio can be.</p>
                        
                        <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-brand-accent/5 blur-3xl -z-10 group-hover:bg-brand-accent/10 transition-all duration-700"></div>
                    </div>
                    <div class="absolute -inset-[1px] bg-gradient-to-br from-brand-accent/20 to-transparent rounded-[2.5rem] -z-10 opacity-50 group-hover:opacity-100 transition-opacity"></div>
                </div>
            </div>

            <div class="space-y-12">
                <div class="relative group">
                    <div class="rounded-[3rem] overflow-hidden aspect-[4/3] border border-white/10 shadow-[0_40px_80px_rgba(0,0,0,0.6)]">
                        <img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=800&q=80" alt="Radio Studio" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110 group-hover:rotate-1" />
                    </div>
                    <div class="absolute inset-0 md:-inset-6 bg-brand-accent/10 rounded-[4rem] blur-2xl md:blur-3xl -z-10 opacity-50 group-hover:opacity-100 transition-opacity duration-1000"></div>
                </div>
                
                <div class="grid grid-cols-2 gap-6">
                    {[
                        { val: "24/7", label: "Transmission" },
                        { val: "100%", label: "Independent" }
                    ].map(stat => (
                        <div class="bg-brand-surface/60 border border-white/5 p-10 rounded-[2rem] text-center backdrop-blur-md transition-all hover:border-brand-accent/30 group relative overflow-hidden">
                            <span class="block text-5xl font-black text-brand-accent mb-2 italic tracking-tighter group-hover:scale-110 transition-transform drop-shadow-[0_0_15px_rgba(255,59,59,0.4)]">{stat.val}</span>
                            <span class="block text-[10px] font-black text-gray-500 uppercase tracking-[0.4em]">{stat.label}</span>
                            <div class="absolute inset-0 bg-gradient-to-tr from-brand-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        </div>
                    ))}
                </div>
            </div>
        </div>

        <section class="max-w-6xl mx-auto pt-32 border-t border-white/5">
            <div class="text-center mb-24">
                <span class="text-brand-accent font-black text-xs tracking-[0.5em] uppercase mb-4 block italic">The Frequency DNA</span>
                <h2 class="text-5xl md:text-6xl font-black uppercase italic tracking-tighter text-white">THE SOUND OF <span class="text-brand-accent">CONTRAST</span></h2>
                <div class="w-24 h-1.5 bg-brand-accent mx-auto mt-8 rounded-full shadow-[0_0_20px_rgba(255,59,59,0.6)]"></div>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                {[
                    { icon: "fa-compact-disc", title: "Reggae & Dub", desc: "Rooted in culture, heavy on the bass. From foundation roots to modern dancehall." },
                    { icon: "fa-microphone-lines", title: "Soul & R&B", desc: "Smooth, emotive, and timeless. The best of classic grooves and contemporary neo-soul." },
                    { icon: "fa-headphones-simple", title: "House & Dance", desc: "Keeping the tempo up with deep, soulful, and underground electronic beats." }
                ].map(genre => (
                    <div class="bg-brand-surface/30 border border-white/5 p-12 rounded-[2.5rem] text-center backdrop-blur-sm transition-all duration-700 hover:border-brand-accent/50 hover:-translate-y-3 group shadow-2xl relative overflow-hidden">
                        <div class="text-5xl text-brand-accent mb-10 group-hover:scale-110 transition-transform duration-500 drop-shadow-[0_0_25px_rgba(255,59,59,0.5)]">
                            <i class={`fa-solid ${genre.icon}`}></i>
                        </div>
                        <h3 class="text-white font-black text-xl mb-5 uppercase italic tracking-wider group-hover:text-brand-accent transition-colors">{genre.title}</h3>
                        <p class="text-gray-500 text-sm leading-relaxed uppercase font-bold tracking-tight">{genre.desc}</p>
                        
                        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-brand-accent/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    </div>
                ))}
            </div>
        </section>

    </div>
</Layout>
