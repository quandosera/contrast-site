---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');
const allFlyers = await getCollection('flyers').catch(() => []);

// 2. TIME LOGIC (UK Time for Live Tracking)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();

const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];

// 3. RESOLVE RELATIONSHIPS (Schedule -> Show -> DJ)
const allShowsDetailed = rawSlots.map((slot) => {
    const isAutoDj = slot.show === 'auto-dj';
    const showEntry = !isAutoDj ? allShows.find(s => s.id === slot.show) : null;
    
    const firstHostId = showEntry?.data?.hosts?.[0];
    const djEntry = firstHostId ? allDjs.find(d => d.id === firstHostId) : null;

    return { 
        ...slot, 
        isAutoDj,
        showData: showEntry?.data,
        djData: djEntry?.data 
    };
});

// 4. BUILD CONTINUOUS ROLLING TIMELINE
let timeline: any[] = [];

// A. Yesterday's Crossover Logic
const yesterdayIndex = (currentDayIndex + 6) % 7;
allShowsDetailed.filter(s => s.day === daysArray[yesterdayIndex]).forEach(slot => {
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime, true);
    
    if (endMins <= startMins || endMins === 1440) { 
        timeline.push({
            ...slot,
            absoluteStart: -1440 + startMins,
            absoluteEnd: (endMins === 1440) ? 0 : endMins 
        });
    }
});

function timeToMins(timeStr: string, isEndTime: boolean = false) {
    if (!timeStr) return 0;
    const str = String(timeStr).trim();
    let [h, m] = str.split(':').map(Number);
    if (isEndTime && (h === 24 || (h === 0 && m === 0))) return 1440;
    if (h === 24) h = 0;
    return h * 60 + m;
}

// B. Today + Next 6 Days Sequential Timeline
for (let i = 0; i < 7; i++) {
    const targetDayIndex = (currentDayIndex + i) % 7;
    const targetDayStr = daysArray[targetDayIndex];
    
    allShowsDetailed.filter(s => s.day === targetDayStr).forEach(slot => {
        const startMins = timeToMins(slot.startTime);
        let endMins = timeToMins(slot.endTime, true);
        
        let absoluteStart = i * 1440 + startMins;
        
        if (endMins <= startMins && endMins !== 1440) {
            endMins += 1440;
        }
        let absoluteEnd = i * 1440 + endMins;

        timeline.push({
            ...slot,
            absoluteStart,
            absoluteEnd
        });
    });
}

timeline.sort((a, b) => a.absoluteStart - b.absoluteStart);
const relevantShows = timeline.filter(show => show.absoluteEnd > currentMins);

// 5. LIVE SHOW DETECTION & UPCOMING LIST
const displayedShows = relevantShows.slice(0, 5).map(show => ({
    ...show,
    isLive: currentMins >= show.absoluteStart && currentMins < show.absoluteEnd
}));

const liveShow = displayedShows.find(show => show.isLive);

// 6. FALLBACK VALUES
const currentShowName = liveShow ? (liveShow.isAutoDj ? "Contrast Selection" : (liveShow.showData?.title || "TBA")) : "Auto DJ Mix";
const currentDJName = liveShow ? (liveShow.isAutoDj ? "Contrast Radio" : (liveShow.djData?.name || "Guest DJ")) : "Contrast Radio";

// 7. FLYERS
const activeFlyers = allFlyers
    .sort((a, b) => b.id.localeCompare(a.id)) 
    .slice(0, 4);
---

<Layout title="Contrast Radio | Up and Coming" currentShow={currentShowName}>
    
    <section class="hero-section">
        <div class="hero-bg">
            <img src="https://images.unsplash.com/photo-1633294666093-ab54f43a947a?q=80&w=774&auto=format&fit=crop&ixlib=rb-4.1.0" alt="DJ Mixing" />
            <div class="hero-gradient"></div>
        </div>
        <div class="container hero-content">
            <div class="glass-panel">
                <div class="live-status-container">
                    {liveShow ? (
                        <div class="status-badge live">
                            <span class="pulse"></span> LIVE NOW: {currentDJName}
                        </div>
                    ) : (
                        <div class="status-badge offline">
                            <i class="fa-solid fa-robot"></i> AUTO DJ MODE
                        </div>
                    )}
                </div>

                <h2 class="hero-headline">Broadcasting the <span style="color: var(--purple-light);">Vibe</span>.</h2>
                <p class="hero-subline">
                    Currently playing: <strong>{currentShowName}</strong> {liveShow && !liveShow.isAutoDj && `with ${currentDJName}`}.
                    <br/>Welcome to the home of Contrast Radio. Streaming the finest Reggae, Soul, R&B, and House music 24/7.
                </p>
            </div>
        </div>
    </section>

    <div class="container main-wrapper">
        
        <section class="top-split-section">
            
            <div class="schedule-list-wrapper">
                <div class="schedule-header-bar">
                    <div class="header-left">
                        <i class="fa-solid fa-tower-broadcast"></i> UPCOMING SHOWS
                    </div>
                    <a href="/schedule" class="view-all-link">View Full Schedule &rarr;</a>
                </div>
                
                <div class="schedule-items">
                    {displayedShows.length > 0 ? (
                        displayedShows.map(slot => (
                            <div class={`schedule-row ${slot.isLive ? 'is-live' : ''}`}>
                                <div class="time-col">
                                    <span class="day-label">{slot.day.split('-')[1].toUpperCase()}</span>
                                    <span class="time-text">{slot.startTime} - {slot.endTime}</span>
                                    {slot.isLive && <span class="live-badge">ON AIR</span>}
                                </div>
                                <div class="name-col">
                                    <div class="show-title">{slot.isAutoDj ? "Contrast Selection" : (slot.showData?.title || "TBA")}</div>
                                    <span class="show-genre">
                                        {slot.isAutoDj ? "AUTO MIX" : (slot.showData?.genre?.toUpperCase() || "VARIOUS")}
                                    </span>
                                </div>
                                <div class="dj-col dj-profile">
                                    {slot.djData?.avatar ? (
                                        <img 
                                            src={slot.djData.avatar} 
                                            alt={slot.djData.name} 
                                            class="dj-avatar"
                                        />
                                    ) : (
                                        <div class="dj-avatar-placeholder">
                                            <i class={`fa-solid ${slot.isAutoDj ? 'fa-compact-disc fa-spin' : 'fa-user'}`}></i>
                                        </div>
                                    )}
                                    <span class="dj-name">{slot.isAutoDj ? "Contrast Radio" : (slot.djData?.name || "Guest DJ")}</span>
                                </div>
                            </div>
                        ))
                    ) : (
                        <div class="schedule-row">
                            <div class="time-col">24/7</div>
                            <div class="name-col">
                                <div class="show-title">Auto DJ Mix</div>
                            </div>
                            <div class="dj-col dj-profile">
                                <div class="dj-avatar-placeholder"><i class="fa-solid fa-robot"></i></div>
                                <span class="dj-name">Contrast Radio</span>
                            </div>
                        </div>
                    )}
                </div>
            </div>
            
            <div class="video-wrapper">
                <div class="video-box">
                    <img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=800&q=80" alt="Studio Background" class="video-bg" />
                    <div class="video-overlay">
                        <button class="play-video-btn" aria-label="Play Studio Session">
                            <i class="fa-solid fa-play"></i>
                        </button>
                        <div class="video-text">
                            <h3>Live Studio Sessions</h3>
                            <span>Highlights & Interviews coming soon</span>
                        </div>
                    </div>
                </div>
            </div>

        </section>

        <section class="flyers-section">
            <div class="section-header">
                <div class="section-icon"><i class="fa-solid fa-ticket"></i></div>
                <h2>LATEST EVENTS</h2>
            </div>

            <div class="flyer-grid">
                {activeFlyers.map(flyer => (
                    <button class="flyer-card" aria-label={`View flyer: ${flyer.data.title}`}>
                        {flyer.data.image ? (
                            <img src={flyer.data.image} alt={flyer.data.title} class="flyer-img" loading="lazy" />
                        ) : (
                            <div class="placeholder-img">No Image</div>
                        )}
                        <div class="flyer-overlay">
                            <h3>{flyer.data.title}</h3>
                        </div>
                    </button>
                ))}
            </div>
        </section>

        <section class="sponsors-section">
            <div class="section-header">
                <div class="section-icon"><i class="fa-solid fa-handshake"></i></div>
                <h2>OUR SPONSORS</h2>
            </div>
            <div class="sponsor-logos">
                <div class="sponsor-logo"><img src="https://via.placeholder.com/200x80/f1f5f9/94a3b8?text=SPONSOR+1" alt="Sponsor 1"></div>
                <div class="sponsor-logo"><img src="https://via.placeholder.com/200x80/f1f5f9/94a3b8?text=SPONSOR+2" alt="Sponsor 2"></div>
                <div class="sponsor-logo"><img src="https://via.placeholder.com/200x80/f1f5f9/94a3b8?text=SPONSOR+3" alt="Sponsor 3"></div>
                <div class="sponsor-logo"><img src="https://via.placeholder.com/200x80/f1f5f9/94a3b8?text=SPONSOR+4" alt="Sponsor 4"></div>
                <div class="sponsor-logo"><img src="https://via.placeholder.com/200x80/f1f5f9/94a3b8?text=SPONSOR+5" alt="Sponsor 5"></div>
            </div>
        </section>

    </div>

    <div id="flyer-modal" class="modal" role="dialog" aria-modal="true">
        <div class="modal-content">
            <span class="close-modal">&times;</span>
            <img id="modal-img" src="" alt="Full Size Flyer">
        </div>
    </div>

</Layout>

<script>
    document.addEventListener('astro:page-load', () => {
        const flyerCards = document.querySelectorAll('.flyer-card');
        const modal = document.getElementById('flyer-modal');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const closeModal = document.querySelector('.close-modal');

        if (!modal || !modalImg) return;

        flyerCards.forEach(card => {
            card.addEventListener('click', () => {
                const img = card.querySelector('.flyer-img') as HTMLImageElement;
                if(img) {
                    modalImg.src = img.src;
                    modal.classList.add('active');
                    document.body.style.overflow = 'hidden'; 
                }
            });
        });

        const hideModal = () => {
            modal.classList.remove('active');
            document.body.style.overflow = 'auto';
            setTimeout(() => { modalImg.src = ""; }, 300);
        };

        closeModal?.addEventListener('click', hideModal);
        modal?.addEventListener('click', (e) => { if(e.target === modal) hideModal(); });
        
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && modal?.classList.contains('active')) hideModal();
        });
    });
</script>

<style>
    /* === VARIABLES === */
    :root {
        --purple: #a855f7;
        --purple-dark: #7e22ce;
        --purple-light: #e9d5ff;
        --dark-bg: #0f172a;
        --bg-body: #f8fafc;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --border-light: #e2e8f0;
    }

    /* === HERO SECTION === */
    .hero-section {
        position: relative;
        padding: 8rem 20px;
        margin-bottom: 4rem;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: -1;
        overflow: hidden;
    }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
    .hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(15, 23, 42, 0.4) 0%, rgba(15, 23, 42, 0.9) 80%, var(--bg-body) 100%);
    }
    .hero-content { position: relative; z-index: 1; width: 100%; max-width: 900px; display: flex; justify-content: center;}
    
    .glass-panel {
        background: rgba(15, 23, 42, 0.4);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 3rem 2rem;
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        width: 100%;
    }

    /* === LIVE INDICATOR === */
    .live-status-container { margin-bottom: 1.5rem; }
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.85rem;
        font-weight: 800;
        letter-spacing: 1px;
        text-transform: uppercase;
        border: 1px solid rgba(255,255,255,0.2);
    }
    .status-badge.live { background: rgba(168, 85, 247, 0.2); color: #f0abfc; border-color: var(--purple); }
    .status-badge.offline { background: rgba(255,255,255,0.05); color: #94a3b8; }
    .pulse {
        width: 10px; height: 10px; background: #ef4444; border-radius: 50%;
        box-shadow: 0 0 0 rgba(239, 68, 68, 0.4);
        animation: pulse-animation 2s infinite;
    }
    @keyframes pulse-animation {
        0% { box-shadow: 0 0 0 0px rgba(239, 68, 68, 0.7); }
        70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0px rgba(239, 68, 68, 0); }
    }

    .hero-headline { font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 900; letter-spacing: -1px; color: #fff; line-height: 1.1; text-transform: uppercase; margin: 0; }
    .hero-subline { font-size: 1.15rem; color: #cbd5e1; margin: 1.5rem auto 0; line-height: 1.6; max-width: 600px;}

    /* === MAIN WRAPPER === */
    .main-wrapper { padding-bottom: 5rem; max-width: 1200px; margin: 0 auto;}
    .section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 2rem; }
    .section-icon { color: var(--purple); font-size: 1.8rem; }
    .section-header h2 { margin: 0; font-weight: 900; font-size: 2rem; letter-spacing: -1px; text-transform: uppercase; color: var(--text-main); }

    /* === SCHEDULE LIST === */
    .top-split-section { display: flex; flex-direction: column; gap: 2.5rem; margin-bottom: 5rem; }
    .schedule-list-wrapper { 
        flex: 1.8; 
        background: #fff; 
        border-radius: 16px; 
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.01); 
        border: 1px solid var(--border-light);
        overflow: hidden; 
    }
    .schedule-header-bar {
        padding: 1.2rem 1.5rem;
        background: #f8fafc;
        border-bottom: 1px solid var(--border-light);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .header-left { font-weight: 800; color: var(--text-muted); font-size: 0.85rem; letter-spacing: 1px; display: flex; align-items: center; gap: 8px;}
    .view-all-link { font-size: 0.85rem; color: var(--purple); font-weight: 700; text-decoration: none; transition: 0.2s;}
    .view-all-link:hover { color: var(--purple-dark); transform: translateX(3px); }

    .schedule-items { display: flex; flex-direction: column; }
    .schedule-row { 
        display: flex; 
        padding: 1.5rem; 
        border-bottom: 1px solid var(--border-light); 
        align-items: center; 
        gap: 20px; 
        transition: background 0.2s;
    }
    .schedule-row:hover:not(.is-live) { background: #f8fafc; }
    .schedule-row:last-child { border-bottom: none; }
    
    /* Live Row Styling */
    .schedule-row.is-live { 
        background: linear-gradient(135deg, var(--purple-dark), var(--purple)); 
        color: #fff;
    }
    .schedule-row.is-live .time-col, 
    .schedule-row.is-live .show-title, 
    .schedule-row.is-live .dj-col { color: #fff; }
    .schedule-row.is-live .show-genre { background: rgba(255,255,255,0.2); color: #fff; border: none;}
    .schedule-row.is-live .day-label { background: #fff; color: var(--purple-dark); border: none;}
    .schedule-row.is-live .dj-avatar { border-color: #fff; }
    
    .time-col { flex: 1; font-weight: 700; color: var(--text-muted); font-size: 0.95rem; display: flex; flex-direction: column; align-items: flex-start; gap: 6px; }
    .day-label { font-size: 0.7rem; font-weight: 900; color: var(--purple); text-transform: uppercase; background: var(--purple-light); padding: 3px 8px; border-radius: 6px; border: 1px solid rgba(168, 85, 247, 0.2); line-height: 1;}
    .time-text { font-variant-numeric: tabular-nums; }
    .live-badge { background: #ef4444; color: #fff; font-size: 0.65rem; padding: 3px 8px; border-radius: 4px; font-weight: 900; letter-spacing: 0.5px; animation: pulse-opacity 2s infinite;}
    
    @keyframes pulse-opacity {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.7; }
    }

    .name-col { flex: 2; display: flex; flex-direction: column; align-items: flex-start; gap: 6px; }
    .show-title { font-weight: 900; font-size: 1.15rem; color: var(--text-main); line-height: 1.2;}
    .show-genre { font-size: 0.7rem; font-weight: 800; color: var(--text-muted); background: #f1f5f9; padding: 3px 10px; border-radius: 6px; border: 1px solid #e2e8f0; letter-spacing: 0.5px; }

    .dj-col { flex: 1.5; color: var(--text-muted); font-weight: 600; font-size: 0.95rem; }
    .dj-profile { display: flex; align-items: center; gap: 12px; }
    .dj-avatar { width: 48px; height: 48px; border-radius: 50%; border: 2px solid var(--purple); object-fit: cover; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
    .dj-avatar-placeholder { width: 48px; height: 48px; border-radius: 50%; background: #e2e8f0; display: flex; align-items: center; justify-content: center; color: #94a3b8; border: 2px solid #cbd5e1; font-size: 1.2rem;}
    .dj-name { font-weight: 700; }

    /* === VIDEO === */
    .video-wrapper { flex: 1.2; display: flex; }
    .video-box { 
        position: relative;
        background: var(--dark-bg); 
        border-radius: 16px; 
        width: 100%;
        overflow: hidden;
        box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1);
        display: flex;
    }
    .video-bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.5; transition: 0.5s; }
    .video-box:hover .video-bg { opacity: 0.3; transform: scale(1.05); }
    .video-overlay {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
        width: 100%;
        background: linear-gradient(to top, rgba(15, 23, 42, 0.9), transparent);
    }
    .play-video-btn {
        width: 70px; height: 70px;
        border-radius: 50%;
        background: rgba(168, 85, 247, 0.9);
        color: #fff;
        border: none;
        font-size: 1.8rem;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 0 20px rgba(168, 85, 247, 0.5);
        margin-bottom: 1.5rem;
    }
    .play-video-btn:hover { background: var(--purple); transform: scale(1.1); box-shadow: 0 0 30px rgba(168, 85, 247, 0.8); }
    .video-text h3 { margin: 0; font-weight: 900; font-size: 1.4rem; color: #fff; }
    .video-text span { display: block; font-size: 0.85rem; color: #cbd5e1; margin-top: 5px; font-weight: 500;}

    /* === FLYERS GRID === */
    .flyer-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; }
    .flyer-card { 
        position: relative; width: 100%; padding-top: 100%; border-radius: 16px; overflow: hidden; 
        background: #e2e8f0; cursor: pointer; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); 
        border: none; display: block;
    }
    .flyer-card:hover .flyer-img { transform: scale(1.08); }
    .flyer-img { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
    .flyer-overlay { 
        position: absolute; bottom: 0; left: 0; width: 100%; 
        background: linear-gradient(transparent, rgba(0,0,0,0.9)); 
        padding: 2rem 1.5rem 1.5rem 1.5rem; text-align: left; pointer-events: none;
    }
    .flyer-overlay h3 { color: #fff; margin: 0; font-size: 1.1rem; font-weight: 800; line-height: 1.3;}
    .placeholder-img { position: absolute; top:0; left:0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #94a3b8; font-weight: 600; text-transform: uppercase; font-size: 0.9rem;}

    /* === MODAL === */
    .modal { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.95); z-index: 3000; display: none; justify-content: center; align-items: center; opacity: 0; transition: 0.3s; backdrop-filter: blur(8px); }
    .modal.active { display: flex; opacity: 1; }
    .modal-content { position: relative; max-width: 90%; max-height: 90vh; }
    .modal-content img { max-width: 100%; max-height: 85vh; border-radius: 12px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); }
    .close-modal { position: absolute; top: -50px; right: 0; color: #fff; font-size: 3rem; cursor: pointer; background: none; border: none; transition: color 0.2s; line-height: 1;}
    .close-modal:hover { color: var(--purple); }

    /* === SPONSORS === */
    .sponsors-section { margin-top: 5rem; padding-top: 4rem; border-top: 1px solid var(--border-light); }
    .sponsor-logos { display: flex; gap: 2rem; justify-content: space-between; align-items: center; flex-wrap: wrap; margin-top: 2rem; }
    .sponsor-logo { flex: 1 1 150px; display: flex; justify-content: center; }
    .sponsor-logo img { height: 40px; filter: grayscale(1); opacity: 0.4; transition: 0.3s; }
    .sponsor-logo img:hover { filter: grayscale(0); opacity: 1; }

    /* === RESPONSIVE === */
    @media (min-width: 1024px) {
        .top-split-section { flex-direction: row; }
        .video-box { min-height: 400px; }
    }
    @media (max-width: 768px) {
        .schedule-row { flex-direction: column; align-items: flex-start; gap: 12px; }
        .flyer-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 480px) {
        .flyer-grid { grid-template-columns: 1fr; }
    }
</style>