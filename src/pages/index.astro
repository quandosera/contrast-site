---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');
const allFlyers = await getCollection('flyers').catch(() => []);

// 2. TIME LOGIC (UK Time)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();

const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];

// 3. RESOLVE RELATIONSHIPS (With Fuzzy Matching for master.yaml)
const allShowsDetailed = rawSlots.map((slot) => {
    // Standardize Auto DJ check
    const isAutoDj = slot.show === 'Auto DJ' || slot.show === 'auto-dj';
    
    // Fuzzy matching: Check ID, Title, or URL-safe slug
    const showEntry = !isAutoDj ? allShows.find(s => 
        s.id === slot.show || 
        s.data.title === slot.show ||
        s.id === slot.show.toLowerCase().replace(/\s+/g, '-')
    ) : null;
    
    const firstHostId = showEntry?.data?.hosts?.[0];
    
    const djEntry = firstHostId ? allDjs.find(d => {
        const safeId = d.id.replace(/\.[^/.]+$/, "");
        return safeId === firstHostId || d.data?.slug === firstHostId || d.id === firstHostId;
    }) : null;

    return { 
        ...slot, 
        isAutoDj,
        showData: showEntry?.data,
        djData: djEntry?.data,
        djId: djEntry?.id?.replace(/\.[^/.]+$/, "") || firstHostId,
        displayName: isAutoDj ? "Contrast Selection" : (showEntry?.data.title || slot.show)
    };
});

function timeToMins(timeStr: string, isEndTime: boolean = false) {
    if (!timeStr) return 0;
    const str = String(timeStr).trim();
    let [h, m] = str.split(':').map(Number);
    // Standardize 00:00 as end of day (1440 mins)
    if (isEndTime && (h === 24 || (h === 0 && m === 0))) return 1440;
    if (h === 24) h = 0;
    return h * 60 + m;
}

// 4. BUILD CONTINUOUS ROLLING TIMELINE
let timeline: any[] = [];

// A. Yesterday's Crossover Logic (Catch shows that started yesterday but end today)
const yesterdayIndex = (currentDayIndex + 6) % 7;
allShowsDetailed.filter(s => s.day === daysArray[yesterdayIndex]).forEach(slot => {
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime, true);
    
    if (endMins <= startMins || endMins === 1440) { 
        timeline.push({
            ...slot,
            absoluteStart: -1440 + startMins,
            absoluteEnd: (endMins === 1440) ? 0 : endMins 
        });
    }
});

// B. Next 7 Days Sequential Timeline
for (let i = 0; i < 7; i++) {
    const targetDayIndex = (currentDayIndex + i) % 7;
    const targetDayStr = daysArray[targetDayIndex];
    
    allShowsDetailed.filter(s => s.day === targetDayStr).forEach(slot => {
        const startMins = timeToMins(slot.startTime);
        let endMins = timeToMins(slot.endTime, true);
        
        let absoluteStart = i * 1440 + startMins;
        if (endMins <= startMins && endMins !== 1440) {
            endMins += 1440;
        }
        let absoluteEnd = i * 1440 + endMins;

        timeline.push({
            ...slot,
            absoluteStart,
            absoluteEnd
        });
    });
}

timeline.sort((a, b) => a.absoluteStart - b.absoluteStart);

// Filter relevant shows (current live show + upcoming)
const relevantShows = timeline.filter(show => show.absoluteEnd > currentMins);

// 5. LIVE SHOW DETECTION
const displayedShows = relevantShows.slice(0, 5).map(show => ({
    ...show,
    isLive: currentMins >= show.absoluteStart && currentMins < show.absoluteEnd
}));

const liveShow = displayedShows.find(show => show.isLive);

// 6. HEADER METADATA
const currentShowName = liveShow ? liveShow.displayName : "Auto DJ Mix";
const currentDJName = liveShow ? (liveShow.isAutoDj ? "Contrast Radio" : (liveShow.djData?.name || liveShow.djId || "Guest DJ")) : "Contrast Radio";

// 7. FLYERS
const activeFlyers = allFlyers
    .sort((a, b) => b.id.localeCompare(a.id)) 
    .slice(0, 4);
---

<Layout title="Contrast Radio | Up and Coming" currentShow={currentShowName}>
    
    <section class="relative h-[75vh] min-h-[500px] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1603048588665-791ca8aea617?q=80&w=2070&auto=format&fit=crop" alt="Contrast Turntable" class="w-full h-full object-cover opacity-40">
            <div class="absolute inset-0 bg-gradient-to-t from-[#13111C] via-[#13111C]/30 to-transparent"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10 text-center">
            <div class="inline-flex items-center gap-2 bg-[#1E1B29]/80 border border-[#9b51e0]/20 backdrop-blur-sm px-4 py-2 rounded-full mb-8 shadow-2xl">
                <span class={`w-2.5 h-2.5 rounded-full ${liveShow ? 'bg-red-500 animate-ping' : 'bg-gray-500'}`}></span>
                <span class="text-[10px] font-black tracking-[0.25em] text-white uppercase">
                    {liveShow ? `LIVE NOW: ${currentDJName}` : 'AUTO DJ MODE'}
                </span>
            </div>
            
            <h2 class="text-6xl md:text-[5.5rem] font-black tracking-tighter mb-6 uppercase italic leading-[0.9]">
                BROADCASTING THE <br/>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">VIBE.</span>
            </h2>
            
            <p class="text-base md:text-xl text-gray-300 max-w-2xl mx-auto mb-12 leading-relaxed font-medium">
                Streaming the finest Reggae, Soul, R&B, and House music 24/7.
                <br class="hidden md:block"/> Currently playing: <strong class="text-white italic">{currentShowName}</strong>
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
                <button class="player-trigger w-full sm:w-64 bg-white text-[#13111C] hover:bg-gray-200 px-8 py-5 rounded-full font-black text-xs tracking-[0.2em] transition-all shadow-[0_0_30px_rgba(255,255,255,0.1)] flex items-center justify-center gap-3 active:scale-95 uppercase">
                    <i class="fa-solid fa-play text-[10px]"></i> Listen Live
                </button>
                <a href="/schedule" class="w-full sm:w-64 bg-[#1E1B29]/60 backdrop-blur-md hover:bg-gray-800 text-white border border-gray-700/50 px-8 py-5 rounded-full font-black text-xs tracking-[0.2em] transition-all flex items-center justify-center gap-3 active:scale-95 uppercase">
                    View Schedule
                </a>
            </div>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 space-y-24 py-20">
        
        <section id="schedule" class="scroll-mt-24">
            <div class="flex items-center justify-between mb-10">
                <h2 class="text-2xl font-black flex items-center gap-3 uppercase italic tracking-tighter">
                    <i class="fa-solid fa-tower-broadcast text-[#9b51e0]"></i> Upcoming Shows
                </h2>
                <a href="/schedule" class="text-[#b77bed] hover:text-white font-black text-[10px] flex items-center gap-2 transition-colors uppercase tracking-[0.2em]">
                    FULL SCHEDULE <i class="fa-solid fa-chevron-right text-[8px]"></i>
                </a>
            </div>

            <div class="bg-[#1E1B29]/40 rounded-[2.5rem] border border-gray-800/40 overflow-hidden divide-y divide-gray-800/40 shadow-2xl backdrop-blur-sm">
                {displayedShows.map(slot => (
                    <div class={`relative flex flex-col md:flex-row md:items-center p-8 sm:p-10 transition-all duration-500 group ${slot.isLive ? 'bg-[#9b51e0]/10' : 'hover:bg-white/[0.02]'}`}>
                        
                        <div class="flex-shrink-0 w-40 mb-4 md:mb-0 flex flex-col">
                            <span class={`text-[10px] font-black uppercase mb-1 tracking-[0.2em] ${slot.isLive ? 'text-[#b77bed]' : 'text-gray-500'}`}>
                                {slot.day.split('-')[1]}
                            </span>
                            <span class={`text-xl font-black tracking-tighter ${slot.isLive ? 'text-white' : 'text-gray-300'}`}>
                                {slot.startTime} — {slot.endTime}
                            </span>
                            {slot.isLive && (
                                <div class="flex items-center gap-2 mt-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                    <span class="text-[9px] font-black text-red-500 tracking-widest uppercase">ON AIR</span>
                                </div>
                            )}
                        </div>

                        <div class="flex-grow md:px-12 text-left">
                            <h3 class="text-2xl font-black text-white mb-2 leading-tight group-hover:text-[#b77bed] transition-colors uppercase italic">
                                {slot.displayName}
                            </h3>
                            <span class={`text-[9px] font-black px-3 py-1 rounded-full inline-block uppercase tracking-[0.2em] border transition-colors ${slot.isLive ? 'bg-[#9b51e0]/20 border-[#9b51e0]/40 text-white' : 'bg-gray-800 border-gray-700 text-gray-500'}`}>
                                {slot.isAutoDj ? "Auto Mix" : (slot.showData?.genre || "Various")}
                            </span>
                        </div>

                        <div class="flex items-center justify-end gap-5 mt-6 md:mt-0 md:min-w-[280px]">
                            <div class="flex flex-col text-right">
                                <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest mb-1">Presented by</span>
                                <span class={`font-black text-base uppercase italic leading-none transition-colors ${slot.isLive ? 'text-white' : 'text-gray-400'}`}>
                                    {slot.isAutoDj ? "Contrast Radio" : (slot.djData?.name || slot.djId || "Guest DJ")}
                                </span>
                            </div>
                            <div class={`w-12 h-12 rounded-full overflow-hidden flex items-center justify-center text-sm transition-all duration-500 shadow-2xl ${slot.isLive ? 'ring-2 ring-[#9b51e0] scale-110' : 'bg-gray-800 border border-gray-700 grayscale opacity-40'}`}>
                                {slot.djData?.avatar && !slot.isAutoDj ? (
                                    <img src={slot.djData.avatar} alt={slot.djData?.name} class="w-full h-full object-cover" />
                                ) : (
                                    <i class={`fa-solid ${slot.isAutoDj ? 'fa-compact-disc' : 'fa-user'} ${slot.isLive && slot.isAutoDj ? 'fa-spin' : ''}`}></i>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section id="events">
            <div class="flex items-center justify-between mb-10">
                <h2 class="text-2xl font-black flex items-center gap-3 uppercase italic tracking-tighter">
                    <i class="fa-solid fa-ticket text-[#9b51e0]"></i> Session Archive
                </h2>
                <a href="/gallery" class="text-[#b77bed] hover:text-white font-black text-[10px] flex items-center gap-2 transition-colors uppercase tracking-[0.2em]">
                    VIEW ALL <i class="fa-solid fa-chevron-right text-[8px]"></i>
                </a>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
                {activeFlyers.map(flyer => (
                    <button class="flyer-card group relative rounded-[2rem] overflow-hidden aspect-[4/5] bg-gray-800 border border-gray-800/50 text-left transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 active:scale-95">
                        {flyer.data.image && <img src={flyer.data.image} alt={flyer.data.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/20 to-transparent flex flex-col justify-end p-6">
                            <span class="text-[#b77bed] text-[8px] font-black uppercase tracking-[0.2em] mb-1">Visual</span>
                            <h3 class="text-white font-black text-sm leading-tight uppercase italic group-hover:text-[#b77bed] transition-colors">{flyer.data.title}</h3>
                        </div>
                    </button>
                ))}
                
                {activeFlyers.length === 0 && (
                    <div class="col-span-full py-20 text-center rounded-[2.5rem] border-2 border-dashed border-gray-800/40">
                         <i class="fa-solid fa-image-portrait text-3xl text-gray-700 mb-4"></i>
                         <p class="text-gray-500 font-black text-xs tracking-widest uppercase">Archive coming soon</p>
                    </div>
                )}
            </div>
        </section>

        <section id="sponsors" class="pt-16 border-t border-gray-800/40">
            <div class="flex items-center justify-center mb-12">
                <span class="text-[10px] font-black tracking-[0.4em] text-gray-600 uppercase flex items-center gap-8">
                    <span class="w-16 h-[1px] bg-gray-800/60"></span> OUR PARTNERS <span class="w-16 h-[1px] bg-gray-800/60"></span>
                </span>
            </div>
            <div class="flex flex-wrap justify-center items-center gap-x-16 gap-y-10 opacity-30 hover:opacity-100 transition-opacity duration-1000 grayscale hover:grayscale-0">
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 cursor-default transition-transform hover:scale-105"><i class="fa-solid fa-building text-[#9b51e0]"></i> SION SPACES</div>
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 cursor-default transition-transform hover:scale-105"><i class="fa-solid fa-house text-[#9b51e0]"></i> Hyde & Rowe</div>
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 cursor-default transition-transform hover:scale-105"><i class="fa-solid fa-martini-glass text-[#9b51e0]"></i> Barry's Bar</div>
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 cursor-default transition-transform hover:scale-105"><i class="fa-solid fa-car text-[#9b51e0]"></i> Sayez Car Care</div>
            </div>
        </section>
    </div>

    <div id="flyer-modal" class="fixed inset-0 z-[60] bg-black/98 backdrop-blur-2xl hidden flex items-center justify-center p-6 transition-opacity duration-300 opacity-0">
        <button class="absolute top-8 right-8 text-white hover:text-[#9b51e0] text-5xl w-14 h-14 flex items-center justify-center bg-white/5 rounded-full transition-all hover:scale-110 active:scale-90 z-[70]">&times;</button>
        <img id="modal-img" src="" alt="Full Flyer" class="max-w-full max-h-[90vh] object-contain rounded-2xl shadow-[0_0_80px_rgba(0,0,0,0.9)] border border-white/5 scale-95 transition-transform duration-500">
    </div>

</Layout>

<script>
    document.addEventListener('astro:page-load', () => {
        const flyers = document.querySelectorAll('.flyer-card');
        const modal = document.getElementById('flyer-modal');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const closeBtn = modal?.querySelector('button');

        flyers.forEach(card => card.addEventListener('click', () => {
            const img = card.querySelector('img');
            if (img && modal && modalImg) {
                modalImg.src = img.src;
                modal.classList.remove('hidden');
                setTimeout(() => { 
                    modal.classList.replace('opacity-0', 'opacity-100'); 
                    modalImg.classList.replace('scale-95', 'scale-100'); 
                }, 10);
                document.body.style.overflow = 'hidden';
            }
        }));

        const closeModal = () => {
            if (modal && modalImg) {
                modal.classList.replace('opacity-100', 'opacity-0');
                modalImg.classList.replace('scale-100', 'scale-95');
                setTimeout(() => { 
                    modal.classList.add('hidden'); 
                    document.body.style.overflow = ''; 
                }, 300);
            }
        };

        closeBtn?.addEventListener('click', closeModal);
        modal?.addEventListener('click', (e) => { if(e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    });
</script>
