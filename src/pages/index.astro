---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');
const allFlyers = await getCollection('flyers').catch(() => []);

// 2. TIME LOGIC (UK Time)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();

const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];

// 3. RESOLVE RELATIONSHIPS (Corrected for new filenames and DJ Fallbacks)
const allShowsDetailed = rawSlots.map((slot) => {
    const isAutoDj = slot.show === 'Auto DJ'; // Updated to match your new filename
    const showEntry = !isAutoDj ? allShows.find(s => s.id === slot.show) : null;
    
    const firstHostId = showEntry?.data?.hosts?.[0];
    
    // DJ Lookup fix: Stripping extensions and checking slug/id
    const djEntry = firstHostId ? allDjs.find(d => {
        const safeId = d.id.replace(/\.[^/.]+$/, "");
        return safeId === firstHostId || d.data?.slug === firstHostId || d.id === firstHostId;
    }) : null;

    return { 
        ...slot, 
        isAutoDj,
        showData: showEntry?.data,
        djData: djEntry?.data,
        djId: djEntry?.id?.replace(/\.[^/.]+$/, "") || firstHostId // Fallback ID
    };
});

function timeToMins(timeStr: string, isEndTime: boolean = false) {
    if (!timeStr) return 0;
    const str = String(timeStr).trim();
    let [h, m] = str.split(':').map(Number);
    if (isEndTime && (h === 24 || (h === 0 && m === 0))) return 1440;
    if (h === 24) h = 0;
    return h * 60 + m;
}

// 4. BUILD CONTINUOUS ROLLING TIMELINE
let timeline: any[] = [];

// A. Yesterday's Crossover Logic
const yesterdayIndex = (currentDayIndex + 6) % 7;
allShowsDetailed.filter(s => s.day === daysArray[yesterdayIndex]).forEach(slot => {
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime, true);
    
    if (endMins <= startMins || endMins === 1440) { 
        timeline.push({
            ...slot,
            absoluteStart: -1440 + startMins,
            absoluteEnd: (endMins === 1440) ? 0 : endMins 
        });
    }
});

// B. Today + Next 6 Days Sequential Timeline
for (let i = 0; i < 7; i++) {
    const targetDayIndex = (currentDayIndex + i) % 7;
    const targetDayStr = daysArray[targetDayIndex];
    
    allShowsDetailed.filter(s => s.day === targetDayStr).forEach(slot => {
        const startMins = timeToMins(slot.startTime);
        let endMins = timeToMins(slot.endTime, true);
        
        let absoluteStart = i * 1440 + startMins;
        
        if (endMins <= startMins && endMins !== 1440) {
            endMins += 1440;
        }
        let absoluteEnd = i * 1440 + endMins;

        timeline.push({
            ...slot,
            absoluteStart,
            absoluteEnd
        });
    });
}

timeline.sort((a, b) => a.absoluteStart - b.absoluteStart);
const relevantShows = timeline.filter(show => show.absoluteEnd > currentMins);

// 5. LIVE SHOW DETECTION & UPCOMING LIST
const displayedShows = relevantShows.slice(0, 5).map(show => ({
    ...show,
    isLive: currentMins >= show.absoluteStart && currentMins < show.absoluteEnd
}));

const liveShow = displayedShows.find(show => show.isLive);

// 6. FALLBACK VALUES (Updated to use djId)
const currentShowName = liveShow ? (liveShow.isAutoDj ? "Contrast Selection" : (liveShow.showData?.title || "TBA")) : "Auto DJ Mix";
const currentDJName = liveShow ? (liveShow.isAutoDj ? "Contrast Radio" : (liveShow.djData?.name || liveShow.djId || "Guest DJ")) : "Contrast Radio";

// 7. FLYERS
const activeFlyers = allFlyers
    .sort((a, b) => b.id.localeCompare(a.id)) 
    .slice(0, 4);
---

<Layout title="Contrast Radio | Up and Coming" currentShow={currentShowName}>
    
    <section class="relative h-[70vh] min-h-[450px] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1603048588665-791ca8aea617?q=80&w=2070&auto=format&fit=crop" alt="Contrast Turntable" class="w-full h-full object-cover opacity-40">
            <div class="absolute inset-0 bg-gradient-to-t from-[#13111C] via-[#13111C]/30 to-transparent"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10 text-center">
            <div class="inline-flex items-center gap-2 bg-[#1E1B29]/80 border border-[#9b51e0]/20 backdrop-blur-sm px-4 py-1.5 rounded-full mb-6">
                <span class={`w-2 h-2 rounded-full ${liveShow ? 'bg-red-500 animate-pulse' : 'bg-gray-500'}`}></span>
                <span class="text-[10px] font-bold tracking-[0.2em] text-red-50 uppercase">
                    {liveShow ? `LIVE NOW: ${currentDJName}` : 'AUTO DJ MODE'}
                </span>
            </div>
            
            <h2 class="text-5xl md:text-7xl font-black tracking-tighter mb-4 uppercase">
                Broadcasting the <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">Vibe.</span>
            </h2>
            
            <p class="text-base md:text-lg text-gray-300 max-w-xl mx-auto mb-10 leading-relaxed">
                Currently playing: <strong class="text-white">{currentShowName}</strong>{liveShow && !liveShow.isAutoDj && ` with ${currentDJName}`}.<br>
                Streaming the finest Reggae, Soul, R&B, and House music 24/7.
            </p>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <button class="player-trigger w-full sm:w-auto bg-[#9b51e0] hover:bg-purple-600 text-white px-8 py-4 rounded-full font-bold text-xs tracking-widest transition-all shadow-xl shadow-purple-500/20 flex items-center justify-center gap-3 group active:scale-95">
                    <i class="fa-solid fa-play group-hover:scale-110 transition-transform"></i> TUNE IN NOW
                </button>
                <a href="/schedule" class="w-full sm:w-auto bg-[#1E1B29] hover:bg-gray-800 text-white border border-gray-700 px-8 py-4 rounded-full font-bold text-xs tracking-widest transition-all flex items-center justify-center gap-2 active:scale-95">
                    VIEW SCHEDULE
                </a>
            </div>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 space-y-20 py-12">
        <section id="schedule" class="scroll-mt-24">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-xl font-black flex items-center gap-2 uppercase tracking-tight">
                    <i class="fa-solid fa-tower-broadcast text-[#9b51e0]"></i> Upcoming Shows
                </h2>
                <a href="/schedule" class="text-[#b77bed] hover:text-white font-bold text-xs flex items-center gap-1 transition-colors uppercase tracking-widest">
                    Full Schedule <i class="fa-solid fa-arrow-right text-[10px]"></i>
                </a>
            </div>

            <div class="bg-[#1E1B29] rounded-2xl border border-gray-800/50 overflow-hidden divide-y divide-gray-800/50 shadow-2xl">
                {displayedShows.map(slot => (
                    <div class={`relative flex flex-col sm:flex-row sm:items-center p-6 sm:p-7 transition-all group ${slot.isLive ? 'bg-[#9b51e0]/10 border-l-4 border-[#9b51e0]' : 'hover:bg-gray-800/30'}`}>
                        <div class="flex-shrink-0 w-32 mb-2 sm:mb-0 flex flex-col">
                            <span class={`text-[10px] font-black uppercase mb-0.5 tracking-widest ${slot.isLive ? 'text-[#b77bed]' : 'text-gray-500'}`}>
                                {slot.day.split('-')[1]}
                            </span>
                            <span class={`text-lg font-black ${slot.isLive ? 'text-white' : 'text-gray-200'}`}>
                                {slot.startTime} - {slot.endTime}
                            </span>
                            {slot.isLive && <span class="bg-red-500 text-white text-[9px] font-black px-2 py-0.5 rounded uppercase tracking-wider mt-1.5 w-fit shadow-lg shadow-red-500/20 animate-pulse">ON AIR</span>}
                        </div>

                        <div class="flex-grow sm:px-12 text-left">
                            <h3 class="text-xl font-black text-white mb-2 leading-tight group-hover:text-[#b77bed] transition-colors">
                                {slot.isAutoDj ? "Contrast Selection" : (slot.showData?.title || "TBA")}
                            </h3>
                            <span class={`text-[10px] font-black px-2.5 py-1 rounded inline-block uppercase tracking-widest border ${slot.isLive ? 'bg-[#9b51e0]/20 border-[#9b51e0]/30 text-[#b77bed]' : 'bg-gray-800 border-gray-700 text-gray-500'}`}>
                                {slot.isAutoDj ? "Auto Mix" : (slot.showData?.genre || "Various")}
                            </span>
                        </div>

                        <div class="flex items-center justify-end gap-4 mt-5 sm:mt-0 sm:min-w-[260px]">
                            <div class={`w-11 h-11 rounded-full flex items-center justify-center text-sm ring-2 ring-offset-2 ring-offset-[#1E1B29] transition-all duration-300 shadow-inner overflow-hidden ${slot.isLive ? 'bg-[#9b51e0]/30 text-[#b77bed] ring-[#9b51e0]/50' : 'bg-gray-800 text-gray-400 border border-gray-700 ring-transparent'}`}>
                                {slot.djData?.avatar && !slot.isAutoDj ? (
                                    <img src={slot.djData.avatar} alt={slot.djData?.name || slot.djId} class="w-full h-full object-cover" />
                                ) : (
                                    <i class={`fa-solid ${slot.isAutoDj ? 'fa-compact-disc' : 'fa-user'} ${slot.isLive && slot.isAutoDj ? 'fa-spin' : ''}`}></i>
                                )}
                            </div>
                            <div class="flex flex-col text-right">
                                <span class="text-[9px] font-bold text-gray-500 uppercase tracking-widest">HOST</span>
                                <span class={`font-bold text-sm leading-none ${slot.isLive ? 'text-white' : 'text-gray-400'}`}>
                                    {slot.isAutoDj ? "Contrast Radio" : (slot.djData?.name || slot.djId || "Guest DJ")}
                                </span>
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section id="events">
            <h2 class="text-xl font-black flex items-center gap-2 mb-8 uppercase tracking-tight">
                <i class="fa-solid fa-ticket text-[#9b51e0]"></i> Latest Events
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-5 sm:gap-6">
                {activeFlyers.map(flyer => (
                    <button class="flyer-card group relative rounded-xl overflow-hidden aspect-[4/5] bg-gray-800 border border-gray-700/50 text-left transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10">
                        {flyer.data.image && <img src={flyer.data.image} alt={flyer.data.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />}
                        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/20 to-transparent flex flex-col justify-end p-5">
                            <h3 class="text-white font-black text-sm leading-tight uppercase group-hover:text-[#b77bed] transition-colors">{flyer.data.title}</h3>
                        </div>
                    </button>
                ))}
                <div class="hidden md:flex rounded-xl bg-[#1E1B29] border border-dashed border-gray-700 flex flex-col items-center justify-center text-center p-6 hover:border-[#9b51e0]/50 transition-all group cursor-pointer hover:bg-[#1E1B29]/40">
                    <i class="fa-solid fa-circle-plus text-3xl text-gray-600 mb-4 group-hover:text-[#9b51e0] group-hover:scale-110 transition-all"></i>
                    <h3 class="text-white font-black text-xs mb-1 uppercase tracking-wider">Host an Event?</h3>
                    <p class="text-[10px] text-gray-500 uppercase font-bold tracking-tighter">Promote your night with us.</p>
                </div>
            </div>
        </section>

        <section id="sponsors" class="pt-12 border-t border-gray-800/40">
            <div class="flex items-center justify-center mb-10">
                <span class="text-[10px] font-black tracking-[0.3em] text-gray-600 uppercase flex items-center gap-6">
                    <span class="w-12 h-[1px] bg-gray-800"></span> OUR SPONSORS <span class="w-12 h-[1px] bg-gray-800"></span>
                </span>
            </div>
            <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-8 opacity-40 hover:opacity-100 transition-opacity duration-700">
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 hover:text-white transition-colors cursor-default"><i class="fa-solid fa-building text-[#9b51e0]"></i> SION SPACES</div>
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 hover:text-white transition-colors cursor-default"><i class="fa-solid fa-house text-[#9b51e0]"></i> Hyde & Rowe</div>
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 hover:text-white transition-colors cursor-default"><i class="fa-solid fa-martini-glass text-[#9b51e0]"></i> Barry's Bar</div>
                <div class="flex items-center gap-3 font-black text-xs uppercase tracking-widest text-gray-200 hover:text-white transition-colors cursor-default"><i class="fa-solid fa-car text-[#9b51e0]"></i> Sayez Car Care</div>
            </div>
        </section>
    </div>

    <div id="flyer-modal" class="fixed inset-0 z-[60] bg-black/95 backdrop-blur-md hidden flex items-center justify-center p-4 transition-opacity duration-300 opacity-0">
        <button class="absolute top-6 right-6 text-white hover:text-[#9b51e0] text-4xl w-12 h-12 flex items-center justify-center bg-black/40 rounded-full transition-all hover:scale-110 active:scale-95 shadow-lg">&times;</button>
        <img id="modal-img" src="" alt="Full Flyer" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-[0_0_50px_rgba(0,0,0,0.8)] scale-95 transition-transform duration-300">
    </div>

</Layout>

<script>
    document.addEventListener('astro:page-load', () => {
        const flyers = document.querySelectorAll('.flyer-card');
        const modal = document.getElementById('flyer-modal');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const closeBtn = modal?.querySelector('button');

        flyers.forEach(card => card.addEventListener('click', () => {
            const img = card.querySelector('img');
            if (img && modal && modalImg) {
                modalImg.src = img.src;
                modal.classList.remove('hidden');
                setTimeout(() => { 
                    modal.classList.replace('opacity-0', 'opacity-100'); 
                    modalImg.classList.replace('scale-95', 'scale-100'); 
                }, 10);
                document.body.style.overflow = 'hidden';
            }
        }));

        const closeModal = () => {
            if (modal && modalImg) {
                modal.classList.replace('opacity-100', 'opacity-0');
                modalImg.classList.replace('scale-100', 'scale-95');
                setTimeout(() => { 
                    modal.classList.add('hidden'); 
                    document.body.style.overflow = ''; 
                }, 300);
            }
        };

        closeBtn?.addEventListener('click', closeModal);
        modal?.addEventListener('click', (e) => { if(e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    });
</script>
