---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];
const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');
const allFlyers = await getCollection('flyers').catch(() => []);

// 2. TIME LOGIC (UK Time Synchronization)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];

// 3. RESOLVE RELATIONSHIPS
const allShowsDetailed = rawSlots.map((slot) => {
    const isAutoDj = slot.show === 'Auto DJ' || slot.show === 'auto-dj';
    const showEntry = !isAutoDj ? allShows.find(s => 
        s.id === slot.show || s.data.title === slot.show ||
        s.id === slot.show.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and')
    ) : null;
    
    const firstHostId = showEntry?.data?.hosts?.[0];
    const djEntry = firstHostId ? allDjs.find(d => {
        const safeId = d.id.replace(/\.[^/.]+$/, "");
        return safeId === firstHostId || d.data?.slug === firstHostId || d.id === firstHostId;
    }) : null;

    return { 
        ...slot, 
        isAutoDj,
        showData: showEntry?.data,
        djData: djEntry?.data,
        djId: djEntry?.id?.replace(/\.[^/.]+$/, "") || firstHostId,
        displayName: isAutoDj ? "Contrast Selection" : (showEntry?.data.title || slot.show)
    };
});

function timeToMins(timeStr: string, isEndTime: boolean = false) {
    if (!timeStr) return 0;
    const str = String(timeStr).trim();
    let [h, m] = str.split(':').map(Number);
    if (isEndTime && (h === 24 || (h === 0 && m === 0))) return 1440;
    if (h === 24) h = 0;
    return h * 60 + m;
}

// 4. TIMELINE CALCULATION
let timeline: any[] = [];
const yesterdayIndex = (currentDayIndex + 6) % 7;
allShowsDetailed.filter(s => s.day === daysArray[yesterdayIndex]).forEach(slot => {
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime, true);
    if (endMins <= startMins || endMins === 1440) { 
        timeline.push({ ...slot, absoluteStart: -1440 + startMins, absoluteEnd: (endMins === 1440) ? 0 : endMins });
    }
});

for (let i = 0; i < 7; i++) {
    const targetDayIndex = (currentDayIndex + i) % 7;
    const targetDayStr = daysArray[targetDayIndex];
    allShowsDetailed.filter(s => s.day === targetDayStr).forEach(slot => {
        const startMins = timeToMins(slot.startTime);
        let endMins = timeToMins(slot.endTime, true);
        let absoluteStart = i * 1440 + startMins;
        if (endMins <= startMins && endMins !== 1440) endMins += 1440;
        let absoluteEnd = i * 1440 + endMins;
        timeline.push({ ...slot, absoluteStart, absoluteEnd });
    });
}

timeline.sort((a, b) => a.absoluteStart - b.absoluteStart);
const relevantShows = timeline.filter(show => show.absoluteEnd > currentMins);

// 5. LIVE DETECTION
const displayedShows = relevantShows.slice(0, 5).map(show => ({
    ...show,
    isLive: currentMins >= show.absoluteStart && currentMins < show.absoluteEnd
}));

const liveShow = displayedShows.find(show => show.isLive);
const currentShowName = liveShow ? liveShow.displayName : "Auto DJ Mix";
const currentDJName = liveShow ? (liveShow.isAutoDj ? "Contrast Radio" : (liveShow.djData?.name || liveShow.djId || "Guest DJ")) : "Contrast Radio";
const activeFlyers = allFlyers.sort((a, b) => b.id.localeCompare(a.id)).slice(0, 4);
---

<Layout title="Contrast Radio | Up and Coming" currentShow={currentShowName}>
    
    <section class="relative h-[90vh] min-h-[700px] flex items-center justify-center overflow-hidden border-b border-white/5">
        <div class="absolute inset-0 z-0 bg-brand-dark">
            <img src="https://images.unsplash.com/photo-1603048588665-791ca8aea617?q=80&w=2070&auto=format&fit=crop" alt="Turntable" class="w-full h-full object-cover opacity-30 scale-110 rotate-[-1deg] pointer-events-none select-none" />
            <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,59,59,0.05)_0%,transparent_50%)]"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/60 to-brand-dark/10"></div>
            <div class="absolute inset-0 opacity-[0.04] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10 text-center flex flex-col items-center">
            
            <div class="inline-flex items-center gap-3 bg-white/[0.03] border border-white/10 backdrop-blur-2xl px-6 py-2.5 rounded-full mb-8 md:mb-12 shadow-2xl">
                <div class="relative flex items-center justify-center">
                    <span class={`w-2.5 h-2.5 rounded-full ${liveShow ? 'bg-brand-accent animate-ping' : 'bg-gray-500'}`}></span>
                    <span class={`absolute w-2.5 h-2.5 rounded-full ${liveShow ? 'bg-brand-accent' : 'bg-gray-500'}`}></span>
                </div>
                <span class="text-[10px] md:text-[11px] font-black tracking-[0.4em] text-white uppercase italic">
                    {liveShow ? 'LIVE STUDIO TRANSMISSION' : 'AUTOMATED SIGNAL ACTIVE'}
                </span>
            </div>
            
            <div class="mb-10 w-full">
                <h2 class="flex flex-col items-center text-5xl sm:text-7xl md:text-[8rem] lg:text-[9.5rem] font-black tracking-tighter uppercase leading-[0.85] italic select-none">
                    <span class="text-white drop-shadow-[0_5px_15px_rgba(0,0,0,0.6)]">BROADCASTING</span>
                    <span class="text-transparent bg-clip-text bg-gradient-to-br from-white via-white/80 to-brand-accent drop-shadow-[0_0_10px_theme('colors.brand.accent/10')] px-8 -mx-8 py-2">
                        THE VIBE
                    </span>
                </h2>
            </div>
            
            <div class="max-w-3xl mx-auto mb-14">
                <div class="bg-white/[0.03] border border-white/10 rounded-2xl py-5 px-6 md:py-6 md:px-8 backdrop-blur-2xl inline-block shadow-2xl">
                    <p class="text-[10px] md:text-sm text-gray-400 font-medium uppercase tracking-[0.3em] mb-2">
                        Streaming <span class="text-white font-black italic">Curated Underground</span> Sounds 24/7
                    </p>
                    <div class="flex items-center justify-center gap-3">
                        <div class="h-[1px] w-6 md:w-8 bg-brand-accent/40"></div>
                        <p class="text-xs md:text-lg text-white font-black uppercase italic tracking-widest leading-none">
                            On Air: <span class="text-brand-accent drop-shadow-md">{currentDJName}</span>
                        </p>
                        <div class="h-[1px] w-6 md:w-8 bg-brand-accent/40"></div>
                    </div>
                </div>
            </div>

            <div class="flex flex-col sm:flex-row items-center justify-center gap-4 md:gap-6 w-full max-w-lg mx-auto">
                <button class="player-trigger group w-full sm:w-72 bg-brand-accent hover:bg-[#e02d2d] text-white px-10 py-5 md:py-6 rounded-2xl md:rounded-full font-black text-[10px] md:text-[11px] tracking-[0.3em] transition-all shadow-[0_4px_15px_theme('colors.brand.accent/15')] flex items-center justify-center gap-4 active:scale-95 uppercase border border-brand-accent/30">
                    <i class="fa-solid fa-play text-xs group-hover:scale-125 transition-transform"></i> TUNE IN NOW
                </button>
                <a href="/schedule" class="w-full sm:w-72 bg-white/[0.03] backdrop-blur-xl hover:bg-white/10 hover:border-brand-accent/30 text-white border border-white/10 px-10 py-5 md:py-6 rounded-2xl md:rounded-full font-black text-[10px] md:text-[11px] tracking-[0.3em] transition-all flex items-center justify-center gap-3 active:scale-95 uppercase shadow-xl">
                    Full Schedule
                </a>
            </div>
        </div>

        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 opacity-20 animate-bounce hidden md:block text-brand-accent">
            <i class="fa-solid fa-chevron-down text-xl"></i>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 space-y-24 py-24">
        
        <section id="schedule" class="scroll-mt-24">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
                <h2 class="text-3xl md:text-4xl font-black flex items-center gap-4 uppercase italic tracking-tighter text-white">
                    <i class="fa-solid fa-tower-broadcast text-brand-accent drop-shadow-md"></i> Upcoming Shows
                </h2>
                <a href="/schedule" class="w-fit bg-brand-surface border border-white/5 hover:border-brand-accent/50 text-white font-black text-[10px] px-6 py-3 rounded-full flex items-center gap-3 transition-all shadow-xl uppercase tracking-[0.3em] group">
                    FULL CALENDAR <i class="fa-solid fa-chevron-right text-[8px] text-brand-accent group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>

            <div class="bg-brand-surface/40 backdrop-blur-xl rounded-[2rem] border border-white/5 overflow-hidden divide-y divide-white/[0.02] shadow-2xl">
                {displayedShows.map(slot => (
                    <div class={`relative flex flex-col sm:flex-row sm:items-center p-8 sm:p-10 transition-all duration-500 group border-l-4 ${slot.isLive ? 'bg-gradient-to-r from-brand-accent/[0.05] to-transparent border-brand-accent' : 'hover:bg-white/[0.02] border-transparent'}`}>
                        
                        <div class="flex-shrink-0 w-40 mb-4 md:mb-0 flex flex-col">
                            <span class={`text-[10px] font-black uppercase mb-1 tracking-[0.2em] ${slot.isLive ? 'text-brand-accent' : 'text-gray-500'}`}>
                                {slot.day.split('-')[1]}
                            </span>
                            <span class={`text-xl font-black tracking-tighter ${slot.isLive ? 'text-white' : 'text-gray-300'}`}>
                                {slot.startTime} — {slot.endTime}
                            </span>
                            {slot.isLive && (
                                <div class="flex items-center gap-2 mt-2">
                                    <span class="w-1.5 h-1.5 rounded-full bg-brand-accent animate-pulse"></span>
                                    <span class="text-[9px] font-black text-brand-accent tracking-widest uppercase">ON AIR</span>
                                </div>
                            )}
                        </div>

                        <div class="flex-grow md:px-12 text-left">
                            <h3 class="text-2xl font-black text-white mb-2 leading-tight group-hover:text-brand-accent transition-colors uppercase italic">
                                {slot.displayName}
                            </h3>
                            <span class={`text-[9px] font-black px-3 py-1 rounded-full inline-block uppercase tracking-[0.2em] border transition-colors ${slot.isLive ? 'bg-brand-accent/10 border-brand-accent/20 text-brand-accent' : 'bg-brand-dark border-white/5 text-gray-400'}`}>
                                {slot.isAutoDj ? "Auto Mix" : (slot.showData?.genre || "Various")}
                            </span>
                        </div>

                        <div class="flex items-center justify-end gap-5 mt-6 md:mt-0 md:min-w-[280px]">
                            <div class="flex flex-col text-right">
                                <span class="text-[9px] font-black text-gray-500 uppercase tracking-widest mb-1">Presented by</span>
                                <span class={`font-black text-base uppercase italic leading-none transition-colors ${slot.isLive ? 'text-white' : 'text-gray-400'}`}>
                                    {slot.isAutoDj ? "Contrast Radio" : (slot.djData?.name || slot.djId || "Guest DJ")}
                                </span>
                            </div>
                            <div class={`w-14 h-14 rounded-full overflow-hidden flex items-center justify-center text-lg transition-all duration-500 shadow-2xl ${slot.isLive ? 'ring-2 ring-brand-accent scale-110' : 'bg-brand-dark border border-white/5 grayscale opacity-60'}`}>
                                {slot.djData?.avatar && !slot.isAutoDj ? (
                                    <img src={slot.djData.avatar} class="w-full h-full object-cover" />
                                ) : (
                                    <i class={`fa-solid ${slot.isAutoDj ? 'fa-compact-disc' : 'fa-user'} ${slot.isLive ? 'fa-spin-slow' : ''}`}></i>
                                )}
                            </div>
                        </div>
                    </div>
                ))}
            </div>
        </section>

        <section id="events">
            <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
                <h2 class="text-3xl md:text-4xl font-black flex items-center gap-4 uppercase italic tracking-tighter text-white">
                    <i class="fa-solid fa-ticket text-brand-accent"></i> Events & Flyers
                </h2>
                <a href="/gallery" class="w-fit bg-brand-surface border border-white/5 hover:border-brand-accent/50 text-white font-black text-[10px] px-6 py-3 rounded-full flex items-center gap-3 transition-all shadow-xl uppercase tracking-[0.3em] group">
                    VIEW GALLERY <i class="fa-solid fa-arrow-right text-[8px] text-brand-accent group-hover:translate-x-1 transition-transform"></i>
                </a>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
                {activeFlyers.map(flyer => (
                    <button class="flyer-card group relative rounded-[2rem] md:rounded-[2.5rem] overflow-hidden aspect-[4/5] bg-brand-surface/50 border border-white/5 text-left transition-all duration-700 hover:-translate-y-3 hover:border-brand-accent/30 hover:shadow-2xl hover:shadow-brand-accent/20 active:scale-95">
                        {flyer.data.image && <img src={flyer.data.image} alt={flyer.data.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />}
                        <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-brand-dark/20 to-transparent flex flex-col justify-end p-6 md:p-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                            <span class="text-brand-accent text-[8px] font-black uppercase tracking-[0.3em] mb-2">Contrast visual</span>
                            <h3 class="text-white font-black text-lg leading-tight uppercase italic">{flyer.data.title}</h3>
                        </div>
                    </button>
                ))}
            </div>
        </section>

        <section id="sponsors" class="pt-24 pb-12 border-t border-white/5 relative">
            <div class="text-center mb-10">
                <span class="text-[10px] font-black tracking-[0.4em] text-gray-500 uppercase">Station Partners</span>
            </div>
            <div class="flex flex-wrap justify-center items-center gap-x-20 gap-y-12 opacity-50 hover:opacity-100 transition-opacity duration-1000 grayscale hover:grayscale-0">
                <div class="flex items-center gap-3 font-black text-sm uppercase tracking-widest text-gray-400 hover:text-brand-accent cursor-default transition-all hover:scale-105"><i class="fa-solid fa-building text-lg"></i> SION SPACES</div>
                <div class="flex items-center gap-3 font-black text-sm uppercase tracking-widest text-gray-400 hover:text-brand-accent cursor-default transition-all hover:scale-105"><i class="fa-solid fa-house text-lg"></i> Hyde & Rowe</div>
                <div class="flex items-center gap-3 font-black text-sm uppercase tracking-widest text-gray-400 hover:text-brand-accent cursor-default transition-all hover:scale-105"><i class="fa-solid fa-martini-glass text-lg"></i> Barry's Bar</div>
                <div class="flex items-center gap-3 font-black text-sm uppercase tracking-widest text-gray-400 hover:text-brand-accent cursor-default transition-all hover:scale-105"><i class="fa-solid fa-car text-lg"></i> Sayez Car Care</div>
            </div>
        </section>
    </div>

    <div id="flyer-modal" class="fixed inset-0 z-[60] bg-brand-dark/98 backdrop-blur-3xl hidden flex items-center justify-center p-8 transition-opacity duration-300 opacity-0">
        <button class="absolute top-8 right-8 text-white hover:text-brand-accent text-6xl transition-all hover:rotate-90 active:scale-90">&times;</button>
        <img id="modal-img" src="" class="max-w-full max-h-[85vh] object-contain rounded-[2rem] border border-white/10 shadow-[0_0_100px_rgba(0,0,0,0.8)] scale-95 transition-transform duration-500">
    </div>

</Layout>

<style>
    .fa-spin-slow { animation: spin 12s linear infinite; }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>

<script>
    document.addEventListener('astro:page-load', () => {
        const flyers = document.querySelectorAll('.flyer-card');
        const modal = document.getElementById('flyer-modal');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const closeBtn = modal?.querySelector('button');

        flyers.forEach(card => card.addEventListener('click', () => {
            const img = card.querySelector('img');
            if (img && modal && modalImg) {
                modalImg.src = img.src;
                modal.classList.remove('hidden');
                setTimeout(() => { 
                    modal.classList.replace('opacity-0', 'opacity-100'); 
                    modalImg.classList.replace('scale-95', 'scale-100'); 
                }, 10);
                document.body.style.overflow = 'hidden';
            }
        }));

        const closeModal = () => {
            if (modal && modalImg) {
                modal.classList.replace('opacity-100', 'opacity-0');
                modalImg.classList.replace('scale-100', 'scale-95');
                setTimeout(() => { modal.classList.add('hidden'); document.body.style.overflow = ''; }, 300);
            }
        };

        closeBtn?.addEventListener('click', closeModal);
        modal?.addEventListener('click', (e) => { if(e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    });
</script>
