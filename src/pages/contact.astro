---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING - For Header Status Synchronization
const allShows = await getCollection('shows');
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

// 2. TIME LOGIC (For Header Status)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[dateInUK.getDay()];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    return h * 60 + m;
}

const currentSlot = rawSlots.find(slot => {
    if (slot.day !== currentDayStr) return false;
    const start = timeToMins(slot.startTime);
    let end = timeToMins(slot.endTime || "00:00");
    if (end <= start) end += 1440;
    return currentMins >= start && currentMins < end;
});

const currentShowName = currentSlot ? 
    (currentSlot.show === 'Auto DJ' ? "Contrast Selection" : (allShows.find(s => s.id === currentSlot.show)?.data.title || "Unknown")) 
    : "Auto DJ Mix";
---

<Layout title="Contact Us | Contrast Radio" currentShow={currentShowName}>
    
    <Hero 
        title="GET IN" 
        accent="TOUCH" 
        subtextText="Transmission Channels" 
        subtextHighlight="Send a Signal"
        bgImage="https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop"
    />

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-32">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 max-w-6xl mx-auto">
            
            <div class="space-y-12">
                <div class="space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="text-brand-accent text-2xl drop-shadow-[0_0_10px_rgba(255,59,59,0.5)]">
                            <i class="fa-solid fa-satellite-dish"></i>
                        </div>
                        <h2 class="text-3xl font-black uppercase italic tracking-tight text-white">Transmission</h2>
                    </div>
                    
                    <p class="text-lg text-gray-400 leading-relaxed italic font-medium">
                        Whether you're a listener wanting to send a shoutout to the studio, or a DJ looking to pitch a guest mix, we want to hear from you.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-6">
                    {[
                        { label: "General Enquiries", link: "info@contrastradio.com", icon: "fa-envelope" },
                        { label: "Music Submissions", link: "promo@contrastradio.com", icon: "fa-music" },
                        { label: "Studio WhatsApp", link: "+44 7700 900077", icon: "fa-whatsapp", brand: "fa-brands" }
                    ].map(item => (
                        <div class="group flex items-center gap-6 p-8 bg-brand-surface/40 border border-white/5 rounded-[2rem] transition-all duration-500 hover:border-brand-accent/30 hover:bg-brand-surface/60 backdrop-blur-md relative overflow-hidden">
                            <div class="w-14 h-14 rounded-full bg-brand-accent/10 flex items-center justify-center text-brand-accent text-xl group-hover:scale-110 group-hover:bg-brand-accent group-hover:text-white transition-all duration-500 shadow-xl">
                                <i class={`${item.brand || 'fa-solid'} ${item.icon}`}></i>
                            </div>
                            <div class="relative z-10">
                                <span class="block text-[9px] font-black text-gray-500 uppercase tracking-[0.3em] mb-1">{item.label}</span>
                                {item.link.includes('@') ? (
                                    <a href={`mailto:${item.link}`} class="text-white font-black text-lg hover:text-brand-accent transition-colors italic tracking-tight">{item.link}</a>
                                ) : (
                                    <span class="text-white font-black text-lg italic tracking-tight">{item.link}</span>
                                )}
                            </div>
                            <div class="absolute inset-0 bg-gradient-to-tr from-brand-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        </div>
                    ))}
                </div>

                <div class="space-y-8">
                    <h3 class="text-white font-black uppercase italic tracking-tight text-xl">Follow The Vibe</h3>
                    <div class="flex gap-5">
                        {['instagram', 'twitter', 'soundcloud', 'youtube'].map(platform => (
                            <a href="#" class="w-14 h-14 rounded-full bg-brand-surface border border-white/5 flex items-center justify-center text-gray-400 hover:bg-brand-accent hover:text-white hover:border-brand-accent hover:-translate-y-2 transition-all duration-500 shadow-2xl" aria-label={platform}>
                                <i class={`fa-brands fa-${platform} text-xl`}></i>
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <div class="relative group">
                <div class="bg-brand-surface/40 backdrop-blur-2xl border border-white/10 p-10 sm:p-14 rounded-[3rem] shadow-[0_40px_80px_rgba(0,0,0,0.6)] space-y-10 relative z-10 overflow-hidden">
                    <div class="space-y-2">
                        <h3 class="text-3xl font-black text-white uppercase italic tracking-tighter">Send a Signal</h3>
                        <p class="text-gray-500 font-bold text-xs uppercase tracking-widest">Direct Studio Connection</p>
                    </div>
                    
                    <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6" id="contact-form">
                        <input type="hidden" name="access_key" value="0093b5ba-b719-4189-b369-4a09b42259d2">
                        <input type="hidden" name="subject" value="New Message from Contrast Radio Website">
                        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                        <div class="space-y-3">
                            <label for="name" class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] ml-2 italic">Name / DJ Alias</label>
                            <input type="text" id="name" name="name" required placeholder="How should we call you?" class="w-full bg-brand-dark/50 border border-white/5 rounded-2xl px-6 py-5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent/30 transition-all placeholder:text-gray-700 font-medium" />
                        </div>

                        <div class="space-y-3">
                            <label for="email" class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] ml-2 italic">Email Address</label>
                            <input type="email" id="email" name="email" required placeholder="your@email.com" class="w-full bg-brand-dark/50 border border-white/5 rounded-2xl px-6 py-5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent/30 transition-all placeholder:text-gray-700 font-medium" />
                        </div>

                        <div class="space-y-3">
                            <label for="department" class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] ml-2 italic">Department</label>
                            <div class="relative">
                                <select id="department" name="department" required class="w-full bg-brand-dark/50 border border-white/5 rounded-2xl px-6 py-5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent/30 transition-all appearance-none cursor-pointer font-medium">
                                    <option value="" disabled selected>Select an option...</option>
                                    <option value="Studio Shoutout">Studio Shoutout</option>
                                    <option value="Guest Mix Pitch">Guest Mix Pitch</option>
                                    <option value="Advertising/Sponsorship">Advertising & Sponsorship</option>
                                    <option value="General Enquiry">General Enquiry</option>
                                </select>
                                <i class="fa-solid fa-chevron-down absolute right-6 top-1/2 -translate-y-1/2 text-gray-600 pointer-events-none text-xs"></i>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <label for="message" class="text-[10px] font-black text-gray-400 uppercase tracking-[0.3em] ml-2 italic">Message</label>
                            <textarea id="message" name="message" rows="4" required placeholder="What's on your mind?" class="w-full bg-brand-dark/50 border border-white/5 rounded-2xl px-6 py-5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent/30 transition-all placeholder:text-gray-700 resize-none font-medium"></textarea>
                        </div>

                        <div class="h-captcha" data-captcha="true"></div>

                        <button type="submit" class="w-full bg-brand-accent hover:bg-[#e02d2d] text-white py-6 rounded-2xl font-black text-xs uppercase tracking-[0.3em] transition-all shadow-[0_15px_40px_rgba(255,59,59,0.3)] flex items-center justify-center gap-4 active:scale-[0.98]">
                            SEND TRANSMISSION <i class="fa-solid fa-paper-plane text-[10px]"></i>
                        </button>
                        
                        <p id="form-status" class="hidden text-center text-[10px] font-black tracking-[0.2em] p-6 rounded-2xl mt-6 uppercase italic"></p>
                    </form>
                    
                    <div class="absolute -top-20 -right-20 w-64 h-64 bg-brand-accent/5 blur-3xl -z-10"></div>
                </div>
                <div class="absolute -inset-4 bg-brand-accent/10 rounded-[4rem] blur-3xl -z-10 group-hover:opacity-100 transition duration-1000 opacity-30"></div>
            </div>

        </div>
    </div>

</Layout>

<script src="https://web3forms.com/client/script.js" async defer></script>

<script>
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const result = document.getElementById('form-status');

        if (form && result) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
                const originalBtnText = submitBtn.innerHTML;
                
                submitBtn.innerHTML = 'SIGNAL SENDING... <i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i>';
                submitBtn.disabled = true;
                
                const formData = new FormData(form);
                const object = Object.fromEntries(formData);
                const json = JSON.stringify(object);

                fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: json
                })
                .then(async (response) => {
                    let json = await response.json();
                    if (response.status == 200) {
                        result.innerHTML = "SUCCESS! TRANSMISSION RECEIVED.";
                        result.className = "text-center text-[11px] tracking-[0.3em] font-black p-6 rounded-2xl mt-6 bg-green-500/10 text-green-400 border border-green-500/20 uppercase italic block";
                        result.classList.remove('hidden');
                        form.reset();
                    } else {
                        result.innerHTML = json.message || "ERROR IN TRANSMISSION.";
                        result.className = "text-center text-[11px] tracking-[0.3em] font-black p-6 rounded-2xl mt-6 bg-brand-accent/10 text-brand-accent border border-brand-accent/20 uppercase italic block";
                        result.classList.remove('hidden');
                    }
                })
                .catch(error => {
                    result.innerHTML = "CONNECTION FAILED. TRY AGAIN.";
                    result.className = "text-center text-[11px] tracking-[0.3em] font-black p-6 rounded-2xl mt-6 bg-brand-accent/10 text-brand-accent border border-brand-accent/20 uppercase italic block";
                    result.classList.remove('hidden');
                })
                .then(function() {
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    
                    setTimeout(() => {
                        result.classList.add('hidden');
                    }, 8000);
                });
            });
        }
    });
</script>
