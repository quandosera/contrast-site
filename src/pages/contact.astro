---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us | Contrast Radio">
    
    <section class="page-hero">
        <div class="hero-bg">
            <img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=1920&q=80" alt="Radio Studio Broadcasting" />
            <div class="hero-gradient"></div>
        </div>
        <div class="container hero-content">
            <h1 class="page-title">GET IN <span style="color: var(--purple);">TOUCH</span></h1>
            <p class="page-subtitle">Send a shoutout, submit a mix, or inquire about advertising.</p>
        </div>
    </section>

    <div class="container main-wrapper">
        
        <div class="contact-grid">
            
            <div class="contact-info-column">
                <div class="section-header">
                    <div class="section-icon"><i class="fa-solid fa-satellite-dish"></i></div>
                    <h2>TRANSMISSION</h2>
                </div>
                
                <p class="lead-text">
                    Whether you're a listener wanting to send a shoutout to the studio, or a DJ looking to pitch a guest mix, we want to hear from you.
                </p>

                <div class="info-cards">
                    <div class="info-card">
                        <i class="fa-solid fa-envelope"></i>
                        <div class="info-text">
                            <h3>General Enquiries</h3>
                            <a href="mailto:info@contrastradio.com">info@contrastradio.com</a>
                        </div>
                    </div>
                    
                    <div class="info-card">
                        <i class="fa-solid fa-music"></i>
                        <div class="info-text">
                            <h3>Music Submissions</h3>
                            <a href="mailto:promo@contrastradio.com">promo@contrastradio.com</a>
                        </div>
                    </div>

                    <div class="info-card">
                        <i class="fa-brands fa-whatsapp"></i>
                        <div class="info-text">
                            <h3>Studio WhatsApp</h3>
                            <span>+44 7700 900077</span>
                        </div>
                    </div>
                </div>

                <div class="social-links-large">
                    <h3>Follow The Vibe</h3>
                    <div class="social-icons">
                        <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
                        <a href="#" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
                        <a href="#" aria-label="SoundCloud"><i class="fa-brands fa-soundcloud"></i></a>
                        <a href="#" aria-label="YouTube"><i class="fa-brands fa-youtube"></i></a>
                    </div>
                </div>
            </div>

            <div class="contact-form-column">
                <div class="form-wrapper">
                    <h3>Send a Message</h3>
                    
                    <form action="https://api.web3forms.com/submit" method="POST" class="contact-form" id="contact-form">
                        
                        <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE">
                        
                        <input type="hidden" name="subject" value="New Message from Contrast Radio Website">
                        
                        <input type="checkbox" name="botcheck" class="hidden-honeypot" style="display: none;">

                        <div class="form-group">
                            <label for="name">Name / DJ Alias</label>
                            <input type="text" id="name" name="name" required placeholder="How should we call you?" />
                        </div>

                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="email" required placeholder="your@email.com" />
                        </div>

                        <div class="form-group">
                            <label for="department">Department</label>
                            <div class="select-wrapper">
                                <select id="department" name="department" required>
                                    <option value="" disabled selected>Select an option...</option>
                                    <option value="Studio Shoutout">Studio Shoutout</option>
                                    <option value="Guest Mix Pitch">Guest Mix Pitch</option>
                                    <option value="Advertising/Sponsorship">Advertising & Sponsorship</option>
                                    <option value="General Enquiry">General Enquiry</option>
                                </select>
                                <i class="fa-solid fa-chevron-down select-icon"></i>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="message">Message</label>
                            <textarea id="message" name="message" rows="5" required placeholder="What's on your mind?"></textarea>
                        </div>

                        <button type="submit" class="btn-submit">
                            SEND MESSAGE <i class="fa-solid fa-paper-plane"></i>
                        </button>
                        
                        <p id="form-status" class="form-status"></p>
                    </form>
                </div>
            </div>

        </div>
    </div>

</Layout>

<script>
    // Handle the form submission smoothly without leaving the page
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const result = document.getElementById('form-status');

        if (form && result) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Show loading state
                const submitBtn = form.querySelector('.btn-submit') as HTMLButtonElement;
                const originalBtnText = submitBtn.innerHTML;
                submitBtn.innerHTML = 'SENDING... <i class="fa-solid fa-circle-notch fa-spin"></i>';
                submitBtn.disabled = true;
                
                const formData = new FormData(form);
                const object = Object.fromEntries(formData);
                const json = JSON.stringify(object);

                fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: json
                })
                .then(async (response) => {
                    let json = await response.json();
                    if (response.status == 200) {
                        result.innerHTML = "Success! Your message has been sent to the studio.";
                        result.className = "form-status success";
                        form.reset();
                    } else {
                        console.log(response);
                        result.innerHTML = json.message || "Something went wrong!";
                        result.className = "form-status error";
                    }
                })
                .catch(error => {
                    console.log(error);
                    result.innerHTML = "Something went wrong! Please try again later.";
                    result.className = "form-status error";
                })
                .then(function() {
                    // Reset button state
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    
                    // Clear the success message after 5 seconds
                    setTimeout(() => {
                        result.style.display = 'none';
                    }, 5000);
                });
            });
        }
    });
</script>

<style>
    /* === VARIABLES & BASE === */
    :root {
        --purple: #a855f7;
        --purple-light: #f3e8ff;
        --purple-dark: #7e22ce;
        --bg-body: #f8fafc;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --border-light: #e2e8f0;
        --dark-bg: #1e293b;
    }

    /* === PAGE HERO === */
    .page-hero {
        position: relative;
        padding: 6rem 20px;
        margin-bottom: 4rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
    }
    .hero-bg {
        position: absolute;
        inset: 0;
        z-index: -1;
        overflow: hidden;
    }
    .hero-bg img { width: 100%; height: 100%; object-fit: cover; object-position: center 30%; }
    .hero-gradient {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(15, 23, 42, 0.8) 0%, rgba(15, 23, 42, 0.9) 70%, var(--bg-body) 100%);
    }
    .hero-content { position: relative; z-index: 1; max-width: 800px; }
    .page-title { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; color: #fff; margin: 0; text-transform: uppercase; letter-spacing: -1px; }
    .page-subtitle { font-size: 1.1rem; color: #cbd5e1; margin-top: 1rem; }

    /* === MAIN CONTENT === */
    .main-wrapper { max-width: 1200px; margin: 0 auto; padding-bottom: 5rem; }
    
    .section-header { display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem; }
    .section-icon { color: var(--purple); font-size: 1.8rem; }
    .section-header h2 { margin: 0; font-weight: 900; font-size: 2rem; text-transform: uppercase; color: var(--text-main); }

    .contact-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: start;
    }

    /* === LEFT COLUMN: INFO === */
    .contact-info-column .lead-text {
        font-size: 1.15rem;
        line-height: 1.6;
        color: var(--text-muted);
        margin-bottom: 3rem;
    }

    .info-cards {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 3rem;
    }
    .info-card {
        display: flex;
        align-items: center;
        gap: 20px;
        background: #fff;
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--border-light);
        transition: 0.3s;
    }
    .info-card:hover { border-color: var(--purple); box-shadow: 0 10px 15px -3px rgba(168, 85, 247, 0.1); transform: translateX(5px); }
    .info-card i {
        font-size: 1.5rem;
        color: var(--purple);
        background: var(--purple-light);
        width: 50px;
        height: 50px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
    .info-text h3 { margin: 0 0 5px 0; font-size: 0.9rem; text-transform: uppercase; font-weight: 800; color: var(--text-muted); letter-spacing: 1px; }
    .info-text a, .info-text span { color: var(--text-main); font-weight: 700; font-size: 1.1rem; text-decoration: none; transition: 0.2s; }
    .info-text a:hover { color: var(--purple); }

    .social-links-large h3 { font-size: 1.2rem; font-weight: 900; color: var(--text-main); margin-bottom: 1rem; text-transform: uppercase; }
    .social-icons { display: flex; gap: 15px; }
    .social-icons a {
        width: 45px; height: 45px;
        background: var(--dark-bg);
        color: #fff;
        display: flex; align-items: center; justify-content: center;
        border-radius: 50%;
        font-size: 1.2rem;
        text-decoration: none;
        transition: 0.3s;
    }
    .social-icons a:hover { background: var(--purple); transform: translateY(-3px); box-shadow: 0 10px 15px -3px rgba(168, 85, 247, 0.3); }

    /* === RIGHT COLUMN: FORM === */
    .form-wrapper {
        background: #fff;
        padding: 3rem;
        border-radius: 16px;
        box-shadow: 0 20px 25px -5px rgba(0,0,0,0.05), 0 8px 10px -6px rgba(0,0,0,0.01);
        border: 1px solid var(--border-light);
    }
    .form-wrapper h3 { margin: 0 0 2rem 0; font-size: 1.5rem; font-weight: 900; color: var(--text-main); text-transform: uppercase;}
    
    .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
    .form-group { display: flex; flex-direction: column; gap: 8px; }
    .form-group label { font-size: 0.85rem; font-weight: 800; color: var(--text-main); text-transform: uppercase; letter-spacing: 0.5px; }
    
    .contact-form input[type="text"],
    .contact-form input[type="email"],
    .contact-form select,
    .contact-form textarea {
        width: 100%;
        padding: 14px 16px;
        border: 2px solid var(--border-light);
        border-radius: 8px;
        background: var(--bg-body);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        transition: 0.3s;
    }
    .contact-form input:focus,
    .contact-form select:focus,
    .contact-form textarea:focus {
        outline: none;
        border-color: var(--purple);
        background: #fff;
        box-shadow: 0 0 0 4px var(--purple-light);
    }
    .contact-form textarea { resize: vertical; min-height: 120px; }

    /* Custom Select Wrapper */
    .select-wrapper { position: relative; }
    .select-wrapper select { appearance: none; -webkit-appearance: none; cursor: pointer; padding-right: 40px; }
    .select-icon { position: absolute; right: 16px; top: 50%; transform: translateY(-50%); color: var(--text-muted); pointer-events: none; }

    .btn-submit {
        background: var(--purple);
        color: #fff;
        border: none;
        padding: 16px;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 1px;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 10px;
        margin-top: 1rem;
    }
    .btn-submit:hover:not(:disabled) { background: var(--purple-dark); transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(168, 85, 247, 0.4); }
    .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; }

    .form-status { margin-top: 1rem; padding: 1rem; border-radius: 8px; font-weight: 700; font-size: 0.9rem; text-align: center; display: none; }
    .form-status.success { display: block; background: #dcfce7; color: #166534; border: 1px solid #bbf7d0; }
    .form-status.error { display: block; background: #fee2e2; color: #991b1b; border: 1px solid #fecaca; }

    /* === RESPONSIVE === */
    @media (max-width: 992px) {
        .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
        .form-wrapper { padding: 2rem; }
    }
</style>