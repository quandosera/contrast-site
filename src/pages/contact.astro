---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING - For Header Status Sync
const allShows = await getCollection('shows');
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

// 2. TIME LOGIC (For Header Status)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[dateInUK.getDay()];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    return h * 60 + m;
}

const currentSlot = rawSlots.find(slot => {
    if (slot.day !== currentDayStr) return false;
    const start = timeToMins(slot.startTime);
    let end = timeToMins(slot.endTime || "00:00");
    if (end <= start) end += 1440;
    return currentMins >= start && currentMins < end;
});

const currentShowName = currentSlot ? 
    (currentSlot.show === 'Auto DJ' ? "Contrast Selection" : (allShows.find(s => s.id === currentSlot.show)?.data.title || "Unknown")) 
    : "Auto DJ Mix";
---

<Layout title="Contact Us | Contrast Radio" currentShow={currentShowName}>
    
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img 
                src="https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop&ixlib=rb-4.1.0" 
                alt="Radio Studio Mixing Desk" 
                class="w-full h-full object-cover opacity-20" 
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#13111C]/80 to-[#13111C]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic mb-4">
                GET IN <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">TOUCH</span>
            </h1>
            <p class="text-gray-400 font-bold tracking-widest uppercase text-sm">Send a shoutout, submit a mix, or inquire about advertising</p>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-24">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 max-w-6xl mx-auto">
            
            <div class="space-y-12">
                <div class="space-y-6">
                    <div class="flex items-center gap-3">
                        <div class="text-[#9b51e0] text-2xl"><i class="fa-solid fa-satellite-dish"></i></div>
                        <h2 class="text-3xl font-black uppercase italic tracking-tight text-white">Transmission</h2>
                    </div>
                    
                    <p class="text-lg text-gray-400 leading-relaxed italic">
                        Whether you're a listener wanting to send a shoutout to the studio, or a DJ looking to pitch a guest mix, we want to hear from you.
                    </p>
                </div>

                <div class="grid grid-cols-1 gap-4">
                    <div class="group flex items-center gap-6 p-6 bg-[#1E1B29]/40 border border-gray-800/60 rounded-2xl transition-all duration-300 hover:border-[#9b51e0]/40 hover:bg-[#1E1B29]/60">
                        <div class="w-12 h-12 rounded-full bg-[#9b51e0]/20 flex items-center justify-center text-[#9b51e0] group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-envelope"></i>
                        </div>
                        <div>
                            <span class="block text-[8px] font-black text-gray-500 uppercase tracking-widest mb-1">General Enquiries</span>
                            <a href="mailto:info@contrastradio.com" class="text-white font-bold hover:text-[#b77bed] transition-colors">info@contrastradio.com</a>
                        </div>
                    </div>

                    <div class="group flex items-center gap-6 p-6 bg-[#1E1B29]/40 border border-gray-800/60 rounded-2xl transition-all duration-300 hover:border-[#9b51e0]/40 hover:bg-[#1E1B29]/60">
                        <div class="w-12 h-12 rounded-full bg-[#9b51e0]/20 flex items-center justify-center text-[#9b51e0] group-hover:scale-110 transition-transform">
                            <i class="fa-solid fa-music"></i>
                        </div>
                        <div>
                            <span class="block text-[8px] font-black text-gray-500 uppercase tracking-widest">Music Submissions</span>
                            <a href="mailto:promo@contrastradio.com" class="text-white font-bold hover:text-[#b77bed] transition-colors">promo@contrastradio.com</a>
                        </div>
                    </div>

                    <div class="group flex items-center gap-6 p-6 bg-[#1E1B29]/40 border border-gray-800/60 rounded-2xl transition-all duration-300 hover:border-[#9b51e0]/40 hover:bg-[#1E1B29]/60">
                        <div class="w-12 h-12 rounded-full bg-[#9b51e0]/20 flex items-center justify-center text-[#9b51e0] group-hover:scale-110 transition-transform">
                            <i class="fa-brands fa-whatsapp"></i>
                        </div>
                        <div>
                            <span class="block text-[8px] font-black text-gray-500 uppercase tracking-widest">Studio WhatsApp</span>
                            <span class="text-white font-bold">+44 7700 900077</span>
                        </div>
                    </div>
                </div>

                <div class="space-y-6">
                    <h3 class="text-white font-black uppercase italic tracking-tight">Follow The Vibe</h3>
                    <div class="flex gap-4">
                        {['instagram', 'twitter', 'soundcloud', 'youtube'].map(platform => (
                            <a href="#" class="w-12 h-12 rounded-full bg-gray-900 border border-gray-800 flex items-center justify-center text-gray-400 hover:bg-[#9b51e0] hover:text-white hover:border-[#9b51e0] transition-all duration-300" aria-label={platform}>
                                <i class={`fa-brands fa-${platform} text-lg`}></i>
                            </a>
                        ))}
                    </div>
                </div>
            </div>

            <div class="relative group">
                <div class="bg-[#1E1B29]/60 backdrop-blur-xl border border-gray-800/60 p-8 sm:p-10 rounded-[2.5rem] shadow-2xl space-y-8 relative z-10">
                    <h3 class="text-2xl font-black text-white uppercase italic tracking-tight">Send a Message</h3>
                    
                    <form action="https://api.web3forms.com/submit" method="POST" class="space-y-5" id="contact-form">
                        <input type="hidden" name="access_key" value="0093b5ba-b719-4189-b369-4a09b42259d2">
                        <input type="hidden" name="subject" value="New Message from Contrast Radio Website">
                        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">

                        <div class="space-y-2">
                            <label for="name" class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] ml-1">Name / DJ Alias</label>
                            <input type="text" id="name" name="name" required placeholder="How should we call you?" class="w-full bg-[#13111C]/80 border border-gray-800 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-[#9b51e0] focus:ring-1 focus:ring-[#9b51e0]/30 transition-all placeholder:text-gray-700" />
                        </div>

                        <div class="space-y-2">
                            <label for="email" class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] ml-1">Email Address</label>
                            <input type="email" id="email" name="email" required placeholder="your@email.com" class="w-full bg-[#13111C]/80 border border-gray-800 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-[#9b51e0] focus:ring-1 focus:ring-[#9b51e0]/30 transition-all placeholder:text-gray-700" />
                        </div>

                        <div class="space-y-2">
                            <label for="department" class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] ml-1">Department</label>
                            <div class="relative">
                                <select id="department" name="department" required class="w-full bg-[#13111C]/80 border border-gray-800 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-[#9b51e0] focus:ring-1 focus:ring-[#9b51e0]/30 transition-all appearance-none cursor-pointer">
                                    <option value="" disabled selected>Select an option...</option>
                                    <option value="Studio Shoutout">Studio Shoutout</option>
                                    <option value="Guest Mix Pitch">Guest Mix Pitch</option>
                                    <option value="Advertising/Sponsorship">Advertising & Sponsorship</option>
                                    <option value="General Enquiry">General Enquiry</option>
                                </select>
                                <i class="fa-solid fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-600 pointer-events-none text-xs"></i>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="message" class="text-[9px] font-black text-gray-500 uppercase tracking-[0.2em] ml-1">Message</label>
                            <textarea id="message" name="message" rows="4" required placeholder="What's on your mind?" class="w-full bg-[#13111C]/80 border border-gray-800 rounded-xl px-4 py-4 text-white focus:outline-none focus:border-[#9b51e0] focus:ring-1 focus:ring-[#9b51e0]/30 transition-all placeholder:text-gray-700 resize-none"></textarea>
                        </div>

                        <div class="h-captcha" data-captcha="true"></div>

                        <button type="submit" class="w-full bg-[#9b51e0] hover:bg-purple-600 text-white py-4 rounded-xl font-black text-xs uppercase tracking-widest transition-all shadow-lg shadow-purple-500/20 flex items-center justify-center gap-3 active:scale-[0.98]">
                            SEND MESSAGE <i class="fa-solid fa-paper-plane text-[10px]"></i>
                        </button>
                        
                        <p id="form-status" class="hidden text-center text-sm font-bold p-4 rounded-xl mt-4"></p>
                    </form>
                </div>
                <div class="absolute -inset-2 bg-gradient-to-tr from-[#9b51e0]/10 to-[#b77bed]/10 rounded-[3rem] blur-2xl -z-10 group-hover:opacity-100 transition duration-500 opacity-50"></div>
            </div>

        </div>
    </div>

</Layout>

<script src="https://web3forms.com/client/script.js" async defer></script>

<script>
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const result = document.getElementById('form-status');

        if (form && result) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
                const originalBtnText = submitBtn.innerHTML;
                
                submitBtn.innerHTML = 'SENDING... <i class="fa-solid fa-circle-notch fa-spin text-[10px]"></i>';
                submitBtn.disabled = true;
                
                const formData = new FormData(form);
                const object = Object.fromEntries(formData);
                const json = JSON.stringify(object);

                fetch('https://api.web3forms.com/submit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: json
                })
                .then(async (response) => {
                    let json = await response.json();
                    if (response.status == 200) {
                        result.innerHTML = "SUCCESS! TRANSMISSION RECEIVED.";
                        result.className = "text-center text-[10px] tracking-[0.2em] font-black p-4 rounded-xl mt-4 bg-green-500/10 text-green-400 border border-green-500/20 uppercase";
                        result.classList.remove('hidden');
                        form.reset();
                    } else {
                        result.innerHTML = json.message || "ERROR IN TRANSMISSION.";
                        result.className = "text-center text-[10px] tracking-[0.2em] font-black p-4 rounded-xl mt-4 bg-red-500/10 text-red-400 border border-red-500/20 uppercase";
                        result.classList.remove('hidden');
                    }
                })
                .catch(error => {
                    result.innerHTML = "CONNECTION FAILED. TRY AGAIN.";
                    result.className = "text-center text-[10px] tracking-[0.2em] font-black p-4 rounded-xl mt-4 bg-red-500/10 text-red-400 border border-red-500/20 uppercase";
                    result.classList.remove('hidden');
                })
                .then(function() {
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    
                    setTimeout(() => {
                        result.classList.add('hidden');
                    }, 6000);
                });
            });
        }
    });
</script>
