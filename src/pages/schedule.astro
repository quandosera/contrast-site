---
// src/pages/schedule.astro
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');

// 2. TIME LOGIC (UK Time)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();

// Mapping for your 1-mon, 2-tue naming convention
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[currentDayIndex];
const yesterdayStr = daysArray[(currentDayIndex + 6) % 7];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    if (h === 24) h = 0; 
    return h * 60 + m;
}

// 3. RESOLVE RELATIONSHIPS & LIVE STATUS
const scheduleDetailed = rawSlots.map((slot) => {
    // Matches "Auto DJ" exactly as written in your master.yaml
    const isAutoDj = slot.show === 'Auto DJ' || slot.show === 'auto-dj';
    
    // IMPROVED LOOKUP: Checks ID or Title to match your master.yaml
    const showEntry = !isAutoDj ? allShows.find(s => 
        s.id === slot.show || 
        s.data.title === slot.show ||
        s.id === slot.show.toLowerCase().replace(/\s+/g, '-')
    ) : null;

    const firstHostId = showEntry?.data?.hosts?.[0];
    
    const djEntry = firstHostId ? allDjs.find(d => {
        const safeId = d.id.replace(/\.[^/.]+$/, ""); 
        return safeId === firstHostId || d.data.slug === firstHostId || d.id === firstHostId;
    }) : null;

    let isLive = false;
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime || "00:00");
    const crossesMidnight = endMins <= startMins && endMins !== 0;

    if (slot.day === currentDayStr) {
        let adjustedEndMins = crossesMidnight ? endMins + 1440 : (endMins === 0 ? 1440 : endMins);
        if (currentMins >= startMins && currentMins < adjustedEndMins) isLive = true;
    } 
    else if (slot.day === yesterdayStr && crossesMidnight) {
        if (currentMins < endMins) isLive = true;
    }

    return { 
        slot, 
        isLive, 
        isAutoDj,
        showData: showEntry?.data, 
        djData: djEntry?.data,
        displayName: isAutoDj ? "Contrast Selection" : (showEntry?.data.title || slot.show),
        djId: djEntry?.id?.replace(/\.[^/.]+$/, "") || firstHostId 
    };
});

// Dynamic header sync for the player
const currentLiveSlot = scheduleDetailed.find(item => item.isLive);
const currentShowName = currentLiveSlot ? currentLiveSlot.displayName : "Auto DJ Mix";

const daysOfWeek = [
    { id: '1-mon', label: 'Monday' },
    { id: '2-tue', label: 'Tuesday' },
    { id: '3-wed', label: 'Wednesday' },
    { id: '4-thu', label: 'Thursday' },
    { id: '5-fri', label: 'Friday' },
    { id: '6-sat', label: 'Saturday' },
    { id: '7-sun', label: 'Sunday' }
];

const groupedSchedule = daysOfWeek.map(day => {
    return {
        ...day,
        shows: scheduleDetailed
            .filter(item => item.slot.day === day.id)
            .sort((a, b) => a.slot.startTime.localeCompare(b.slot.startTime))
    };
});
---

<Layout title="Station Schedule | Contrast Radio" currentShow={currentShowName}>
    
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img 
                src="https://images.unsplash.com/photo-1566612453429-50faafea3e5f?q=80&w=1740&auto=format&fit=crop" 
                alt="Studio" 
                class="w-full h-full object-cover opacity-20" 
            />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#13111C]/80 to-[#13111C]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic mb-4">
                STATION <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">SCHEDULE</span>
            </h1>
            <p class="text-gray-400 font-bold tracking-widest uppercase text-sm">Streaming selections 24/7 across the globe</p>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-24">
        <div class="max-w-5xl mx-auto space-y-20">
            
            {groupedSchedule.map(dayGroup => (
                <section class="space-y-8" id={`day-${dayGroup.id}`}>
                    <div class="sticky top-16 z-30 py-6 bg-[#13111C]/95 backdrop-blur-md border-b border-gray-800/50 flex items-center justify-between">
                        <h2 class="text-4xl font-black uppercase italic tracking-tighter">{dayGroup.label}</h2>
                        {dayGroup.id === currentDayStr && (
                            <span class="text-[10px] font-black text-[#9b51e0] bg-[#9b51e0]/10 px-4 py-1.5 rounded-full border border-[#9b51e0]/30 tracking-[0.3em] uppercase">Today</span>
                        )}
                    </div>
                    
                    <div class="grid grid-cols-1 gap-6">
                        {dayGroup.shows.length > 0 ? (
                            dayGroup.shows.map(item => (
                                <div class={`relative flex flex-col md:flex-row md:items-center p-8 rounded-[2rem] border transition-all duration-500 group ${item.isLive ? 'bg-[#9b51e0]/10 border-[#9b51e0]/50 shadow-[0_0_40px_rgba(155,81,224,0.1)]' : 'bg-[#1E1B29]/40 border-gray-800/60 hover:border-gray-700'}`}>
                                    
                                    <div class="flex-shrink-0 w-44 mb-6 md:mb-0">
                                        <div class={`text-xl font-black tracking-tighter ${item.isLive ? 'text-white' : 'text-gray-400'}`}>
                                            {item.slot.startTime} — {item.slot.endTime || "00:00"}
                                        </div>
                                        {item.isLive && (
                                            <div class="flex items-center gap-2 mt-2">
                                                <span class="w-2 h-2 rounded-full bg-red-500 animate-ping"></span>
                                                <span class="text-[10px] font-black text-red-500 tracking-[0.2em] uppercase">On Air</span>
                                            </div>
                                        )}
                                    </div>

                                    <div class="flex-grow md:px-10">
                                        <div class="flex flex-wrap items-center gap-4 mb-3">
                                            <h3 class="text-2xl font-black text-white group-hover:text-[#b77bed] transition-colors uppercase italic leading-none">
                                                {item.displayName}
                                            </h3>
                                            <span class={`text-[9px] font-black px-3 py-1 rounded-full uppercase tracking-[0.2em] border ${item.isLive ? 'bg-[#9b51e0]/30 border-[#9b51e0]/50 text-white' : 'bg-gray-800 border-gray-700 text-gray-500'}`}>
                                                {item.isAutoDj ? "Auto Mix" : (item.showData?.genre || "Various")}
                                            </span>
                                        </div>
                                        
                                        {!item.isAutoDj && item.showData?.description && (
                                            <p class="text-sm text-gray-500 leading-relaxed max-w-2xl line-clamp-2 group-hover:text-gray-400 transition-colors">
                                                {item.showData.description}
                                            </p>
                                        )}
                                    </div>

                                    <div class="flex items-center gap-5 mt-8 md:mt-0 md:min-w-[240px] justify-end border-t md:border-t-0 border-gray-800/50 pt-6 md:pt-0">
                                        <div class="flex flex-col text-right">
                                            <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest mb-1">Presented by</span>
                                            <span class={`font-black text-base uppercase italic leading-none ${item.isLive ? 'text-white' : 'text-gray-400'}`}>
                                                {item.isAutoDj ? "Contrast Radio" : (item.djData?.name || "Guest DJ")}
                                            </span>
                                        </div>
                                        <div class={`w-12 h-12 rounded-full overflow-hidden flex items-center justify-center text-lg shadow-2xl transition-all duration-500 ${item.isLive ? 'ring-2 ring-[#9b51e0] scale-110' : 'bg-gray-800 border border-gray-700 grayscale'}`}>
                                            {item.djData?.avatar && !item.isAutoDj ? (
                                                <img src={item.djData.avatar} alt={item.djData?.name} class="w-full h-full object-cover" />
                                            ) : (
                                                <i class={`fa-solid ${item.isAutoDj ? 'fa-compact-disc' : 'fa-user'} ${item.isLive && item.isAutoDj ? 'fa-spin' : ''}`}></i>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            ))
                        ) : (
                            <div class="flex flex-col items-center justify-center py-20 px-6 rounded-3xl bg-[#1E1B29]/30 border-2 border-dashed border-gray-800 text-center">
                                <i class="fa-solid fa-robot text-4xl text-gray-700 mb-4"></i>
                                <h3 class="text-white font-black text-xl mb-2 uppercase">Auto DJ Active</h3>
                                <p class="text-gray-500 text-sm max-w-sm tracking-wide uppercase font-bold">Non-stop curated Contrast selections streaming through the night.</p>
                            </div>
                        )}
                    </div>
                </section>
            ))}

        </div>
    </div>
</Layout>

<style is:global>
    /* Ensure sticky day headers stay below the fixed site navigation */
    .sticky {
        top: 64px; /* Matches header height (h-16) */
    }
</style>
