---
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING - Preserving your slug and collection logic
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];

const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');

// 2. TIME LOGIC (UK Time for Live Tracking)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();

// Mapping for your 1-mon, 2-tue naming convention
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[currentDayIndex];
const yesterdayStr = daysArray[(currentDayIndex + 6) % 7];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    if (h === 24) h = 0; 
    return h * 60 + m;
}

// 3. DEFINE THE WEEK ORDER
const daysOfWeek = [
    { id: '1-mon', label: 'Monday' },
    { id: '2-tue', label: 'Tuesday' },
    { id: '3-wed', label: 'Wednesday' },
    { id: '4-thu', label: 'Thursday' },
    { id: '5-fri', label: 'Friday' },
    { id: '6-sat', label: 'Saturday' },
    { id: '7-sun', label: 'Sunday' }
];

// 4. RESOLVE RELATIONSHIPS & CALCULATE LIVE STATUS
const scheduleDetailed = rawSlots.map((slot) => {
    const isAutoDj = slot.show === 'auto-dj';
    const showEntry = !isAutoDj ? allShows.find(s => s.id === slot.show) : null;
    
    const firstHostId = showEntry?.data?.hosts?.[0];
    const djEntry = firstHostId ? allDjs.find(d => d.id === firstHostId) : null;

    let isLive = false;
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime || "00:00");
    const crossesMidnight = endMins <= startMins && endMins !== 0;

    if (slot.day === currentDayStr) {
        let adjustedEndMins = crossesMidnight ? endMins + 1440 : (endMins === 0 ? 1440 : endMins);
        if (currentMins >= startMins && currentMins < adjustedEndMins) {
            isLive = true;
        }
    } 
    else if (slot.day === yesterdayStr && crossesMidnight) {
        if (currentMins < endMins) {
            isLive = true;
        }
    }

    return { 
        slot, 
        isLive, 
        isAutoDj,
        showData: showEntry?.data, 
        djData: djEntry?.data 
    };
});

// 5. GROUP SHOWS BY DAY
const groupedSchedule = daysOfWeek.map(day => {
    const dayShows = scheduleDetailed
        .filter(item => item.slot.day === day.id)
        .sort((a, b) => a.slot.startTime.localeCompare(b.slot.startTime));
    
    return {
        ...day,
        shows: dayShows
    };
});
---

<Layout title="Station Schedule | Contrast Radio">
    
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?auto=format&fit=crop&w=1920&q=80" alt="Studio Microphone" class="w-full h-full object-cover opacity-20" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#13111C]/80 to-[#13111C]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic mb-4">
                STATION <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">SCHEDULE</span>
            </h1>
            <p class="text-gray-400 font-bold tracking-widest uppercase text-sm">Streaming selections 24/7 across the globe</p>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-20">
        <div class="max-w-5xl mx-auto space-y-16">
            
            {groupedSchedule.map(dayGroup => (
                <section class="space-y-6" id={`day-${dayGroup.id}`}>
                    <!-- Day Header -->
                    <div class="sticky top-16 z-30 py-4 bg-[#13111C]/90 backdrop-blur-md border-b border-gray-800/50 flex items-center justify-between">
                        <h2 class="text-3xl font-black uppercase italic tracking-tight">{dayGroup.label}</h2>
                        {dayGroup.id === currentDayStr && (
                            <span class="text-[10px] font-black text-[#9b51e0] bg-[#9b51e0]/10 px-3 py-1 rounded-full border border-[#9b51e0]/20 tracking-[0.2em] uppercase">Today</span>
                        )}
                    </div>
                    
                    <div class="grid grid-cols-1 gap-4">
                        {dayGroup.shows.length > 0 ? (
                            dayGroup.shows.map(item => (
                                <div class={`relative flex flex-col md:flex-row md:items-center p-6 rounded-2xl border transition-all duration-300 group ${item.isLive ? 'bg-[#9b51e0]/10 border-[#9b51e0]/40 shadow-xl shadow-purple-500/5' : 'bg-[#1E1B29]/50 border-gray-800/60 hover:border-gray-700 hover:bg-[#1E1B29]'}`}>
                                    
                                    <!-- Time Column -->
                                    <div class="flex-shrink-0 w-40 mb-4 md:mb-0">
                                        <div class={`text-lg font-black tracking-tighter ${item.isLive ? 'text-white' : 'text-gray-300'}`}>
                                            {item.slot.startTime} — {item.slot.endTime || "00:00"}
                                        </div>
                                        {item.isLive && (
                                            <div class="flex items-center gap-2 mt-1">
                                                <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-pulse"></span>
                                                <span class="text-[10px] font-black text-red-500 tracking-widest uppercase">On Air</span>
                                            </div>
                                        )}
                                    </div>

                                    <!-- Show Details -->
                                    <div class="flex-grow md:px-8">
                                        <div class="flex flex-wrap items-center gap-3 mb-2">
                                            <h3 class="text-xl font-black text-white group-hover:text-[#b77bed] transition-colors uppercase leading-tight">
                                                {item.isAutoDj ? "Contrast Selection" : (item.showData?.title || "TBA")}
                                            </h3>
                                            <span class={`text-[9px] font-black px-2 py-0.5 rounded uppercase tracking-[0.15em] border ${item.isLive ? 'bg-[#9b51e0]/20 border-[#9b51e0]/40 text-[#b77bed]' : 'bg-gray-800 border-gray-700 text-gray-500'}`}>
                                                {item.isAutoDj ? "Auto Mix" : (item.showData?.genre || "Various")}
                                            </span>
                                        </div>
                                        
                                        {!item.isAutoDj && item.showData?.description && (
                                            <p class="text-sm text-gray-400 leading-relaxed max-w-2xl line-clamp-2">{item.showData.description}</p>
                                        )}
                                    </div>

                                    <!-- Host Profile (Right) -->
                                    <div class="flex items-center gap-4 mt-6 md:mt-0 md:min-w-[200px] justify-end border-t md:border-t-0 border-gray-800/50 pt-4 md:pt-0">
                                        <div class="flex flex-col text-right">
                                            <span class="text-[8px] font-bold text-gray-500 uppercase tracking-widest">Presented by</span>
                                            <span class={`font-bold text-sm leading-none ${item.isLive ? 'text-white' : 'text-gray-400'}`}>
                                                {item.isAutoDj ? "Contrast Radio" : (item.djData?.name || "Guest DJ")}
                                            </span>
                                        </div>
                                        <div class={`w-10 h-10 rounded-full flex items-center justify-center text-sm shadow-inner transition-all duration-500 ${item.isLive ? 'bg-[#9b51e0]/30 text-[#b77bed] ring-2 ring-[#9b51e0]/40' : 'bg-gray-800 text-gray-500 border border-gray-700'}`}>
                                            {item.djData?.avatar && !item.isAutoDj ? (
                                                <img src={item.djData.avatar} alt={item.djData.name} class="w-full h-full object-cover rounded-full" />
                                            ) : (
                                                <i class={`fa-solid ${item.isAutoDj ? 'fa-compact-disc' : 'fa-user'} ${item.isLive && item.isAutoDj ? 'fa-spin' : ''}`}></i>
                                            )}
                                        </div>
                                    </div>
                                </div>
                            ))
                        ) : (
                            <div class="flex flex-col items-center justify-center py-20 px-6 rounded-3xl bg-[#1E1B29]/30 border-2 border-dashed border-gray-800 text-center">
                                <i class="fa-solid fa-robot text-4xl text-gray-700 mb-4"></i>
                                <h3 class="text-white font-black text-xl mb-2 uppercase">Auto DJ Active</h3>
                                <p class="text-gray-500 text-sm max-w-sm tracking-wide uppercase font-bold">Non-stop curated Contrast selections streaming through the night.</p>
                            </div>
                        )}
                    </div>
                </section>
            ))}

        </div>
    </div>
</Layout>

<style is:global>
    /* Ensure sticky day headers stay below the fixed site navigation */
    .day-header-sticky {
        top: 64px; /* Matches header height (h-16) */
    }
</style>