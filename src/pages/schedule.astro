---
// src/pages/schedule.astro
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro'; 
import { getCollection, getEntry } from 'astro:content';

// 1. DATA FETCHING
const scheduleDoc = await getEntry('schedule', 'master');
const rawSlots = scheduleDoc?.data?.allSlots || [];
const allShows = await getCollection('shows');
const allDjs = await getCollection('djs');

// 2. TIME LOGIC (UK Time Synchronization)
const ukTimeOptions = { timeZone: 'Europe/London' };
const dateInUK = new Date(new Date().toLocaleString('en-US', ukTimeOptions));
const currentDayIndex = dateInUK.getDay(); 
const currentMins = dateInUK.getHours() * 60 + dateInUK.getMinutes();

// Mapping for your 1-mon, 2-tue naming convention
const daysArray = ['7-sun', '1-mon', '2-tue', '3-wed', '4-thu', '5-fri', '6-sat'];
const currentDayStr = daysArray[currentDayIndex];
const yesterdayStr = daysArray[(currentDayIndex + 6) % 7];

function timeToMins(timeStr: string) {
    if (!timeStr) return 0;
    let [h, m] = timeStr.split(':').map(Number);
    if (h === 24) h = 0; 
    return h * 60 + m;
}

// 3. RESOLVE RELATIONSHIPS & LIVE STATUS
const scheduleDetailed = rawSlots.map((slot) => {
    const isAutoDj = slot.show === 'Auto DJ' || slot.show === 'auto-dj';
    
    const showEntry = !isAutoDj ? allShows.find(s => 
        s.id === slot.show || 
        s.data.title === slot.show ||
        s.id === slot.show.toLowerCase().replace(/\s+/g, '-').replace(/&/g, 'and')
    ) : null;

    const firstHostId = showEntry?.data?.hosts?.[0];
    
    const djEntry = firstHostId ? allDjs.find(d => {
        const safeId = d.id.replace(/\.[^/.]+$/, ""); 
        return safeId === firstHostId || d.data.slug === firstHostId || d.id === firstHostId;
    }) : null;

    let isLive = false;
    const startMins = timeToMins(slot.startTime);
    const endMins = timeToMins(slot.endTime || "00:00");
    const crossesMidnight = endMins <= startMins && endMins !== 0;

    if (slot.day === currentDayStr) {
        let adjustedEndMins = crossesMidnight ? endMins + 1440 : (endMins === 0 ? 1440 : endMins);
        if (currentMins >= startMins && currentMins < adjustedEndMins) isLive = true;
    } 
    else if (slot.day === yesterdayStr && crossesMidnight) {
        if (currentMins < endMins) isLive = true;
    }

    return { 
        slot, 
        isLive, 
        isAutoDj,
        showData: showEntry?.data, 
        djData: djEntry?.data,
        displayName: isAutoDj ? "Contrast Selection" : (showEntry?.data.title || slot.show),
        djId: djEntry?.id?.replace(/\.[^/.]+$/, "") || firstHostId 
    };
});

const currentLiveSlot = scheduleDetailed.find(item => item.isLive);
const currentShowName = currentLiveSlot ? currentLiveSlot.displayName : "Auto DJ Mix";

const daysOfWeek = [
    { id: '1-mon', label: 'Monday' },
    { id: '2-tue', label: 'Tuesday' },
    { id: '3-wed', label: 'Wednesday' },
    { id: '4-thu', label: 'Thursday' },
    { id: '5-fri', label: 'Friday' },
    { id: '6-sat', label: 'Saturday' },
    { id: '7-sun', label: 'Sunday' }
];

const groupedSchedule = daysOfWeek.map(day => {
    return {
        ...day,
        shows: scheduleDetailed
            .filter(item => item.slot.day === day.id)
            .sort((a, b) => a.slot.startTime.localeCompare(b.slot.startTime))
    };
});
---

<Layout title="Station Schedule | Contrast Radio" currentShow={currentShowName}>
    
    <Hero 
        title="STATION" 
        accent="SCHEDULE" 
        subtextText="Curated Transmission" 
        subtextHighlight="Across the Globe"
    />

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-32">
        <div class="max-w-5xl mx-auto space-y-20">
            
            {groupedSchedule.map(dayGroup => (
                <section class="space-y-8 scroll-mt-28" id={`day-${dayGroup.id}`}>
                    
                    <div class="sticky-day-header sticky z-30 py-4 bg-brand-dark/95 backdrop-blur-xl border-b border-white/5 flex items-center justify-between transition-all duration-300">
                        <h2 class="text-4xl md:text-5xl font-black uppercase italic tracking-tighter text-white">
                            {dayGroup.label}
                        </h2>

                        {dayGroup.id === currentDayStr && (
                            <div class="flex items-center gap-3">
                                <span class="w-2 h-2 rounded-full bg-brand-accent animate-ping"></span>
                                <span class="hidden md:block text-[10px] font-black text-brand-accent tracking-[0.3em] uppercase italic">Live Today</span>
                            </div>
                        )}
                    </div>
                    
                    <div class="grid grid-cols-1 gap-6">
                        {dayGroup.shows.length > 0 ? (
                            dayGroup.shows.map(item => (
                                <div class={`relative flex flex-col md:flex-row md:items-center p-8 md:p-10 rounded-[2.5rem] border transition-all duration-700 group ${item.isLive ? 'bg-brand-accent/10 border-brand-accent/40 shadow-[0_0_60px_rgba(255,59,59,0.08)]' : 'bg-brand-surface/40 border-white/5 hover:border-white/10 hover:bg-brand-surface/60'}`}>
                                    
                                    <div class="flex-shrink-0 w-44 mb-6 md:mb-0">
                                        <div class={`text-xl md:text-2xl font-black tracking-tighter ${item.isLive ? 'text-white' : 'text-gray-400'}`}>
                                            {item.slot.startTime} — {item.slot.endTime || "00:00"}
                                        </div>
                                        {item.isLive && (
                                            <div class="flex items-center gap-2 mt-3">
                                                <span class="w-2 h-2 rounded-full bg-brand-accent"></span>
                                                <span class="text-[11px] font-black text-brand-accent tracking-[0.2em] uppercase italic">On Air Now</span>
                                            </div>
                                        )}
                                    </div>

                                    <div class="flex-grow md:px-12">
                                        <div class="flex flex-wrap items-center gap-4 mb-4">
                                            <h3 class="text-3xl md:text-4xl font-black text-white group-hover:text-brand-accent transition-colors uppercase italic leading-none">
                                                {item.displayName}
                                            </h3>
                                            <span class={`text-[10px] font-black px-3 py-1 rounded-full uppercase tracking-[0.2em] border transition-colors ${item.isLive ? 'bg-brand-accent/20 border-brand-accent/40 text-white' : 'bg-gray-800 border-gray-700 text-gray-500'}`}>
                                                {item.isAutoDj ? "Auto Mix" : (item.showData?.genre || "Underground")}
                                            </span>
                                        </div>
                                        
                                        {!item.isAutoDj && item.showData?.description && (
                                            <p class="text-sm md:text-base text-gray-500 leading-relaxed max-w-2xl line-clamp-2 group-hover:text-gray-400 transition-colors font-medium">
                                                {item.showData.description}
                                            </p>
                                        )}
                                    </div>

                                    <div class="flex items-center gap-5 mt-10 md:mt-0 md:min-w-[280px] justify-end border-t md:border-t-0 border-white/5 pt-8 md:pt-0">
                                        <div class="flex flex-col text-right">
                                            <span class="text-[9px] font-black text-gray-600 uppercase tracking-widest mb-1">Presented by</span>
                                            <span class={`font-black text-lg uppercase italic leading-none transition-colors ${item.isLive ? 'text-white' : 'text-gray-400'}`}>
                                                {item.isAutoDj ? "Contrast Radio" : (item.djData?.name || "Guest DJ")}
                                            </span>
                                        </div>
                                        <div class={`w-14 h-14 rounded-full overflow-hidden flex items-center justify-center text-xl transition-all duration-700 shadow-2xl ${item.isLive ? 'ring-2 ring-brand-accent scale-110' : 'bg-gray-800 border border-gray-700 grayscale opacity-40'}`}>
                                            {item.djData?.avatar && !item.isAutoDj ? (
                                                <img src={item.djData.avatar} alt={item.djData?.name} class="w-full h-full object-cover" />
                                            ) : (
                                                <i class={`fa-solid ${item.isAutoDj ? 'fa-compact-disc' : 'fa-user'} ${item.isLive && item.isAutoDj ? 'fa-spin-slow' : ''}`}></i>
                                            )}
                                        </div>
                                    </div>
                                    
                                    <div class="absolute inset-0 bg-gradient-to-tr from-brand-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity rounded-[2.5rem] pointer-events-none"></div>
                                </div>
                            ))
                        ) : (
                            <div class="flex flex-col items-center justify-center py-24 px-10 rounded-[3rem] bg-brand-surface/30 border-2 border-dashed border-white/5 text-center group">
                                <i class="fa-solid fa-compact-disc text-5xl text-gray-700 mb-6 group-hover:text-brand-accent group-hover:rotate-90 transition-all duration-1000"></i>
                                <h3 class="text-white font-black text-2xl mb-3 uppercase italic">Contrast Selection Active</h3>
                                <p class="text-gray-500 text-sm max-w-sm tracking-widest uppercase font-bold">Curated underground sounds streaming non-stop through the session.</p>
                            </div>
                        )}
                    </div>
                </section>
            ))}

        </div>
    </div>
</Layout>

<style is:global>
    /* THE SURGICAL OFFSET:
       96px (Header) + 2px (Hairline Gap) = 98px.
       This prevents the 'digging in' without creating a massive void.
    */
    .sticky-day-header {
        top: 98px !important; 
    }

    /* Mobile specific tweak for even tighter screens */
    @media (max-width: 768px) {
        .sticky-day-header {
            top: 97px !important; 
        }
    }

    .fa-spin-slow { animation: spin 10s linear infinite; }
    @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
