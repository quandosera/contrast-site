---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. DATA FETCHING - Preserving your original Keystatic logic
const allFlyers = await getCollection('flyers');
const sortedFlyers = allFlyers.sort((a, b) => b.id.localeCompare(a.id));
---

<Layout title="Event Flyers | Contrast Radio">
    
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1514525253161-7a46d19cd819?auto=format&fit=crop&w=1920&q=80" alt="Concert Atmosphere" class="w-full h-full object-cover opacity-20" />
            <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#13111C]/80 to-[#13111C]"></div>
        </div>
        <div class="container mx-auto px-4 relative z-10 text-center">
            <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase italic mb-4">
                EVENT <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#b77bed] to-[#9b51e0]">FLYERS</span>
            </h1>
            <p class="text-gray-400 font-bold tracking-widest uppercase text-sm">Visuals from our past and upcoming Contrast Radio sessions</p>
        </div>
    </section>

    <div class="container mx-auto px-4 sm:px-6 lg:px-8 pb-24">
        
        <!-- Archive Header -->
        <div class="max-w-4xl mx-auto text-center mb-16">
            <div class="flex items-center justify-center gap-3 mb-6">
                <div class="w-12 h-[1px] bg-gray-800"></div>
                <div class="text-[#9b51e0] text-xl"><i class="fa-solid fa-images"></i></div>
                <h2 class="text-2xl font-black uppercase italic tracking-tight">The Archive</h2>
                <div class="w-12 h-[1px] bg-gray-800"></div>
            </div>
            <p class="text-gray-400 leading-relaxed text-lg italic">
                Step into the visual world of Contrast Radio. A collection of event flyers from our club nights, guest residencies, and special broadcasts across the city.
            </p>
        </div>

        <!-- Flyer Grid -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 sm:gap-8">
            {sortedFlyers.length > 0 ? (
                sortedFlyers.map(flyer => (
                    <button class="flyer-card group relative rounded-2xl overflow-hidden aspect-[4/5] bg-[#1E1B29] border border-gray-800/60 text-left transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-purple-500/10 active:scale-95" aria-label={`View full flyer for ${flyer.data.title}`}>
                        {flyer.data.image ? (
                            <img src={flyer.data.image} alt={flyer.data.title} class="flyer-img w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" />
                        ) : (
                            <div class="w-full h-full flex flex-col items-center justify-center text-gray-600 p-6 text-center">
                                <i class="fa-solid fa-image text-3xl mb-2 opacity-20"></i>
                                <span class="text-[10px] font-black uppercase tracking-widest leading-tight">No Image Provided</span>
                            </div>
                        )}
                        
                        <!-- Overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-black/95 via-black/20 to-transparent flex flex-col justify-end p-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                            <div class="flex flex-col transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                <span class="text-[#b77bed] text-[9px] font-black uppercase tracking-widest mb-1">Session Visual</span>
                                <h3 class="text-white font-black text-sm leading-tight uppercase italic">{flyer.data.title}</h3>
                            </div>
                        </div>
                    </button>
                ))
            ) : (
                <div class="col-span-full flex flex-col items-center justify-center py-32 px-6 rounded-3xl bg-[#1E1B29]/30 border-2 border-dashed border-gray-800 text-center">
                    <i class="fa-regular fa-folder-open text-5xl text-gray-700 mb-6"></i>
                    <h3 class="text-white font-black text-xl mb-2 uppercase italic">The Archive is Empty</h3>
                    <p class="text-gray-500 text-sm max-w-xs tracking-wide uppercase font-bold">No flyers uploaded yet. Head to the admin panel to add some!</p>
                </div>
            )}
        </div>

    </div>

    <!-- Premium Flyer Modal -->
    <div id="flyer-modal" class="fixed inset-0 z-[60] bg-black/95 backdrop-blur-md hidden flex items-center justify-center p-4 transition-opacity duration-300 opacity-0" role="dialog" aria-modal="true">
        <button class="absolute top-6 right-6 text-white hover:text-[#9b51e0] text-4xl w-12 h-12 flex items-center justify-center bg-black/40 rounded-full transition-all hover:scale-110 active:scale-95 shadow-lg z-[70]">&times;</button>
        <div class="relative max-w-full max-h-[85vh] group">
            <img id="modal-img" src="" alt="Full Flyer" class="max-w-full max-h-[85vh] object-contain rounded-lg shadow-[0_0_50px_rgba(0,0,0,0.8)] border border-white/5 scale-95 transition-transform duration-300">
        </div>
    </div>

</Layout>

<script>
    // Bind to astro:page-load for persistent audio compatibility
    document.addEventListener('astro:page-load', () => {
        const flyerCards = document.querySelectorAll('.flyer-card');
        const modal = document.getElementById('flyer-modal');
        const modalImg = document.getElementById('modal-img') as HTMLImageElement;
        const closeBtn = modal?.querySelector('button');

        if (!modal || !modalImg) return;

        flyerCards.forEach(card => {
            card.addEventListener('click', () => {
                const img = card.querySelector('img') as HTMLImageElement;
                if (img) {
                    modalImg.src = img.src;
                    modal.classList.remove('hidden');
                    // Start fade & scale animation
                    setTimeout(() => { 
                        modal.classList.replace('opacity-0', 'opacity-100'); 
                        modalImg.classList.replace('scale-95', 'scale-100'); 
                    }, 10);
                    document.body.style.overflow = 'hidden';
                }
            });
        });

        const closeModal = () => {
            if (modal && modalImg) {
                modal.classList.replace('opacity-100', 'opacity-0');
                modalImg.classList.replace('scale-100', 'scale-95');
                setTimeout(() => { 
                    modal.classList.add('hidden'); 
                    modalImg.src = ""; // Cleanup
                    document.body.style.overflow = ''; 
                }, 300);
            }
        };

        closeBtn?.addEventListener('click', closeModal);
        modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
        document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    });
</script>
