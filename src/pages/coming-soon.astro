---
// Version: Cinematic Atmosphere. Removed EQ bars for a cleaner, high-end look.
---
<!doctype html>
<html lang="en-GB" class="h-full bg-brand-dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Launching Soon | Contrast Radio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="h-full flex flex-col items-center justify-center text-white overflow-hidden relative antialiased font-['Inter',sans-serif] bg-[#050505]">
    
    <div class="absolute inset-0 z-0 overflow-hidden">
        <img 
            src="https://images.unsplash.com/photo-1470225620780-dba8ba36b745?q=80&w=2070&auto=format&fit=crop" 
            alt="" 
            class="w-full h-full object-cover opacity-20 pointer-events-none select-none grayscale animate-slow-zoom" 
        />
        
        <div class="absolute top-[-10%] left-[-10%] w-[70vw] h-[70vw] bg-brand-accent/10 rounded-full blur-[120px] animate-drift-slow pointer-events-none"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[60vw] h-[60vw] bg-brand-accent/5 rounded-full blur-[120px] animate-drift-alternate pointer-events-none"></div>
        
        <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/40 via-brand-dark/80 to-brand-dark pointer-events-none"></div>
        <div class="absolute inset-0 opacity-[0.05] bg-[url('https://grainy-gradients.vercel.app/noise.svg')] pointer-events-none"></div>
    </div>

    <div class="relative z-10 w-full max-w-6xl px-6 py-12 text-center flex flex-col items-center">
        
        <div class="mb-12 md:mb-16 flex flex-col items-center">
            <div class="relative inline-flex items-center justify-center bg-brand-surface/40 backdrop-blur-2xl px-10 py-5 rounded-[2rem] border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
                <h1 class="text-3xl md:text-5xl font-black italic tracking-tighter uppercase leading-none">
                    CONTRAST<span class="text-brand-accent drop-shadow-[0_0_15px_rgba(255,59,59,0.5)]">RADIO</span>
                </h1>
            </div>
            
            <div class="mt-6 flex items-center justify-center gap-3">
                <div class="relative flex items-center justify-center">
                    <span class="absolute w-3 h-3 bg-brand-accent rounded-full animate-ping opacity-60"></span>
                    <span class="w-2 h-2 rounded-full bg-brand-accent relative z-10"></span>
                </div>
                <span class="text-[10px] md:text-xs font-black uppercase tracking-[0.6em] text-gray-500 italic">Signal Incoming</span>
            </div>
        </div>
        
        <div class="mb-16 w-full flex flex-col items-center overflow-visible">
            <h2 class="text-7xl sm:text-8xl md:text-[10rem] font-black uppercase italic tracking-tighter leading-[0.8] select-none text-center overflow-visible">
                <span class="text-white drop-shadow-[0_10px_20px_rgba(0,0,0,0.5)] block">COMING</span> 
                <span class="inline-block text-transparent bg-clip-text bg-gradient-to-br from-white via-white to-brand-accent/80 drop-shadow-[0_0_40px_rgba(255,59,59,0.3)] px-10">
                    SOON
                </span>
            </h2>
        </div>
        
        <div id="countdown" class="grid grid-cols-4 gap-4 md:gap-8 w-full max-w-2xl mx-auto">
            {[ 
                { id: "days", label: "Days", color: "text-brand-accent" },
                { id: "hours", label: "Hours", color: "text-white" },
                { id: "minutes", label: "Mins", color: "text-white" },
                { id: "seconds", label: "Secs", color: "text-white" } 
            ].map((item) => (
                <div class="flex flex-col items-center">
                    <div class="bg-brand-surface/40 backdrop-blur-md border border-white/5 rounded-2xl md:rounded-[2.5rem] w-full aspect-square flex flex-col items-center justify-center shadow-2xl relative overflow-hidden group transition-all hover:border-brand-accent/30">
                        <span id={item.id} class={`${item.color} text-3xl sm:text-5xl md:text-7xl font-black tracking-tighter block tabular-nums leading-none z-10`}>00</span>
                        <div class="absolute bottom-0 w-full h-1/2 bg-gradient-to-t from-brand-accent/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    </div>
                    <span class="mt-4 text-[9px] md:text-[11px] uppercase tracking-[0.4em] text-gray-600 font-black italic">{item.label}</span>
                </div>
            ))}
        </div>
    </div>

    <script is:inline>
        const targetDate = new Date(2026, 9, 22, 11, 0, 0).getTime();
        function updateCountdown() {
            const now = new Date().getTime();
            const distance = targetDate - now;
            if (distance < 0) return;
            const d = Math.floor(distance / (1000 * 60 * 60 * 24));
            const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((distance % (1000 * 60)) / 1000);
            const safeSet = (id, val) => {
                const el = document.getElementById(id);
                if (el) el.innerText = val.toString().padStart(2, '0');
            };
            safeSet("days", d); safeSet("hours", h); safeSet("minutes", m); safeSet("seconds", s);
        }
        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
</body>
</html>

<style>
    /* Slow Ken Burns Effect */
    @keyframes slowZoom {
        0% { transform: scale(1); }
        100% { transform: scale(1.15); }
    }
    .animate-slow-zoom {
        animation: slowZoom 30s infinite alternate ease-in-out;
    }

    /* Drifting Spotlight Animations */
    @keyframes drift {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(15%, 10%) scale(1.1); }
        100% { transform: translate(0, 0) scale(1); }
    }
    @keyframes driftAlternate {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(-10%, -15%) scale(0.9); }
        100% { transform: translate(0, 0) scale(1); }
    }
    .animate-drift-slow {
        animation: drift 25s infinite ease-in-out;
    }
    .animate-drift-alternate {
        animation: driftAlternate 35s infinite ease-in-out;
    }

    html, body { 
        overflow: hidden; 
        height: 100%; 
        width: 100%; 
        background-color: #050505; 
    }
</style>
