---
// src/pages/coming-soon.astro
---
<!doctype html>
<html lang="en-GB" class="h-full bg-[#0a090f]">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Launching Soon | Contrast Radio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="h-full flex items-center justify-center text-white overflow-hidden relative antialiased font-['Inter',sans-serif]">
    
    <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1598488035139-bdbb2231ce04?q=80&w=1920&auto=format&fit=crop" alt="Radio Studio" class="w-full h-full object-cover opacity-10 scale-110 blur-[3px]" />
        
        <div class="absolute inset-0 opacity-[0.03] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
        
        <div class="absolute inset-0 bg-gradient-to-b from-[#13111C]/40 via-[#0a090f] to-black"></div>
        
        <div class="absolute top-1/4 -left-20 w-[500px] h-[500px] bg-brand-accent/10 rounded-full blur-[120px] animate-pulse"></div>
        <div class="absolute bottom-1/4 -right-20 w-[500px] h-[500px] bg-brand-accent/10 rounded-full blur-[120px] animate-pulse" style="animation-delay: 1s;"></div>
    </div>

    <div class="relative z-10 w-full max-w-4xl px-6 py-12 text-center">
        
        <div class="mb-16 inline-block">
            <div class="relative flex items-center justify-center bg-[#13111C] px-10 py-5 rounded-2xl border border-white/5 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
                <h1 class="text-4xl md:text-6xl font-black italic tracking-tighter uppercase leading-none">
                    CONTRAST<span class="text-brand-accent drop-shadow-[0_0_15px_rgba(255,59,59,0.5)]">RADIO</span>
                </h1>
            </div>
            <div class="mt-6 flex items-center justify-center gap-3">
                <span class="w-2.5 h-2.5 rounded-full bg-brand-accent animate-ping"></span>
                <span class="text-xs font-black uppercase tracking-[0.5em] text-gray-500">Signal Incoming</span>
            </div>
        </div>
        
        <h2 class="text-6xl md:text-[9rem] font-black uppercase tracking-tighter mb-16 leading-[0.85] select-none">
            COMING <br/> 
            <span class="relative inline-block">
                <span class="text-white drop-shadow-[0_0_30px_rgba(255,255,255,0.2)]">SOON</span>
                <span class="absolute -inset-1 blur-2xl bg-brand-accent/20 -z-10"></span>
            </span><span class="text-brand-accent">.</span>
        </h2>
        
        <div id="countdown" class="flex justify-center gap-6 md:gap-12">
            {[ 
                { id: "days", label: "Days", color: "text-brand-accent" },
                { id: "hours", label: "Hours", color: "text-white" },
                { id: "minutes", label: "Mins", color: "text-white" },
                { id: "seconds", label: "Secs", color: "text-white" } 
            ].map((item) => (
                <div class="flex flex-col items-center">
                    <div class="relative group">
                        <span id={item.id} class={`${item.color} text-4xl md:text-7xl font-black tracking-tighter mb-2 block tabular-nums`}>00</span>
                        <div class="absolute -bottom-1 left-0 w-full h-[2px] bg-white/5 scale-x-0 group-hover:scale-x-100 transition-transform"></div>
                    </div>
                    <span class="text-[10px] md:text-xs uppercase tracking-[0.3em] text-gray-500 font-black">{item.label}</span>
                </div>
            ))}
        </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full h-1.5 flex items-end justify-center gap-1.5 px-2 opacity-30">
        {Array.from({ length: 12 }).map((_, i) => (
            <div class={`bar w-full bg-gradient-to-t from-brand-accent to-white/40`} style={`animation-delay: ${i * 0.15}s`}></div>
        ))}
    </div>

    <script is:inline>
        // Target date fixed to October 22, 2026
        const targetDate = new Date(2026, 9, 22, 11, 0, 0).getTime();

        function updateCountdown() {
            const now = new Date().getTime();
            const distance = targetDate - now;

            if (distance < 0) {
                ["days", "hours", "minutes", "seconds"].forEach(id => {
                    document.getElementById(id).innerText = "00";
                });
                return;
            }

            const d = Math.floor(distance / (1000 * 60 * 60 * 24));
            const h = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((distance % (1000 * 60)) / 1000);

            const safeSet = (id, val) => {
                const el = document.getElementById(id);
                if (el) el.innerText = val.toString().padStart(2, '0');
            };

            safeSet("days", d);
            safeSet("hours", h);
            safeSet("minutes", m);
            safeSet("seconds", s);
        }

        setInterval(updateCountdown, 1000);
        updateCountdown();
    </script>
</body>
</html>

<style>
    /* Audio Bar Animation */
    @keyframes bar-grow { 
        0%, 100% { height: 8px; opacity: 0.3; } 
        50% { height: 45px; opacity: 1; } 
    }
    .bar { 
        animation: bar-grow 1.8s ease-in-out infinite; 
        border-radius: 4px 4px 0 0; 
        min-height: 8px;
    }

    /* Prevent mobile horizontal scroll */
    html, body {
        overflow-x: hidden;
        height: 100%;
        width: 100%;
    }
</style>
